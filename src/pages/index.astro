---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import BrandMarquee from '../components/landing/BrandMarquee.astro';
import Features from '../components/landing/Features.astro';
import PlatformGrid from '../components/landing/PlatformGrid.astro';
import Showcase from '../components/landing/Showcase.astro';
import Results from '../components/landing/Results.astro';
import WhyUs from '../components/landing/WhyUs.astro';
import Faq from '../components/landing/Faq.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import MotionController from '../components/common/MotionController.astro';
import { site } from '../site.config';
---

<BaseLayout 
  title={`${site.name} — Digital Strategy, Paid Advertising & Growth`}
  description={site.description}
>
  {/* 1. Hero with Kepler Orbit Graphic & 3D Elements */}
  <Hero />

  {/* 2. Clients, Brands & Business Partners (2 Opposite Scrolling Marquees) */}
  <BrandMarquee />

  {/* 3. Capabilities (Kepler Features Adaptation with Lucide Icons) */}
  <Features />

  {/* 4. Platforms & Tools We Work With (12 Official Platform Logos) */}
  <PlatformGrid />

  {/* 5. Featured Work (Kepler Showcase Visual Compositions) */}
  <Showcase />

  {/* 6. Verified Commercial Results (Animated Counters) */}
  <Results />

  {/* 7. Why Starts Digital (Kepler Card Grid) */}
  <WhyUs />

  {/* 8. Frequently Asked Questions (Kepler Accordion) */}
  <Faq />

  {/* 9. Final Call to Action (Kepler Banner) */}
  <FinalCta />

  {/* 10. Motion Controller (IntersectionObserver Scroll Reveals & Counters) */}
  <MotionController />
</BaseLayout>
