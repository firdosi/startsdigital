---
import BaseLayout from '../layouts/BaseLayout.astro';

// Section Components
import Hero from '../components/sections/Hero.astro';
import BrandExperience from '../components/sections/BrandExperience.astro';
import Services from '../components/sections/Services.astro';
import FeaturedWork from '../components/sections/FeaturedWork.astro';
import Results from '../components/sections/Results.astro';
import PlatformsTools from '../components/sections/PlatformsTools.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import FounderSection from '../components/sections/FounderSection.astro';
import Process from '../components/sections/Process.astro';
import FAQ from '../components/sections/FAQ.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';
---

<BaseLayout 
  title="Digital Strategy, Marketing & Technology Agency" 
  description="Starts Digital helps businesses grow through performance marketing, website development, technical SEO, creative content and practical AI digital systems."
>
  {/* 1. Hero Section (Dark Editorial) */}
  <Hero />

  {/* 2. Brand Experience Continuous Marquee (Dark Editorial) */}
  <BrandExperience />

  {/* 3. Core Services Bento Box (Dark Editorial) */}
  <Services />

  {/* 4. Editorial Featured Work Showcase (Dark Editorial) */}
  <FeaturedWork />

  {/* 5. Commercial Results (Dark Editorial) */}
  <Results />

  {/* 6. Platforms & Tools (Dark Editorial) */}
  <PlatformsTools />

  {/* 7. Why Starts Digital / Operating Model (Dark Editorial) */}
  <WhyUs />

  {/* 8. Founder Section (Disabled until verified media is provided) */}
  <FounderSection enabled={false} />

  {/* 9. Methodology & Process Timeline (Dark Editorial) */}
  <Process />

  {/* 10. Frequently Asked Questions (Dark Editorial) */}
  <FAQ />

  {/* 11. Final Contact CTA (Dark Editorial) */}
  <ContactCTA />
</BaseLayout>
