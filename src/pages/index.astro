---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import Features from '../components/landing/Features.astro';
import Showcase from '../components/landing/Showcase.astro';
import Results from '../components/landing/Results.astro';
import WhyUs from '../components/landing/WhyUs.astro';
import Faq from '../components/landing/Faq.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import { site } from '../site.config';
---

<BaseLayout 
  title={`${site.name} — Digital Strategy, Paid Advertising & Growth`}
  description={site.description}
>
  {/* 1. Hero with Orbit Graphic & Brand Strip */}
  <Hero />

  {/* 2. Capabilities (Kepler Features Section Adaptation) */}
  <Features />

  {/* 3. Featured Work (Kepler Showcase Section Adaptation) */}
  <Showcase />

  {/* 4. Verified Commercial Results (Kepler Pricing Section Visual Adaptation) */}
  <Results />

  {/* 5. Why Starts Digital (Kepler Testimonials Section Visual Adaptation) */}
  <WhyUs />

  {/* 6. Frequently Asked Questions (Kepler FAQ Accordion) */}
  <Faq />

  {/* 7. Final Call to Action (Kepler Final CTA Banner) */}
  <FinalCta />
</BaseLayout>
