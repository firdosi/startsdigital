---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/landing/Hero.astro';
import BrandMarquee from '../components/landing/BrandMarquee.astro';
import Features from '../components/landing/Features.astro';
import Showcase from '../components/landing/Showcase.astro';
import Results from '../components/landing/Results.astro';
import PlatformGrid from '../components/landing/PlatformGrid.astro';
import WhyUs from '../components/landing/WhyUs.astro';
import Process from '../components/landing/Process.astro';
import Faq from '../components/landing/Faq.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import MotionController from '../components/common/MotionController.astro';
import { site } from '../site.config';
---

<BaseLayout 
  title={`${site.name} — Digital Marketing, Paid Ads, Websites & AI Systems`}
  description={site.description}
>
  {/* 1. Hero with Layered Visual Composition & Verified Metrics */}
  <Hero />

  {/* 2. Clients, Brands & Business Partners */}
  <BrandMarquee />

  {/* 3. Capabilities / Services (Varied Editorial Layout) */}
  <Features />

  {/* 4. Featured Work (3 Distinct Large Visual Compositions) */}
  <Showcase />

  {/* 5. Verified Commercial Results (Oversized Typography & Counters) */}
  <Results />

  {/* 6. Platforms & Tools We Work With (12 Official Logotypes) */}
  <PlatformGrid />

  {/* 7. Why Starts Digital (Editorial Credibility & Operator Perspective) */}
  <WhyUs />

  {/* 8. Working Process (Horizontal Desktop / Vertical Mobile Journey) */}
  <Process />

  {/* 9. Frequently Asked Questions (Clean Accordion) */}
  <Faq />

  {/* 10. Final Call to Action (Bold Conversion Section) */}
  <FinalCta />

  {/* Motion Controller System */}
  <MotionController />
</BaseLayout>
