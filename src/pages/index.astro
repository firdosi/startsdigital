---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import Container from '../components/ui/Container.astro';

// Section Component Imports
import Results from '../components/sections/Results.astro';
import Services from '../components/sections/Services.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import Process from '../components/sections/Process.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import AboutPreview from '../components/sections/AboutPreview.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';

const capabilities = [
  'Digital Strategy',
  'Meta Advertising',
  'SEO',
  'Website Development',
  'Content',
  'AI Marketing Solutions',
];
---

<BaseLayout 
  title="AI-Powered Digital Marketing Agency" 
  description="Starts Digital provides digital strategy, Meta advertising, SEO, website development, creative content and practical AI marketing solutions for growing businesses."
>
  <!-- Homepage Hero Section -->
  <section class="relative pt-32 pb-24 md:pt-44 md:pb-36 overflow-hidden">
    <!-- Subtle Grid Background Composition for Premium Technical Feel -->
    <div 
      class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(102,112,133,0.04)_1px,transparent_1px),linear-gradient(to_bottom,rgba(102,112,133,0.04)_1px,transparent_1px)] bg-[size:4.5rem_4.5rem]"
      aria-hidden="true"
    ></div>

    <Container class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Left Column: Primary Copy and Call to Actions -->
      <div class="lg:col-span-7 flex flex-col space-y-6 md:space-y-8">
        <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
          STRATEGY &middot; MARKETING &middot; TECHNOLOGY
        </span>
        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-brand-white leading-[1.1] max-w-2xl">
          Digital marketing built to <span class="text-brand-blue">start</span>, grow and scale businesses online.
        </h1>
        <p class="font-body text-base sm:text-lg font-light leading-relaxed text-brand-text max-w-xl">
          Starts Digital combines strategy, paid advertising, SEO, websites, content and practical AI solutions to help businesses build a stronger digital presence and create measurable opportunities.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <Button 
            href="#work" 
            variant="primary"
          >
            View Our Work
          </Button>
          <Button 
            href="#contact" 
            variant="secondary"
          >
            Discuss Your Project
          </Button>
        </div>
      </div>

      <!-- Right Column: Restrained Capabilities Presentation -->
      <div class="lg:col-span-5">
        <div class="bg-brand-navy border border-brand-grey/10 rounded-xl p-8 relative overflow-hidden">
          <!-- Subtle layout glow in corner to frame content without neon excessive gradients -->
          <div class="absolute -top-12 -right-12 h-32 w-32 bg-brand-blue/5 blur-3xl rounded-full" aria-hidden="true"></div>
          
          <h3 class="font-heading text-xs font-bold tracking-widest text-brand-grey/50 uppercase mb-6 pb-2 border-b border-brand-grey/5">
            Core Capabilities
          </h3>
          <ul class="space-y-4">
            {
              capabilities.map((item, index) => (
                <li class="flex items-center justify-between group border-b border-brand-grey/5 pb-3.5 last:border-0 last:pb-0">
                  <div class="flex items-center gap-4">
                    <span class="font-heading text-xs text-brand-text/45 font-semibold">0{index + 1}</span>
                    <span class="font-body text-sm sm:text-base font-normal text-brand-white group-hover:text-brand-blue transition-colors duration-200">
                      {item}
                    </span>
                  </div>
                  <span class="text-brand-teal text-xs font-semibold tracking-wider uppercase opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-1 group-hover:translate-x-0 font-heading">
                    Active &rarr;
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- Section 3: Results and Credibility -->
  <Results />

  <!-- Section 4: Services -->
  <Services />

  <!-- Section 5: Selected Work -->
  <SelectedWork />

  <!-- Section 6: Working Process -->
  <Process />

  <!-- Section 7: Why Starts Digital -->
  <WhyUs />

  <!-- Section 8: About Preview -->
  <AboutPreview />

  <!-- Section 9: Final Contact CTA -->
  <ContactCTA />
</BaseLayout>
