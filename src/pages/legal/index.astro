---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import MotionController from '../../components/common/MotionController.astro';
import { site } from '../../site.config';
import { ShieldCheck, Mail, Lock, BarChart2, Award } from '@lucide/astro';
---

<BaseLayout
  title="Legal Notice and Portfolio Disclaimer — Starts Digital"
  description="Legal notice, portfolio use disclaimer, confidentiality policy and contact information for Starts Digital."
  type="website"
>
  <!-- Deep Navy Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-24 rounded-b-[40px] shadow-2xl overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <div data-motion="scale-in">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ddff35]">
          <ShieldCheck class="size-4 text-[#ddff35]" />
          <span>LEGAL & GOVERNANCE</span>
        </span>
      </div>

      <h1 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[36px] sm:text-[48px] lg:text-[56px] text-white leading-[1.1] tracking-[-0.03em] max-w-[840px] mx-auto">
        Legal Notice & Portfolio Disclaimer
      </h1>

      <p data-motion="fade-up" data-motion-delay="200" class="font-body text-base sm:text-lg text-slate-200 max-w-[640px] mx-auto leading-[1.65]">
        Important information regarding portfolio attribution, client trademarks, confidentiality, and historical performance reporting.
      </p>
    </Container>
  </section>

  <!-- Legal Content Section -->
  <section class="py-16 lg:py-24 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
    <Container class="max-w-[960px] px-6 sm:px-8 space-y-12">
      
      <!-- Portfolio Use & Trademark Disclaimer -->
      <div data-motion="fade-up" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#ff762b]">
          <Award class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33]">
            Portfolio Use & Trademark Disclaimer
          </h2>
        </div>

        <div class="font-body text-base text-slate-700 leading-relaxed space-y-4 pt-2">
          <p>
            Starts Digital displays selected client names, trademarks, public project visuals and project descriptions to identify professional experience and work completed.
          </p>
          <p class="font-medium text-[#061d33] bg-[#f7f4ed] p-4 rounded-xl border border-slate-200">
            Client and third-party names, logos and trademarks belong to their respective owners. They are displayed solely to identify projects and professional experience. Their inclusion does not imply endorsement, sponsorship, partnership or affiliation unless expressly stated.
          </p>
          <p>
            Selected images, videos, advertisements, website screenshots and other portfolio materials may represent work created, managed or supported by Starts Digital and may also contain intellectual property owned by the relevant client or third-party rights holders.
          </p>
          <p>
            No ownership of client trademarks, brands or unrelated third-party intellectual property is claimed.
          </p>
        </div>
      </div>

      <!-- Confidentiality -->
      <div data-motion="fade-up" data-motion-delay="100" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#9a83f5]">
          <Lock class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33]">
            Confidentiality Policy
          </h2>
        </div>

        <div class="font-body text-base text-slate-700 leading-relaxed pt-2">
          <p>
            Starts Digital does not intentionally publish confidential campaign information, customer data, private communications, advertising-account access, internal dashboards or personally identifiable information.
          </p>
        </div>
      </div>

      <!-- Performance Information -->
      <div data-motion="fade-up" data-motion-delay="150" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#39c98a]">
          <BarChart2 class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33]">
            Performance Information
          </h2>
        </div>

        <div class="font-body text-base text-slate-700 leading-relaxed pt-2">
          <p>
            Any results shown are rounded historical figures supplied through first-party business records or project reporting. Results are provided as examples of prior work and do not guarantee future performance.
          </p>
        </div>
      </div>

      <!-- Contact -->
      <div data-motion="fade-up" data-motion-delay="200" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#ff514b]">
          <Mail class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33]">
            Contact & Attribution Inquiries
          </h2>
        </div>

        <div class="font-body text-base text-slate-700 leading-relaxed pt-2 space-y-3">
          <p>
            Requests concerning attribution, correction or removal may be sent to:
          </p>
          <div class="pt-1">
            <a 
              href={`mailto:${site.contact.email}`} 
              class="inline-flex items-center gap-2 font-mono font-semibold text-lg text-[#061d33] hover:text-[#ff762b] transition-colors underline"
            >
              <span>{site.contact.email}</span>
            </a>
          </div>
        </div>
      </div>

    </Container>
  </section>

  <MotionController />
</BaseLayout>
