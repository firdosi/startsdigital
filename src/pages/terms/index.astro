---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import MotionController from '../../components/common/MotionController.astro';
import { site } from '../../site.config';
import { FileText, AlertCircle, Link, Scale, Copyright } from '@lucide/astro';
---

<BaseLayout
  title="Terms of Use — Starts Digital"
  description="Terms of use governing website access, intellectual property, portfolio materials, and disclaimer of liability for Starts Digital."
  type="website"
>
  <!-- Deep Navy Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-24 rounded-b-[40px] shadow-2xl overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <div data-motion="scale-in">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ddff35]">
          <FileText class="size-4 text-[#ddff35]" />
          <span>TERMS & CONDITIONS</span>
        </span>
      </div>

      <h1 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[36px] sm:text-[48px] lg:text-[56px] text-white leading-[1.1] tracking-[-0.03em] max-w-[840px] mx-auto">
        Terms of Use
      </h1>

      <p data-motion="fade-up" data-motion-delay="200" class="font-body text-base sm:text-lg text-slate-200 max-w-[640px] mx-auto leading-[1.65]">
        These terms govern your access to and use of the website and portfolio materials published by Starts Digital.
      </p>
    </Container>
  </section>

  <!-- Content -->
  <section class="py-16 lg:py-24 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
    <Container class="max-w-[960px] px-6 sm:px-8 space-y-10">

      <!-- Informational Purpose -->
      <div data-motion="fade-up" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#ff762b]">
          <FileText class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl text-[#061d33]">
            1. Website Informational Purpose
          </h2>
        </div>
        <p class="font-body text-slate-700 leading-relaxed">
          This website is provided solely for informational and portfolio demonstration purposes to highlight the professional experience, services, and capabilities of Starts Digital. Accessing or viewing information on this website does not constitute a binding commercial agreement or client relationship.
        </p>
      </div>

      <!-- No Guaranteed Marketing Results -->
      <div data-motion="fade-up" data-motion-delay="100" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#9a83f5]">
          <AlertCircle class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl text-[#061d33]">
            2. Performance Disclaimer & Marketing Outcomes
          </h2>
        </div>
        <p class="font-body text-slate-700 leading-relaxed">
          Any historical campaign metrics, revenue figures, or project outcomes described on this website represent prior work examples based on first-party records. They do not constitute a promise or guarantee of future marketing results, sales, or campaign performance for any new engagement.
        </p>
      </div>

      <!-- Intellectual Property & Third-Party Trademarks -->
      <div data-motion="fade-up" data-motion-delay="150" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#39c98a]">
          <Copyright class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl text-[#061d33]">
            3. Intellectual Property & Third-Party Trademarks
          </h2>
        </div>
        <p class="font-body text-slate-700 leading-relaxed">
          Original website content, branding, page structure, and design assets belong to Starts Digital. Client names, logos, screenshots, and registered trademarks belong strictly to their respective corporate owners and are displayed solely for portfolio work identification. No endorsement, sponsorship, or transfer of intellectual property rights is implied.
        </p>
      </div>

      <!-- External Links & Liability -->
      <div data-motion="fade-up" data-motion-delay="200" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#ff514b]">
          <Link class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl text-[#061d33]">
            4. External Links & Limitation of Liability
          </h2>
        </div>
        <p class="font-body text-slate-700 leading-relaxed">
          This website may contain links to client websites or third-party web pages. Starts Digital does not control or assume responsibility for the content, privacy practices, or accuracy of third-party websites. Starts Digital shall not be liable for any indirect, incidental, or consequential damages resulting from reliance on website content.
        </p>
      </div>

      <!-- Governing Law Placeholder & Contact -->
      <div data-motion="fade-up" data-motion-delay="250" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg space-y-4">
        <div class="flex items-center gap-3 text-[#061d33]">
          <Scale class="size-6 shrink-0" />
          <h2 class="font-heading font-bold text-2xl text-[#061d33]">
            5. Legal Inquiries
          </h2>
        </div>
        <p class="font-body text-slate-700 leading-relaxed">
          These terms shall be interpreted in accordance with applicable legal principles governing digital service providers. If you have questions regarding these terms or website attribution, please reach out to:
        </p>
        <div class="pt-2">
          <a 
            href={`mailto:${site.contact.email}`} 
            class="font-mono font-semibold text-[#061d33] hover:text-[#ff762b] transition-colors underline text-lg"
          >
            {site.contact.email}
          </a>
        </div>
      </div>

    </Container>
  </section>

  <MotionController />
</BaseLayout>
