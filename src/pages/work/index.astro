---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Showcase from '../../components/landing/Showcase.astro';
import FinalCta from '../../components/landing/FinalCta.astro';
import MotionController from '../../components/common/MotionController.astro';
import { brands } from '../../data/brands';
import { site } from '../../site.config';

// Remaining approved brands
const remainingBrands = brands.filter((b) => b.id !== 'black-gold-fertilizer' && b.id !== 'rk-reno-solutions');
---

<BaseLayout 
  title="Client Work & Case Studies — Starts Digital"
  description="Selected campaigns, websites and growth projects supported by Starts Digital."
  type="website"
>
  <!-- Deep Navy Rounded Hero Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-28 rounded-b-[40px] shadow-2xl">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-bold uppercase tracking-widest text-[#ddff35]">
        <span>OUR WORK</span>
      </span>
      
      <!-- Hero Headline: Manrope 700, natural sentence case -->
      <h1 class="font-body font-bold text-[36px] sm:text-[54px] lg:text-[62px] text-white leading-[1.08] tracking-normal max-w-[800px] mx-auto">
        Work built around <span class="text-[#ff762b]">real business outcomes.</span>
      </h1>
      
      <p class="font-body text-base sm:text-[18px] text-slate-200 max-w-[680px] mx-auto leading-[1.6] font-normal">
        Selected campaigns, websites and growth projects supported by Starts Digital.
      </p>
    </Container>
  </section>

  <!-- 3 Large Image-Led Featured Projects -->
  <Showcase />

  <!-- Other Brands and Projects We Have Worked With -->
  <section class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
    <Container class="max-w-[1280px] px-6 sm:px-8 space-y-16">
      <div class="text-center max-w-3xl mx-auto space-y-3">
        <span class="text-xs font-bold font-mono uppercase tracking-widest text-[#ff762b] block">
          PORTFOLIO & PARTNERSHIPS
        </span>
        <h2 class="font-body font-bold text-[28px] sm:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15]">
          Other brands and projects we have worked with
        </h2>
        <p class="text-base sm:text-lg text-slate-700 font-body leading-[1.6] font-normal max-w-2xl mx-auto">
          Client accounts across e-commerce, international consultation, education, and regional service sectors.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {remainingBrands.map((b, idx) => (
          <div 
            class="reveal-on-scroll rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-md hover:shadow-xl hover:border-[#ff762b] transition-all duration-300 flex items-center gap-5 group"
            data-reveal-delay={idx * 50}
          >
            {b.logo && b.logoApproved ? (
              <div class="size-16 rounded-2xl bg-[#f7f4ed] p-2 flex items-center justify-center shrink-0 border border-slate-200">
                <img 
                  src={`${site.basePath}${b.logo}`} 
                  alt={`${b.name} logo`} 
                  class="max-h-10 max-w-12 object-contain grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all"
                />
              </div>
            ) : (
              <div class="size-16 rounded-2xl bg-[#061d33] text-white flex items-center justify-center font-body font-bold text-xl shrink-0">
                {b.name.charAt(0)}
              </div>
            )}
            
            <div>
              <h3 class="font-body font-semibold text-lg sm:text-xl text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-tight">
                {b.name}
              </h3>
              <p class="text-xs font-mono font-bold text-slate-500 uppercase mt-1">
                {b.category}
              </p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Approved Navy CTA Panel -->
  <FinalCta />

  <MotionController />
</BaseLayout>
