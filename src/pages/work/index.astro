---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/navigation/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import Container from '../../components/ui/Container.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { siteConfig, getAssetPath } from '../../data/site';

// Fetch case studies that are NOT drafts
const caseStudies = await getCollection('case-studies', ({ data }) => !data.draft);
// Sort case studies by order property
const sortedStudies = caseStudies.sort((a, b) => a.data.order - b.data.order);

// Additional experience data that are NOT full case studies yet
const additionalExperience = [
  {
    title: 'RK Reno Solutions',
    industry: 'Renovation and local services',
    services: ['SEO strategy', 'service-page development', 'website content', 'local search optimisation'],
    result: 'Built a structured SEO foundation targeting renovation and air-conditioning services in Kuala Lumpur and Selangor.'
  },
  {
    title: 'Immigration and Education Projects',
    industry: 'Immigration and education',
    services: ['Lead generation', 'websites', 'campaign content', 'AI videos', 'digital marketing systems'],
    result: 'Managed digital execution across immigration, education and international recruitment projects.'
  }
];

const breadcrumbsList = [
  { label: 'Work' }
];

const schemaItems = [
  { name: 'Home', item: `${siteConfig.basePath}/` },
  { name: 'Work', item: `${siteConfig.basePath}/work/` }
];

// CollectionPage JSON-LD Schema
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Client Success & Case Studies | Starts Digital",
  "description": "Explore Starts Digital case studies covering e-commerce growth, paid advertising, lead generation and verified campaign outcomes.",
  "url": `${siteConfig.url}${siteConfig.basePath}/work/`
};
---

<BaseLayout 
  title="Client Success & Case Studies" 
  description="Explore Starts Digital case studies covering e-commerce growth, paid advertising, lead generation and verified campaign outcomes."
>
  <BreadcrumbSchema items={schemaItems} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <div class="bg-brand-black min-h-screen">
    <!-- Breadcrumbs -->
    <Breadcrumbs items={breadcrumbsList} class="border-b border-brand-grey/10" />

    <!-- Introductory Hero Section -->
    <section class="py-16 md:py-24 border-b border-brand-grey/5 relative overflow-hidden">
      <!-- Subtle Grid Background -->
      <div 
        class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(102,112,133,0.02)_1px,transparent_1px),linear-gradient(to_bottom,rgba(102,112,133,0.02)_1px,transparent_1px)] bg-[size:4.5rem_4.5rem]"
        aria-hidden="true"
      ></div>
      <Container class="space-y-6 max-w-4xl">
        <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
          OUR PORTFOLIO
        </span>
        <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-brand-white leading-tight">
          Client Success &amp; Verified Case Studies
        </h1>
        <p class="font-body text-lg sm:text-xl font-normal text-brand-muted-dark leading-relaxed max-w-3xl">
          Explore our case studies covering e-commerce growth, paid advertising, lead generation and verified campaign outcomes. We focus on strategic commercial execution that supports sustainable client growth.
        </p>
      </Container>
    </section>

    <!-- Featured Case Studies (Published) -->
    <section class="py-20 md:py-28 bg-brand-white text-brand-black">
      <Container class="space-y-12 md:space-y-16">
        <SectionHeading
          eyebrow="FEATURED SUCCESS"
          title="Factual case studies with verified campaign outcomes."
          theme="light"
        />

        <div class="flex flex-col border-t border-brand-grey/25 divide-y divide-brand-grey/25">
          {
            sortedStudies.map((study, index) => (
              <div class="py-12 md:py-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                <!-- Project info -->
                <div class="lg:col-span-5 space-y-3">
                  <span class="font-heading text-xs sm:text-sm font-bold text-brand-teal uppercase tracking-widest">
                    Case Study 0{index + 1}
                  </span>
                  <h3 class="font-heading text-2xl sm:text-3xl font-bold text-brand-black leading-tight">
                    {study.data.title}
                  </h3>
                  <p class="font-body text-xs sm:text-sm font-semibold text-brand-text uppercase tracking-wider">
                    {study.data.industry}
                  </p>
                </div>

                <!-- Outcome & Read Link -->
                <div class="lg:col-span-7 space-y-6 lg:pl-6">
                  <div class="space-y-2">
                    <span class="block font-heading text-xs font-bold tracking-widest text-brand-teal uppercase">
                      Verified Outcome
                    </span>
                    <p class="font-heading text-lg sm:text-xl font-bold text-brand-black leading-relaxed">
                      {study.data.outcomeSummary}
                    </p>
                  </div>

                  <div class="pt-4 border-t border-brand-grey/15 flex justify-between items-center flex-wrap gap-4">
                    <p class="font-body text-sm sm:text-base font-normal text-brand-text leading-relaxed">
                      <strong class="font-semibold text-brand-black">Services:</strong>{' '}
                      {study.data.services.slice(0, 3).join(', ')}...
                    </p>
                    <a
                      href={getAssetPath(`/work/${study.id}/`)}
                      class="inline-flex items-center text-sm font-heading font-bold text-brand-blue hover:text-brand-blue/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue rounded px-1 py-0.5"
                    >
                      Read Case Study &rarr;
                    </a>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- Additional Experience (Unlinked Projects) -->
    <section class="py-20 md:py-28 bg-brand-navy text-brand-white border-t border-b border-brand-grey/10">
      <Container class="space-y-12 md:space-y-16">
        <SectionHeading
          eyebrow="MORE EXPERIENCE"
          title="Additional sectors served."
          theme="dark"
        />

        <div class="flex flex-col border-t border-brand-grey/10 divide-y divide-brand-grey/10">
          {
            additionalExperience.map((project) => (
              <div class="py-10 md:py-12 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                <!-- Info -->
                <div class="lg:col-span-5 space-y-2">
                  <h3 class="font-heading text-xl sm:text-2xl font-bold text-brand-white leading-tight">
                    {project.title}
                  </h3>
                  <p class="font-body text-xs sm:text-sm font-semibold text-brand-teal uppercase tracking-wider">
                    {project.industry}
                  </p>
                </div>

                <!-- Result -->
                <div class="lg:col-span-7 space-y-4 lg:pl-6">
                  <p class="font-body text-base font-normal text-brand-muted-dark leading-relaxed">
                    {project.result}
                  </p>
                  <div class="pt-3 border-t border-brand-grey/5">
                    <p class="font-body text-sm font-normal text-brand-text">
                      <strong class="font-semibold text-brand-muted-dark">Services:</strong>{' '}
                      {project.services.join(', ')}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- Contact CTA Section -->
    <section class="bg-brand-black text-brand-white py-24 border-t border-brand-grey/5">
      <Container class="text-center space-y-8 max-w-3xl">
        <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
          START YOUR PROJECT
        </span>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-brand-white">
          Ready to build a stronger digital presence?
        </h2>
        <p class="font-body text-base sm:text-lg font-normal text-brand-muted-dark leading-relaxed">
          Tell us where your business is today, what you want to achieve and where digital marketing is currently falling short.
        </p>
        <div class="pt-4">
          <Button href={`${siteConfig.basePath}/#contact`} variant="primary">
            Discuss Your Project
          </Button>
        </div>
      </Container>
    </section>
  </div>
</BaseLayout>
