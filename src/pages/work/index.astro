---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import { getCollection } from 'astro:content';
import { site } from '../../site.config';
import { ArrowRight, Sparkles } from '@lucide/astro';

const caseStudies = await getCollection('case-studies', ({ data }) => !data.draft);
const sortedStudies = caseStudies.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Client Success & Case Studies — Starts Digital" 
  description="Explore Starts Digital case studies covering e-commerce growth, paid advertising, lead generation and verified campaign outcomes."
  type="website"
>
  <!-- Hero Section -->
  <section class="bg-[#061d33] text-white py-16 sm:py-24 border-b border-white/10 relative overflow-hidden rounded-b-[40px]">
    <Container class="relative max-w-[1280px] px-6 sm:px-8 space-y-4">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-mono font-bold uppercase tracking-wider text-[#ddff35]">
        <Sparkles class="size-3.5 text-[#ddff35]" />
        <span>PORTFOLIO & CASE STUDIES</span>
      </span>
      <h1 class="font-display text-4xl sm:text-6xl font-black uppercase tracking-tight text-white leading-tight">
        OUR FEATURED CASE STUDIES
      </h1>
      <p class="font-body text-lg sm:text-xl text-slate-200 max-w-2xl leading-relaxed font-medium">
        Factual case studies covering e-commerce revenue growth, paid media acquisition, and structured search engine architecture.
      </p>
    </Container>
  </section>

  <!-- Main Case Studies Grid -->
  <section class="py-20 bg-[#f7f4ed] text-[#061d33]">
    <Container class="max-w-[1280px] px-6 sm:px-8 space-y-12">
      
      <div class="grid gap-8 md:grid-cols-2">
        {
          sortedStudies.map((study) => (
            <div 
              class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-10 shadow-lg hover:shadow-xl transition-all duration-200 flex flex-col justify-between group"
            >
              <div class="space-y-4">
                <span class="inline-block rounded-full bg-[#ff762b]/15 border border-[#ff762b]/30 px-4 py-1 text-xs font-mono font-bold text-[#ff762b] uppercase tracking-wider">
                  {study.data.industry}
                </span>
                <h2 class="font-display text-3xl sm:text-4xl font-black uppercase text-[#061d33] group-hover:text-[#ff762b] transition-colors">
                  {study.data.title}
                </h2>
                <p class="font-body text-base text-slate-700 leading-relaxed font-medium">
                  {study.data.outcomeSummary}
                </p>
              </div>

              <div class="mt-8 pt-6 border-t border-slate-200 flex items-center justify-between">
                <span class="text-xs font-mono font-bold text-slate-500 uppercase">Verified Case Study</span>
                <a
                  href={`${site.basePath}/work/${study.id}/`}
                  class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-6 py-3 font-display text-sm font-bold text-white hover:bg-[#ff762b] transition-all shadow-sm"
                >
                  <span>Read Case Study</span>
                  <ArrowRight class="size-4" />
                </a>
              </div>
            </div>
          ))
        }
      </div>

    </Container>
  </section>
</BaseLayout>
