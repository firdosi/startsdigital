---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Showcase from '../../components/landing/Showcase.astro';
import FinalCta from '../../components/landing/FinalCta.astro';
import MotionController from '../../components/common/MotionController.astro';
import { brands } from '../../data/brands';
import { site } from '../../site.config';
import { ArrowRight } from '@lucide/astro';
---

<BaseLayout 
  title="Client Work & Portfolio — Starts Digital"
  description="Public CV-style client portfolio and selected project experience supported by Starts Digital."
  type="website"
>
  <!-- Deep Navy Rounded Hero Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-28 rounded-b-[40px] shadow-2xl overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <div data-motion="scale-in">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ddff35]">
          <span>OUR WORK</span>
        </span>
      </div>
      
      <!-- Hero Headline: Sora 700 -->
      <h1 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[40px] md:text-[50px] lg:text-[64px] text-white leading-[1.08] tracking-[-0.035em] max-w-[800px] mx-auto">
        Work built around <span class="text-[#ff762b]">real business outcomes.</span>
      </h1>
      
      <p data-motion="fade-up" data-motion-delay="200" class="font-body text-[16px] sm:text-[18px] text-slate-200 max-w-[680px] mx-auto leading-[1.65] font-normal">
        Selected campaigns, websites and growth projects supported by Starts Digital across e-commerce, services, consultation and technology.
      </p>
    </Container>
  </section>

  <!-- 3 Large Image-Led Featured Projects -->
  <Showcase />

  <!-- Selected Client Experience Section (All 15 Public Brands) -->
  <section class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10 overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8 space-y-16">
      <div class="text-center max-w-3xl mx-auto space-y-3">
        <span data-motion="scale-in" class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
          SELECTED CLIENT EXPERIENCE
        </span>
        <h2 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
          Brands We Have Worked With
        </h2>
        <p data-motion="fade-up" data-motion-delay="200" class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal max-w-2xl mx-auto">
          Explore individual project profiles for all 15 public brands across e-commerce, immigration, local services, technology, and healthcare.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {brands.map((b, idx) => (
          <article 
            data-motion="fade-up"
            data-motion-delay={idx * 40}
            class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-md hover:shadow-xl hover:border-[#ff762b] hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group"
          >
            <div class="space-y-5">
              <!-- Top Row: Logo or Clean Text Identity -->
              <div class="flex items-center justify-between gap-4 pb-4 border-b border-slate-100">
                {b.logo && b.logoApproved ? (
                  <div class="h-14 w-32 rounded-xl bg-[#f7f4ed] p-2 flex items-center justify-center border border-slate-200 group-hover:scale-105 transition-transform shrink-0">
                    <img 
                      src={`${site.basePath}${b.logo}`} 
                      alt={`${b.name} logo`} 
                      class="max-h-10 max-w-[110px] object-contain"
                    />
                  </div>
                ) : (
                  <div class="h-14 px-4 rounded-xl bg-[#061d33] text-[#ddff35] flex items-center justify-center font-heading font-bold text-lg shrink-0 group-hover:scale-105 transition-transform">
                    {b.name}
                  </div>
                )}

                <span class="inline-block rounded-full bg-[#f7f4ed] border border-slate-200 px-3 py-1 text-[11px] font-mono font-medium text-slate-600 uppercase">
                  {b.industry}
                </span>
              </div>

              <!-- Brand Name & High-level Role -->
              <div class="space-y-1.5">
                <h3 class="font-heading font-bold text-xl sm:text-2xl text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-tight">
                  {b.name}
                </h3>
                <p class="text-xs font-mono font-semibold text-[#ff762b] uppercase tracking-wide">
                  Role: {b.role}
                </p>
              </div>

              <!-- Two-line Professional Summary -->
              <p class="text-sm text-slate-600 font-body leading-relaxed line-clamp-2">
                {b.summary}
              </p>

              <!-- Three or Four Service Tags -->
              <div class="flex flex-wrap gap-1.5 pt-2">
                {b.services.slice(0, 4).map((service) => (
                  <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-body font-medium text-slate-700">
                    {service}
                  </span>
                ))}
              </div>
            </div>

            <!-- View Project Profile Link -->
            <div class="pt-6 mt-6 border-t border-slate-100">
              <a
                href={`${site.basePath}/work/clients/${b.id}/`}
                class="inline-flex items-center gap-2 text-sm font-body font-semibold text-[#061d33] group-hover:text-[#ff762b] transition-colors"
              >
                <span>View Project Profile</span>
                <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <!-- Approved Navy CTA Panel -->
  <FinalCta />

  <MotionController />
</BaseLayout>

