---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Features from '../components/landing/Features.astro';
import Process from '../components/landing/Process.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import MotionController from '../components/common/MotionController.astro';

const toolkitItems = [
  { name: 'Meta Advertising', desc: 'Campaign structure & Conversions API' },
  { name: 'Google Advertising', desc: 'Search & Performance Max setup' },
  { name: 'Landing Pages', desc: 'High-converting mobile landers' },
  { name: 'Conversion-Focused Websites', desc: 'Fast WooCommerce & Shopify' },
  { name: 'E-Commerce Architecture', desc: 'Checkout friction reduction' },
  { name: 'Technical SEO', desc: 'Schema markup & site indexation' },
  { name: 'Local SEO', desc: 'Geographic keyword targeting' },
  { name: 'Campaign Creative', desc: 'Direct-response video & graphics' },
  { name: 'Content Systems', desc: 'Scalable creative pipelines' },
  { name: 'Tracking & Analytics', desc: 'GA4, CAPI & attribution auditing' },
  { name: 'AI-Assisted Workflows', desc: 'Lead routing & avatar videos' },
  { name: 'Performance Reporting', desc: 'Transparent revenue tracking' }
];
---

<BaseLayout 
  title="Digital Marketing & Growth Services — Starts Digital"
  description="One connected team for paid advertising, websites, SEO, creative content and practical AI-powered marketing systems."
  type="website"
>
  <!-- Deep Navy Rounded Hero Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-28 rounded-b-[40px] shadow-2xl overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <div data-motion="scale-in">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ddff35]">
          <span>SERVICES</span>
        </span>
      </div>
      
      <!-- Hero Headline: Clip Reveal -->
      <h1 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[40px] md:text-[50px] lg:text-[64px] text-white leading-[1.08] tracking-[-0.035em] max-w-[800px] mx-auto">
        Everything your business needs to <span class="text-[#ff762b]">grow online.</span>
      </h1>
      
      <p data-motion="fade-up" data-motion-delay="200" class="font-body text-[16px] sm:text-[18px] text-slate-200 max-w-[680px] mx-auto leading-[1.65] font-normal">
        One connected team for paid advertising, websites, SEO, creative content and practical AI-powered marketing systems.
      </p>
    </Container>
  </section>

  <!-- Main 6 Colourful Service Cards -->
  <Features />

  <!-- Working Method Accordion -->
  <Process />

  <!-- Explore Our Complete Growth Toolkit -->
  <section class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10 overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8 space-y-16">
      <div class="text-center max-w-3xl mx-auto space-y-3">
        <span data-motion="scale-in" class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
          CAPABILITIES & STACK
        </span>
        <h2 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
          Explore our complete growth toolkit
        </h2>
        <p data-motion="fade-up" data-motion-delay="200" class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal max-w-2xl mx-auto">
          Unified capabilities covering paid acquisition, web infrastructure, search optimization, and AI automation.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {toolkitItems.map((item, idx) => (
          <div 
            data-motion="fade-up"
            data-motion-delay={idx * 50}
            class="rounded-2xl border-2 border-[#061d33]/15 bg-white p-6 shadow-md hover:shadow-xl hover:border-[#ff762b] hover:-translate-y-1 transition-all duration-300 group space-y-2"
          >
            <h3 class="font-heading font-semibold text-[18px] text-[#061d33] leading-snug">
              {item.name}
            </h3>
            <p class="text-base text-slate-600 font-body leading-[1.6] font-normal">
              {item.desc}
            </p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Approved Navy CTA Panel -->
  <FinalCta />

  <MotionController />
</BaseLayout>
