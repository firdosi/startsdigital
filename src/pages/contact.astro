---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Faq from '../components/landing/Faq.astro';
import MotionController from '../components/common/MotionController.astro';
import { site } from '../site.config';
import { 
  Mail, 
  MessageSquare, 
  Send, 
  CheckCircle, 
  ShieldCheck,
  Info,
  Sparkles
} from '@lucide/astro';

// Allowlist mappings for service and source parameters
const SERVICE_ALLOWLIST: Record<string, string> = {
  'paid-advertising': 'Paid Advertising',
  'website-development': 'Website Design and Development',
  'seo': 'SEO',
  'creative-content': 'Creative Content',
  'social-media-marketing': 'Social Media Marketing',
  'ai-marketing-systems': 'AI Marketing Systems',
  'multiple-services': 'Multiple Services',
  'not-sure-yet': 'Not Sure Yet',
};

const SOURCE_ALLOWLIST: Record<string, string> = {
  'black-gold-fertilizer': 'Black Gold Fertilizer',
  'qurbani-campaign': 'Wajib Livestock Qurbani Campaign',
  'rk-reno-solutions': 'RK Reno Solutions',
};

const initialService = Astro.url.searchParams.get('service');
const initialSource = Astro.url.searchParams.get('source');

const preselectedService = (initialService && SERVICE_ALLOWLIST[initialService]) ? SERVICE_ALLOWLIST[initialService] : '';
const caseStudySource = (initialSource && SOURCE_ALLOWLIST[initialSource]) ? SOURCE_ALLOWLIST[initialSource] : '';
---

<BaseLayout 
  title="Contact Starts Digital — Start a Project"
  description="Selected client work, featured case studies and public brand pages supported by Starts Digital. Send a structured project inquiry through WhatsApp or email."
  type="website"
>
  <!-- Deep Navy Rounded Hero Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-28 rounded-b-[40px] shadow-2xl overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <div data-motion="scale-in">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ddff35]">
          <Sparkles class="size-3.5 text-[#ddff35]" />
          <span>PROJECT INQUIRY</span>
        </span>
      </div>
      
      <!-- Hero Headline -->
      <h1 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[38px] sm:text-[50px] lg:text-[64px] text-white leading-[1.08] tracking-[-0.035em] max-w-[840px] mx-auto">
        Let’s discuss what you want to <span class="text-[#ff762b]">grow.</span>
      </h1>
      
      <p data-motion="fade-up" data-motion-delay="200" class="font-body text-[16px] sm:text-[18px] text-slate-200 max-w-[700px] mx-auto leading-[1.65] font-normal">
        Share your business goals, current challenges and the support you need. Your project brief can be opened directly in WhatsApp or email.
      </p>
    </Container>
  </section>

  <!-- Contact Cards & Form Section -->
  <section class="py-16 sm:py-20 lg:py-24 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10 overflow-hidden">
    <Container class="max-w-[1280px] px-6 sm:px-8">
      
      <div class="grid gap-12 lg:grid-cols-12 items-start">
        
        <!-- Left Column: Clickable Contact Cards & Direct Info -->
        <div class="lg:col-span-5 space-y-8">
          <div class="space-y-3">
            <span data-motion="scale-in" class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
              DIRECT COMMUNICATIONS
            </span>
            <h2 data-motion="fade-left" data-motion-delay="100" class="font-heading font-bold text-[30px] sm:text-[36px] lg:text-[42px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
              Connect directly with our team
            </h2>
            <p data-motion="fade-left" data-motion-delay="200" class="text-base text-slate-700 font-body leading-[1.65] font-normal">
              Send a structured project inquiry through WhatsApp or email with your business goals and requirements.
            </p>
          </div>

          <!-- Clickable WhatsApp Card -->
          <a
            data-motion="fade-up"
            data-motion-delay="300"
            href={site.contact.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            data-track="contact-whatsapp"
            class="block rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-lg hover:border-[#39c98a] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group"
          >
            <div class="flex items-center gap-4">
              <div class="size-14 rounded-2xl bg-[#39c98a] text-white flex items-center justify-center font-bold shrink-0 group-hover:rotate-6 transition-transform">
                <MessageSquare class="size-7" />
              </div>
              <div>
                <span class="text-xs font-mono font-medium uppercase text-slate-500 block">WhatsApp Direct</span>
                <span class="font-heading font-semibold text-[18px] sm:text-xl text-[#061d33] group-hover:text-[#39c98a] transition-colors">
                  {site.contact.phone}
                </span>
                <p class="text-xs text-slate-600 font-body mt-0.5 font-normal">Use WhatsApp for project details and voice notes</p>
              </div>
            </div>
          </a>

          <!-- Clickable Email Card -->
          <a
            data-motion="fade-up"
            data-motion-delay="400"
            href={`mailto:${site.contact.email}`}
            data-track="contact-email"
            class="block rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-lg hover:border-[#ff762b] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group"
          >
            <div class="flex items-center gap-4">
              <div class="size-14 rounded-2xl bg-[#ff762b] text-white flex items-center justify-center font-bold shrink-0 group-hover:rotate-6 transition-transform">
                <Mail class="size-7" />
              </div>
              <div>
                <span class="text-xs font-mono font-medium uppercase text-slate-500 block">Email Inquiry</span>
                <span class="font-heading font-semibold text-[18px] sm:text-xl text-[#061d33] group-hover:text-[#ff762b] transition-colors">
                  {site.contact.email}
                </span>
                <p class="text-xs text-slate-600 font-body mt-0.5 font-normal">Send a detailed project brief by email</p>
              </div>
            </div>
          </a>

          <!-- Expectations Box -->
          <div data-motion="fade-up" data-motion-delay="500" class="rounded-2xl border border-slate-300 bg-white/70 p-6 space-y-3 font-body text-sm font-normal text-slate-700">
            <div class="flex items-center gap-2 text-[#061d33] font-semibold font-body uppercase text-xs tracking-wider">
              <ShieldCheck class="size-5 text-[#ff762b]" />
              <span>DIRECT CONTACT OPTIONS</span>
            </div>
            <div class="flex items-center gap-2">
              <CheckCircle class="size-4 text-[#39c98a] shrink-0" />
              <span>Send your project details through WhatsApp or email</span>
            </div>
            <div class="flex items-center gap-2">
              <CheckCircle class="size-4 text-[#39c98a] shrink-0" />
              <span>Choose the channel that is most convenient for you</span>
            </div>
          </div>
        </div>

        <!-- Right Column: Structured Project Brief Form -->
        <div data-motion="fade-right" data-motion-delay="250" class="lg:col-span-7">
          <div class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-6 sm:p-10 lg:p-12 shadow-2xl space-y-6">
            
            <div>
              <h3 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33] mb-2 leading-tight">
                Project Brief Form
              </h3>
              <p class="text-base text-slate-600 font-body leading-[1.65] font-normal">
                Fill in your details below to generate your structured brief for WhatsApp or Email.
              </p>
            </div>

            <!-- Verified Case Study Context Banner (Shown when URL source param is present) -->
            <div 
              id="case-study-context-note"
              class:list={[
                'rounded-2xl border border-[#ff762b]/30 bg-[#ff762b]/10 p-4 flex items-start gap-3 text-sm text-[#061d33]',
                caseStudySource ? 'block' : 'hidden'
              ]}
            >
              <Info class="size-5 text-[#ff762b] shrink-0 mt-0.5" />
              <div>
                <span class="font-semibold block">Case Study Context</span>
                <span id="case-study-context-text">
                  You are contacting us after viewing the <strong id="case-study-name">{caseStudySource}</strong> case study.
                </span>
              </div>
            </div>

            <!-- Form -->
            <form 
              id="contact-form"
              class="space-y-5"
              novalidate
            >
              <!-- 1. Full Name & 2. Business Name -->
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="name" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                    1. Full Name <span class="text-[#ff762b]">*</span>
                  </label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name"
                    required
                    autocomplete="name"
                    aria-describedby="name-error"
                    placeholder="e.g. John Smith"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                  <span id="name-error" aria-live="polite" class="hidden text-xs text-red-600 font-body mt-1">Please enter your full name.</span>
                </div>

                <div>
                  <label for="company" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                    2. Business / Brand Name <span class="text-[#ff762b]">*</span>
                  </label>
                  <input 
                    type="text" 
                    id="company" 
                    name="company"
                    required
                    aria-describedby="company-error"
                    placeholder="e.g. Black Gold Fertilizer"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                  <span id="company-error" aria-live="polite" class="hidden text-xs text-red-600 font-body mt-1">Please enter your business or brand name.</span>
                </div>
              </div>

              <!-- 3. Email & 4. Phone -->
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="email" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                    3. Email Address <span class="text-[#ff762b]">*</span>
                  </label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email"
                    required
                    autocomplete="email"
                    aria-describedby="email-error"
                    placeholder="name@company.com"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                  <span id="email-error" aria-live="polite" class="hidden text-xs text-red-600 font-body mt-1">Please enter a valid email address.</span>
                </div>

                <div>
                  <label for="phone" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                    4. WhatsApp / Phone Number <span class="text-slate-400 font-normal">(Optional)</span>
                  </label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone"
                    autocomplete="tel"
                    placeholder="+92 339 4135544"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
              </div>

              <!-- 5. Website or Social Page -->
              <div>
                <label for="website" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                  5. Website or Social Page <span class="text-slate-400 font-normal">(Optional)</span>
                </label>
                <input 
                  type="url" 
                  id="website" 
                  name="website"
                  aria-describedby="website-error"
                  placeholder="https://example.com or https://instagram.com/yourbrand"
                  class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                />
                <span id="website-error" aria-live="polite" class="hidden text-xs text-red-600 font-body mt-1">Please enter a valid URL (starting with http:// or https://).</span>
              </div>

              <!-- 6. Service Needed & 7. Primary Business Goal -->
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="service" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                    6. Service Needed <span class="text-[#ff762b]">*</span>
                  </label>
                  <select 
                    id="service" 
                    name="service"
                    required
                    aria-describedby="service-error"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  >
                    <option value="" disabled selected={!preselectedService}>Select a service...</option>
                    <option value="Paid Advertising" selected={preselectedService === 'Paid Advertising'}>Paid Advertising</option>
                    <option value="Website Design and Development" selected={preselectedService === 'Website Design and Development'}>Website Design and Development</option>
                    <option value="SEO" selected={preselectedService === 'SEO'}>SEO</option>
                    <option value="Creative Content" selected={preselectedService === 'Creative Content'}>Creative Content</option>
                    <option value="Social Media Marketing" selected={preselectedService === 'Social Media Marketing'}>Social Media Marketing</option>
                    <option value="AI Marketing Systems" selected={preselectedService === 'AI Marketing Systems'}>AI Marketing Systems</option>
                    <option value="Multiple Services" selected={preselectedService === 'Multiple Services'}>Multiple Services</option>
                    <option value="Not Sure Yet" selected={preselectedService === 'Not Sure Yet'}>Not Sure Yet</option>
                  </select>
                  <span id="service-error" aria-live="polite" class="hidden text-xs text-red-600 font-body mt-1">Please select a service requirement.</span>
                </div>

                <div>
                  <label for="goal" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                    7. Primary Business Goal <span class="text-[#ff762b]">*</span>
                  </label>
                  <select 
                    id="goal" 
                    name="goal"
                    required
                    aria-describedby="goal-error"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  >
                    <option value="" disabled selected>Select primary goal...</option>
                    <option value="Generate More Leads">Generate More Leads</option>
                    <option value="Increase Online Sales">Increase Online Sales</option>
                    <option value="Build or Improve a Website">Build or Improve a Website</option>
                    <option value="Improve Search Visibility">Improve Search Visibility</option>
                    <option value="Improve Social Media Content">Improve Social Media Content</option>
                    <option value="Automate Marketing Tasks">Automate Marketing Tasks</option>
                    <option value="Launch a New Business or Product">Launch a New Business or Product</option>
                    <option value="Other">Other</option>
                  </select>
                  <span id="goal-error" aria-live="polite" class="hidden text-xs text-red-600 font-body mt-1">Please select your primary business goal.</span>
                </div>
              </div>

              <!-- 8. Monthly Budget -->
              <div>
                <label for="budget" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                  8. Monthly Marketing Budget <span class="text-slate-400 font-normal">(Optional)</span>
                </label>
                <select 
                  id="budget" 
                  name="budget"
                  class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                >
                  <option value="" disabled selected>Select approximate budget...</option>
                  <option value="Under PKR 100,000">Under PKR 100,000</option>
                  <option value="PKR 100,000 to 250,000">PKR 100,000 to 250,000</option>
                  <option value="PKR 250,000 to 500,000">PKR 250,000 to 500,000</option>
                  <option value="PKR 500,000+">PKR 500,000+</option>
                  <option value="International Budget">International Budget</option>
                  <option value="Not Decided Yet">Not Decided Yet</option>
                </select>
              </div>

              <!-- 9. Project Details -->
              <div>
                <label for="message" class="block font-mono text-xs font-semibold uppercase text-[#061d33] mb-2">
                  9. Project Details <span class="text-[#ff762b]">*</span>
                </label>
                <textarea 
                  id="message" 
                  name="message"
                  rows="4"
                  required
                  aria-describedby="details-help message-error"
                  placeholder="Tell us what you sell, your target market, current challenge and expected outcome..."
                  class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                ></textarea>
                <p id="details-help" class="text-xs text-slate-500 font-body mt-1.5 font-normal">
                  Tell us what you sell, your target market, current challenge and expected outcome.
                </p>
                <span id="message-error" aria-live="polite" class="hidden text-xs text-red-600 font-body mt-1">Please provide project details.</span>
              </div>

              <!-- Action Choice Buttons -->
              <div class="pt-4 flex flex-col sm:flex-row gap-4 font-body">
                <button
                  type="button"
                  id="btn-send-whatsapp"
                  data-track="contact-whatsapp"
                  class="w-full sm:w-1/2 inline-flex items-center justify-center min-h-[52px] gap-2.5 rounded-2xl bg-[#39c98a] px-6 py-4 font-body font-semibold text-base text-white shadow-lg hover:bg-[#2fb078] active:scale-98 transition-all cursor-pointer"
                >
                  <MessageSquare class="size-5 text-white" />
                  <span>Open Project Brief in WhatsApp</span>
                </button>

                <button
                  type="button"
                  id="btn-send-email"
                  data-track="contact-email"
                  class="w-full sm:w-1/2 inline-flex items-center justify-center min-h-[52px] gap-2.5 rounded-2xl border-2 border-[#061d33] bg-white px-6 py-4 font-body font-semibold text-base text-[#061d33] shadow-md hover:bg-[#061d33] hover:text-white active:scale-98 transition-all cursor-pointer group"
                >
                  <Send class="size-5 text-[#061d33] group-hover:text-white transition-colors" />
                  <span>Open Project Brief in Email</span>
                </button>
              </div>

              <!-- Privacy Statement -->
              <div class="pt-3 text-center border-t border-slate-100">
                <p class="text-xs text-slate-600 font-body font-normal max-w-lg mx-auto">
                  Your details are used only to prepare your WhatsApp or email message. This website does not store or submit the form to a database.
                </p>
              </div>

              <!-- No-JS Fallback Message -->
              <noscript>
                <div class="mt-6 rounded-2xl border-2 border-[#061d33] bg-[#061d33] text-white p-6 space-y-3 font-body">
                  <h4 class="font-heading font-semibold text-lg text-[#ddff35]">JavaScript is Disabled</h4>
                  <p class="text-sm text-slate-200">
                    You can still get in touch with us directly via your preferred channel:
                  </p>
                  <div class="flex flex-wrap gap-4 pt-2">
                    <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-[#39c98a] px-4 py-2 text-sm font-semibold text-white">
                      <span>Chat on WhatsApp ({site.contact.phone})</span>
                    </a>
                    <a href={`mailto:${site.contact.email}`} class="inline-flex items-center gap-2 rounded-xl bg-white px-4 py-2 text-sm font-semibold text-[#061d33]">
                      <span>Send Email ({site.contact.email})</span>
                    </a>
                  </div>
                </div>
              </noscript>
            </form>
          </div>
        </div>

      </div>

      <!-- What Happens Next Section -->
      <div class="mt-20 pt-16 border-t border-[#061d33]/15">
        <div class="text-center max-w-2xl mx-auto mb-12 space-y-2">
          <span data-motion="scale-in" class="text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ff762b]">
            TRANSPARENT PROCESS
          </span>
          <h3 data-motion="clip-up" class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33]">
            What Happens Next
          </h3>
        </div>

        <div data-motion-group data-motion-stagger="100" class="grid gap-6 sm:grid-cols-3 font-body">
          <!-- Step 1 -->
          <div data-motion="fade-up" class="rounded-2xl border border-slate-300 bg-white p-6 shadow-md space-y-3">
            <div class="size-10 rounded-xl bg-[#061d33] text-[#ddff35] flex items-center justify-center font-heading font-bold text-lg">
              1
            </div>
            <h4 class="font-heading font-semibold text-lg text-[#061d33]">
              Share Your Goals
            </h4>
            <p class="text-sm text-slate-600 leading-[1.6] font-normal">
              Send the business context, service requirement and expected outcome.
            </p>
          </div>

          <!-- Step 2 -->
          <div data-motion="fade-up" class="rounded-2xl border border-slate-300 bg-white p-6 shadow-md space-y-3">
            <div class="size-10 rounded-xl bg-[#061d33] text-[#ddff35] flex items-center justify-center font-heading font-bold text-lg">
              2
            </div>
            <h4 class="font-heading font-semibold text-lg text-[#061d33]">
              Scope Review
            </h4>
            <p class="text-sm text-slate-600 leading-[1.6] font-normal">
              Starts Digital reviews the requirement and identifies the most practical next step.
            </p>
          </div>

          <!-- Step 3 -->
          <div data-motion="fade-up" class="rounded-2xl border border-slate-300 bg-white p-6 shadow-md space-y-3">
            <div class="size-10 rounded-xl bg-[#061d33] text-[#ddff35] flex items-center justify-center font-heading font-bold text-lg">
              3
            </div>
            <h4 class="font-heading font-semibold text-lg text-[#061d33]">
              Direct Discussion
            </h4>
            <p class="text-sm text-slate-600 leading-[1.6] font-normal">
              Continue the conversation through WhatsApp or email.
            </p>
          </div>
        </div>
      </div>

    </Container>
  </section>

  <!-- FAQ Section -->
  <Faq />

  <MotionController />

  <!-- Interactive Dispatch & Validation Script with Duplicate Binding Guard -->
  <script>
    const SERVICE_ALLOWLIST: Record<string, string> = {
      'paid-advertising': 'Paid Advertising',
      'website-development': 'Website Design and Development',
      'seo': 'SEO',
      'creative-content': 'Creative Content',
      'social-media-marketing': 'Social Media Marketing',
      'ai-marketing-systems': 'AI Marketing Systems',
      'multiple-services': 'Multiple Services',
      'not-sure-yet': 'Not Sure Yet',
    };

    const SOURCE_ALLOWLIST: Record<string, string> = {
      'black-gold-fertilizer': 'Black Gold Fertilizer',
      'qurbani-campaign': 'Wajib Livestock Qurbani Campaign',
      'rk-reno-solutions': 'RK Reno Solutions',
    };

    function initContactForm() {
      const form = document.getElementById('contact-form') as HTMLFormElement;
      if (!form) return;

      // Prevent duplicate listener binding
      if (form.dataset.bound === 'true') return;
      form.dataset.bound = 'true';

      const btnWhatsApp = document.getElementById('btn-send-whatsapp');
      const btnEmail = document.getElementById('btn-send-email');
      const serviceSelect = document.getElementById('service') as HTMLSelectElement;
      const contextBanner = document.getElementById('case-study-context-note');
      const contextName = document.getElementById('case-study-name');

      // Handle URL parameters dynamically on client load
      const urlParams = new URLSearchParams(window.location.search);
      const serviceParam = urlParams.get('service');
      const sourceParam = urlParams.get('source');

      if (serviceParam && SERVICE_ALLOWLIST[serviceParam] && serviceSelect) {
        serviceSelect.value = SERVICE_ALLOWLIST[serviceParam];
      }

      if (sourceParam && SOURCE_ALLOWLIST[sourceParam] && contextBanner && contextName) {
        contextName.textContent = SOURCE_ALLOWLIST[sourceParam];
        contextBanner.classList.remove('hidden');
        contextBanner.classList.add('flex');
      }

      function buildMessageText() {
        const nameVal = (document.getElementById('name') as HTMLInputElement)?.value.trim() || '';
        const companyVal = (document.getElementById('company') as HTMLInputElement)?.value.trim() || '';
        const emailVal = (document.getElementById('email') as HTMLInputElement)?.value.trim() || '';
        const phoneVal = (document.getElementById('phone') as HTMLInputElement)?.value.trim() || '';
        const websiteVal = (document.getElementById('website') as HTMLInputElement)?.value.trim() || '';
        const serviceVal = (document.getElementById('service') as HTMLSelectElement)?.value || 'Not selected';
        const goalVal = (document.getElementById('goal') as HTMLSelectElement)?.value || 'Not selected';
        const rawBudgetVal = (document.getElementById('budget') as HTMLSelectElement)?.value;
        const budgetVal = rawBudgetVal ? rawBudgetVal : 'Not decided yet';
        const detailsVal = (document.getElementById('message') as HTMLTextAreaElement)?.value.trim() || '';

        const phoneText = phoneVal ? phoneVal : 'Not provided';
        const websiteText = websiteVal ? websiteVal : 'Not provided';
        const pageUrl = window.location.href;

        return {
          companyVal,
          serviceVal,
          bodyText: 
`Hello Starts Digital,

I would like to discuss a project.

Name:
${nameVal}

Business:
${companyVal}

Email:
${emailVal}

Phone / WhatsApp:
${phoneText}

Website / Social Page:
${websiteText}

Service Needed:
${serviceVal}

Primary Goal:
${goalVal}

Approximate Budget:
${budgetVal}

Project Details:
${detailsVal}

Source Page:
${pageUrl}`
        };
      }

      function validateForm(): boolean {
        const fields = [
          { id: 'name', isRequired: true, checkValid: (el: HTMLInputElement) => !!el.value.trim() },
          { id: 'company', isRequired: true, checkValid: (el: HTMLInputElement) => !!el.value.trim() },
          { id: 'email', isRequired: true, checkValid: (el: HTMLInputElement) => !!el.value.trim() && el.validity.valid },
          { id: 'website', isRequired: false, checkValid: (el: HTMLInputElement) => !el.value.trim() || el.validity.valid },
          { id: 'service', isRequired: true, checkValid: (el: HTMLSelectElement) => !!el.value },
          { id: 'goal', isRequired: true, checkValid: (el: HTMLSelectElement) => !!el.value },
          { id: 'message', isRequired: true, checkValid: (el: HTMLTextAreaElement) => !!el.value.trim() },
        ];

        let isValid = true;
        let firstInvalidEl: HTMLElement | null = null;

        fields.forEach(({ id, checkValid }) => {
          const el = document.getElementById(id) as HTMLElement & { value: string; validity?: ValidityState };
          const errEl = document.getElementById(`${id}-error`);
          
          if (el) {
            const valid = checkValid(el as any);
            if (!valid) {
              isValid = false;
              el.setAttribute('aria-invalid', 'true');
              if (errEl) errEl.classList.remove('hidden');
              if (!firstInvalidEl) firstInvalidEl = el;
            } else {
              el.removeAttribute('aria-invalid');
              if (errEl) errEl.classList.add('hidden');
            }
          }
        });

        if (!isValid) {
          form.reportValidity();
          if (firstInvalidEl) {
            (firstInvalidEl as HTMLElement).focus();
          }
        }

        return isValid;
      }

      btnWhatsApp?.addEventListener('click', () => {
        if (!validateForm()) return;
        const { bodyText } = buildMessageText();
        const encodedText = encodeURIComponent(bodyText);
        window.open(`https://wa.me/923394135544?text=${encodedText}`, '_blank');
      });

      btnEmail?.addEventListener('click', () => {
        if (!validateForm()) return;
        const { companyVal, serviceVal, bodyText } = buildMessageText();
        const subject = encodeURIComponent(`Project Inquiry: ${companyVal} - ${serviceVal}`);
        const encodedBody = encodeURIComponent(bodyText);
        window.location.href = `mailto:firdosidigital@gmail.com?subject=${subject}&body=${encodedBody}`;
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initContactForm);
    } else {
      initContactForm();
    }
    document.addEventListener('astro:page-load', initContactForm);
  </script>
</BaseLayout>
