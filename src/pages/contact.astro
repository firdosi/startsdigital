---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Faq from '../components/landing/Faq.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import MotionController from '../components/common/MotionController.astro';
import { site } from '../site.config';
import { 
  Sparkles, 
  Mail, 
  MessageSquare, 
  Send, 
  CheckCircle2, 
  Clock, 
  ShieldCheck 
} from '@lucide/astro';
---

<BaseLayout 
  title="Contact Starts Digital — Discuss Your Growth Strategy"
  description="Tell us about your business, current challenges and goals. Speak directly with our team to evaluate your paid campaigns, web architecture and growth roadmap."
  type="website"
>
  <!-- Deep Navy Rounded Hero Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-28 rounded-b-[40px] shadow-2xl">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-bold uppercase tracking-widest text-[#ddff35]">
        <Sparkles class="size-3.5 text-[#ddff35]" />
        <span>CONTACT</span>
      </span>
      
      <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl font-black uppercase tracking-tight leading-none text-white max-w-5xl mx-auto">
        LET’S TALK ABOUT YOUR NEXT <span class="text-[#ff762b]">GROWTH OPPORTUNITY</span>
      </h1>
      
      <p class="font-body text-lg sm:text-2xl text-slate-200 max-w-3xl mx-auto leading-relaxed font-medium">
        Tell us about your business, current challenges and goals. We will review where Starts Digital may be able to help.
      </p>
    </Container>
  </section>

  <!-- Contact Cards & Form Section -->
  <section class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
    <Container class="max-w-[1280px] px-6 sm:px-8">
      
      <div class="grid gap-12 lg:grid-cols-12 items-start">
        
        <!-- Left Column: Clickable Contact Cards & Assurance -->
        <div class="lg:col-span-5 space-y-8">
          <div>
            <span class="text-xs font-bold font-mono uppercase tracking-widest text-[#ff762b] mb-2 block">
              DIRECT CHANNELS
            </span>
            <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-black uppercase text-[#061d33] leading-tight">
              GET IN TOUCH DIRECTLY
            </h2>
            <p class="mt-3 text-base text-slate-700 font-body leading-relaxed font-medium">
              We respond promptly to project enquiries with honest commercial evaluations and direct strategic feedback.
            </p>
          </div>

          <!-- Clickable Email Card -->
          <a
            href={`mailto:${site.contact.email}`}
            class="block rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-lg hover:border-[#ff762b] hover:shadow-xl transition-all duration-300 group"
          >
            <div class="flex items-center gap-4">
              <div class="size-14 rounded-2xl bg-[#ff762b] text-white flex items-center justify-center font-bold shrink-0">
                <Mail class="size-7" />
              </div>
              <div>
                <span class="text-xs font-mono font-bold uppercase text-slate-500 block">Email Inquiry</span>
                <span class="font-display text-lg sm:text-xl font-black text-[#061d33] group-hover:text-[#ff762b] transition-colors">
                  {site.contact.email}
                </span>
                <p class="text-xs text-slate-600 font-body mt-0.5">Direct inbox monitored daily</p>
              </div>
            </div>
          </a>

          <!-- Clickable WhatsApp Card -->
          <a
            href={site.contact.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-lg hover:border-[#39c98a] hover:shadow-xl transition-all duration-300 group"
          >
            <div class="flex items-center gap-4">
              <div class="size-14 rounded-2xl bg-[#39c98a] text-white flex items-center justify-center font-bold shrink-0">
                <MessageSquare class="size-7" />
              </div>
              <div>
                <span class="text-xs font-mono font-bold uppercase text-slate-500 block">WhatsApp Direct Chat</span>
                <span class="font-display text-lg sm:text-xl font-black text-[#061d33] group-hover:text-[#39c98a] transition-colors">
                  {site.contact.phone}
                </span>
                <p class="text-xs text-slate-600 font-body mt-0.5">Quick voice note or chat consultation</p>
              </div>
            </div>
          </a>

          <!-- Expectation Guarantees -->
          <div class="rounded-2xl border border-slate-300 bg-white/60 p-6 space-y-3 font-body text-sm font-medium text-slate-700">
            <div class="flex items-center gap-2 text-[#061d33] font-bold font-display uppercase">
              <ShieldCheck class="size-5 text-[#ff762b]" />
              <span>COMMERCIAL ASSURANCE</span>
            </div>
            <div class="flex items-center gap-2">
              <Clock class="size-4 text-slate-500 shrink-0" />
              <span>Response within 24 business hours</span>
            </div>
            <div class="flex items-center gap-2">
              <CheckCircle2 class="size-4 text-slate-500 shrink-0" />
              <span>No pushy sales calls or junior account managers</span>
            </div>
          </div>
        </div>

        <!-- Right Column: Professional Interactive Form -->
        <div class="lg:col-span-7">
          <div class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-12 shadow-2xl space-y-6">
            <div>
              <h3 class="font-display text-2xl sm:text-3xl font-black uppercase text-[#061d33] mb-2">
                TELL US ABOUT YOUR PROJECT
              </h3>
              <p class="text-sm sm:text-base text-slate-600 font-body">
                Fill out the form below or message us directly via WhatsApp.
              </p>
            </div>

            <!-- Form -->
            <form 
              id="contact-form"
              action={`mailto:${site.contact.email}`}
              method="GET"
              class="space-y-5"
            >
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="name" class="block font-mono text-xs font-bold uppercase text-[#061d33] mb-2">
                    Your Name *
                  </label>
                  <input 
                    type="text" 
                    id="name" 
                    name="subject"
                    required
                    placeholder="e.g. John Doe"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-sm font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
                <div>
                  <label for="email" class="block font-mono text-xs font-bold uppercase text-[#061d33] mb-2">
                    Email Address *
                  </label>
                  <input 
                    type="email" 
                    id="email" 
                    name="replyto"
                    required
                    placeholder="name@company.com"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-sm font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="phone" class="block font-mono text-xs font-bold uppercase text-[#061d33] mb-2">
                    Phone / WhatsApp
                  </label>
                  <input 
                    type="text" 
                    id="phone" 
                    name="phone"
                    placeholder="+92 300 0000000"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-sm font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
                <div>
                  <label for="company" class="block font-mono text-xs font-bold uppercase text-[#061d33] mb-2">
                    Company / Brand Name
                  </label>
                  <input 
                    type="text" 
                    id="company" 
                    name="company"
                    placeholder="Your Business Name"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-sm font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
              </div>

              <div>
                <label for="service" class="block font-mono text-xs font-bold uppercase text-[#061d33] mb-2">
                  Service Needed *
                </label>
                <select 
                  id="service" 
                  name="service"
                  required
                  class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-sm font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                >
                  <option value="Paid Advertising & Lead Gen">Paid Advertising and Lead Generation</option>
                  <option value="Website Design & E-Commerce">Website Design and E-Commerce</option>
                  <option value="SEO & Local Search">SEO and Local Search</option>
                  <option value="Creative Content">Creative Content</option>
                  <option value="AI Marketing Systems">AI Marketing Systems</option>
                  <option value="Campaign Strategy">Campaign Strategy & Full Execution</option>
                </select>
              </div>

              <div>
                <label for="message" class="block font-mono text-xs font-bold uppercase text-[#061d33] mb-2">
                  Project Details & Goals *
                </label>
                <textarea 
                  id="message" 
                  name="body"
                  rows="4"
                  required
                  placeholder="Tell us about your current campaigns, website, and growth objectives..."
                  class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-sm font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                ></textarea>
              </div>

              <div class="pt-2">
                <button
                  type="submit"
                  class="w-full inline-flex items-center justify-center gap-3 rounded-2xl bg-[#061d33] px-8 py-4 font-display text-lg font-bold text-white shadow-xl hover:bg-[#ff762b] transition-all cursor-pointer"
                >
                  <Send class="size-5 text-[#ddff35]" />
                  <span>SEND ENQUIRY VIA EMAIL</span>
                </button>
              </div>

              <p class="text-xs text-center text-slate-500 font-mono">
                Note: Submitting this form opens your email client directly addressing {site.contact.email}.
              </p>
            </form>
          </div>
        </div>

      </div>

    </Container>
  </section>

  <!-- FAQ Section -->
  <Faq />

  <!-- Approved Navy CTA Panel -->
  <FinalCta />

  <MotionController />
</BaseLayout>
