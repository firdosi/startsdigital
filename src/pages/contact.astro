---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Faq from '../components/landing/Faq.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import MotionController from '../components/common/MotionController.astro';
import { site } from '../site.config';
import { 
  Mail, 
  MessageSquare, 
  Send, 
  CheckCircle2, 
  Clock, 
  ShieldCheck 
} from '@lucide/astro';
---

<BaseLayout 
  title="Contact Starts Digital — Discuss Your Growth Strategy"
  description="Tell us about your business, current challenges and goals. Speak directly with our team to evaluate your paid campaigns, web architecture and growth roadmap."
  type="website"
>
  <!-- Deep Navy Rounded Hero Header -->
  <section class="relative bg-[#061d33] text-white pt-16 pb-20 lg:pt-20 lg:pb-28 rounded-b-[40px] shadow-2xl">
    <Container class="max-w-[1280px] px-6 sm:px-8 text-center space-y-6">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ddff35]">
        <span>CONTACT</span>
      </span>
      
      <!-- Hero Headline: Sora 700 -->
      <h1 class="font-heading font-bold text-[40px] md:text-[50px] lg:text-[64px] text-white leading-[1.08] tracking-[-0.035em] max-w-[800px] mx-auto">
        Let’s talk about your next <span class="text-[#ff762b]">growth opportunity.</span>
      </h1>
      
      <p class="font-body text-[16px] sm:text-[18px] text-slate-200 max-w-[680px] mx-auto leading-[1.65] font-normal">
        Tell us about your business, current challenges and goals. We will review where Starts Digital may be able to help.
      </p>
    </Container>
  </section>

  <!-- Contact Cards & Form Section -->
  <section class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
    <Container class="max-w-[1280px] px-6 sm:px-8">
      
      <div class="grid gap-12 lg:grid-cols-12 items-start">
        
        <!-- Left Column: Clickable Contact Cards & Assurance -->
        <div class="lg:col-span-5 space-y-8">
          <div class="space-y-3">
            <span class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
              DIRECT CHANNELS
            </span>
            <!-- Sora 700 section heading: 31px mobile, 36px tablet, 44px desktop -->
            <h2 class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
              Get in touch directly
            </h2>
            <p class="text-base text-slate-700 font-body leading-[1.65] font-normal">
              We respond promptly to project enquiries with honest commercial evaluations and direct strategic feedback.
            </p>
          </div>

          <!-- Clickable Email Card -->
          <a
            href={`mailto:${site.contact.email}`}
            class="block rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-lg hover:border-[#ff762b] hover:shadow-xl transition-all duration-300 group"
          >
            <div class="flex items-center gap-4">
              <div class="size-14 rounded-2xl bg-[#ff762b] text-white flex items-center justify-center font-bold shrink-0">
                <Mail class="size-7" />
              </div>
              <div>
                <span class="text-xs font-mono font-medium uppercase text-slate-500 block">Email Inquiry</span>
                <span class="font-heading font-semibold text-[18px] sm:text-xl text-[#061d33] group-hover:text-[#ff762b] transition-colors">
                  {site.contact.email}
                </span>
                <p class="text-xs text-slate-600 font-body mt-0.5 font-normal">Direct inbox monitored daily</p>
              </div>
            </div>
          </a>

          <!-- Clickable WhatsApp Card -->
          <a
            href={site.contact.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 shadow-lg hover:border-[#39c98a] hover:shadow-xl transition-all duration-300 group"
          >
            <div class="flex items-center gap-4">
              <div class="size-14 rounded-2xl bg-[#39c98a] text-white flex items-center justify-center font-bold shrink-0">
                <MessageSquare class="size-7" />
              </div>
              <div>
                <span class="text-xs font-mono font-medium uppercase text-slate-500 block">WhatsApp Direct Chat</span>
                <span class="font-heading font-semibold text-[18px] sm:text-xl text-[#061d33] group-hover:text-[#39c98a] transition-colors">
                  {site.contact.phone}
                </span>
                <p class="text-xs text-slate-600 font-body mt-0.5 font-normal">Quick voice note or chat consultation</p>
              </div>
            </div>
          </a>

          <!-- Expectation Guarantees -->
          <div class="rounded-2xl border border-slate-300 bg-white/60 p-6 space-y-3 font-body text-sm font-normal text-slate-700">
            <div class="flex items-center gap-2 text-[#061d33] font-semibold font-body uppercase text-xs tracking-wider">
              <ShieldCheck class="size-5 text-[#ff762b]" />
              <span>COMMERCIAL ASSURANCE</span>
            </div>
            <div class="flex items-center gap-2">
              <Clock class="size-4 text-slate-500 shrink-0" />
              <span>Response within 24 business hours</span>
            </div>
            <div class="flex items-center gap-2">
              <CheckCircle2 class="size-4 text-slate-500 shrink-0" />
              <span>No pushy sales calls or junior account managers</span>
            </div>
          </div>
        </div>

        <!-- Right Column: Professional Interactive Form -->
        <div class="lg:col-span-7">
          <div class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-12 shadow-2xl space-y-6">
            <div>
              <!-- Form title: Sora 600 -->
              <h3 class="font-heading font-semibold text-2xl sm:text-3xl text-[#061d33] mb-2 leading-tight">
                Tell us about your project
              </h3>
              <p class="text-base text-slate-600 font-body leading-[1.65] font-normal">
                Choose your preferred channel below (Email or WhatsApp) to send your inquiry directly to our execution team.
              </p>
            </div>

            <!-- Form -->
            <form 
              id="contact-form"
              class="space-y-5"
            >
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="name" class="block font-mono text-xs font-medium uppercase text-[#061d33] mb-2">
                    Your Name *
                  </label>
                  <input 
                    type="text" 
                    id="name" 
                    required
                    placeholder="e.g. John Doe"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
                <div>
                  <label for="email" class="block font-mono text-xs font-medium uppercase text-[#061d33] mb-2">
                    Email Address *
                  </label>
                  <input 
                    type="email" 
                    id="email" 
                    required
                    placeholder="name@company.com"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="phone" class="block font-mono text-xs font-medium uppercase text-[#061d33] mb-2">
                    Phone / WhatsApp
                  </label>
                  <input 
                    type="text" 
                    id="phone" 
                    placeholder="+92 300 0000000"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
                <div>
                  <label for="company" class="block font-mono text-xs font-medium uppercase text-[#061d33] mb-2">
                    Company / Brand Name
                  </label>
                  <input 
                    type="text" 
                    id="company" 
                    placeholder="Your Business Name"
                    class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                  />
                </div>
              </div>

              <div>
                <label for="service" class="block font-mono text-xs font-medium uppercase text-[#061d33] mb-2">
                  Service Needed *
                </label>
                <select 
                  id="service" 
                  required
                  class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                >
                  <option value="Paid Advertising & Lead Gen">Paid Advertising and Lead Generation</option>
                  <option value="Website Design & E-Commerce">Website Design and E-Commerce</option>
                  <option value="SEO & Local Search">SEO and Local Search</option>
                  <option value="Creative Content">Creative Content</option>
                  <option value="AI Marketing Systems">AI Marketing Systems</option>
                  <option value="Campaign Strategy">Campaign Strategy & Full Execution</option>
                </select>
              </div>

              <div>
                <label for="message" class="block font-mono text-xs font-medium uppercase text-[#061d33] mb-2">
                  Project Details & Goals *
                </label>
                <textarea 
                  id="message" 
                  rows="4"
                  required
                  placeholder="Tell us about your current campaigns, website, and growth objectives..."
                  class="w-full rounded-xl border border-slate-300 bg-[#f7f4ed]/50 px-4 py-3.5 text-base font-body text-[#061d33] focus:border-[#ff762b] focus:bg-white focus:outline-none transition-all"
                ></textarea>
              </div>

              <!-- Action Choice Buttons: Inter 600 min 16px -->
              <div class="pt-2 grid gap-4 sm:grid-cols-2 font-body">
                <button
                  type="button"
                  id="btn-send-email"
                  class="w-full inline-flex items-center justify-center min-h-[48px] gap-2 rounded-2xl bg-[#061d33] px-6 py-4 font-body font-semibold text-base text-white shadow-lg hover:bg-[#ff762b] transition-all cursor-pointer"
                >
                  <Send class="size-5 text-[#ddff35]" />
                  <span>Send via Email</span>
                </button>

                <button
                  type="button"
                  id="btn-send-whatsapp"
                  class="w-full inline-flex items-center justify-center min-h-[48px] gap-2 rounded-2xl bg-[#39c98a] px-6 py-4 font-body font-semibold text-base text-white shadow-lg hover:bg-[#2fb078] transition-all cursor-pointer"
                >
                  <MessageSquare class="size-5 text-white" />
                  <span>Send via WhatsApp</span>
                </button>
              </div>

              <p class="text-xs text-center text-slate-500 font-mono">
                Note: Selecting Email opens your email client addressing {site.contact.email}. Selecting WhatsApp opens WhatsApp directly with your pre-filled inquiry.
              </p>
            </form>
          </div>
        </div>

      </div>

    </Container>
  </section>

  <!-- FAQ Section -->
  <Faq />

  <!-- Approved Navy CTA Panel -->
  <FinalCta />

  <MotionController />

  <!-- Client-side Interactive Form Dispatcher -->
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btnEmail = document.getElementById('btn-send-email');
    const btnWhatsApp = document.getElementById('btn-send-whatsapp');

    function getFormData() {
      const name = (document.getElementById('name') as HTMLInputElement)?.value.trim() || 'Not specified';
      const email = (document.getElementById('email') as HTMLInputElement)?.value.trim() || 'Not specified';
      const phone = (document.getElementById('phone') as HTMLInputElement)?.value.trim() || 'Not specified';
      const company = (document.getElementById('company') as HTMLInputElement)?.value.trim() || 'Not specified';
      const service = (document.getElementById('service') as HTMLSelectElement)?.value || 'General Inquiry';
      const message = (document.getElementById('message') as HTMLTextAreaElement)?.value.trim() || '';

      return { name, email, phone, company, service, message };
    }

    btnEmail?.addEventListener('click', () => {
      if (!form.reportValidity()) return;
      const data = getFormData();
      const subject = encodeURIComponent(`Starts Digital Project Inquiry: ${data.service}`);
      const body = encodeURIComponent(
        `Name: ${data.name}\nEmail: ${data.email}\nPhone/WhatsApp: ${data.phone}\nCompany: ${data.company}\nService Needed: ${data.service}\n\nProject Details:\n${data.message}`
      );
      window.location.href = `mailto:firdosidigital@gmail.com?subject=${subject}&body=${body}`;
    });

    btnWhatsApp?.addEventListener('click', () => {
      if (!form.reportValidity()) return;
      const data = getFormData();
      const text = encodeURIComponent(
        `Hello Starts Digital,\n\nI would like to discuss a project:\n\n*Name:* ${data.name}\n*Email:* ${data.email}\n*Phone:* ${data.phone}\n*Company:* ${data.company}\n*Service Needed:* ${data.service}\n\n*Project Details:*\n${data.message}`
      );
      window.open(`https://wa.me/923394135544?text=${text}`, '_blank');
    });
  </script>
</BaseLayout>
