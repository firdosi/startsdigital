---
import '@fontsource/sora/400.css';
import '@fontsource/sora/600.css';
import '@fontsource/sora/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/500.css';

import '../styles/global.css';

import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SEO from '../components/seo/SEO.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import { ClientRouter } from 'astro:transitions';
import { site } from '../site.config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  schemaType?: 'homepage' | 'case-study' | 'page';
  noindex?: boolean;
}

const { title, description, image, type, schemaType, noindex } = Astro.props;
const currentPath = Astro.url.pathname;
const calculatedSchemaType = schemaType || (currentPath === `${site.basePath}/` || currentPath === `${site.basePath}` || currentPath === '/' ? 'homepage' : (currentPath.includes('/work/') && currentPath !== `${site.basePath}/work/` ? 'case-study' : 'page'));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Favicon & App Icons -->
    <link rel="icon" type="image/svg+xml" href={`${site.basePath}/favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${site.basePath}/favicon-32x32.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${site.basePath}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${site.basePath}/site.webmanifest`} />
    <link rel="sitemap" href={`${site.basePath}/sitemap-index.xml`} />
    
    <SEO title={title} description={description} ogImage={image} ogType={type} noindex={noindex} />
    <StructuredData type={calculatedSchemaType} title={title} description={description} image={image} />
    <ClientRouter fallback="swap" />
    
    <script is:inline>
      if (typeof window !== 'undefined' && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('motion-initialized');
      }
    </script>
    <noscript>
      <style>
        [data-motion], .reveal-on-scroll {
          opacity: 1 !important;
          transform: none !important;
          clip-path: none !important;
          filter: none !important;
        }
      </style>
    </noscript>
    <slot name="head" />
  </head>
  <body class="bg-[#f7f4ed] text-[#061d33] antialiased selection:bg-[#ff762b] selection:text-white font-body">
    <!-- Accessibility Skip to Main Content Link -->
    <a 
      href="#main-content" 
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-5 focus:py-3 focus:bg-[#061d33] focus:text-white focus:rounded-xl focus:shadow-2xl focus:outline-none focus:ring-2 focus:ring-[#ff762b]"
    >
      Skip to main content
    </a>

    <div class="max-w-full overflow-x-clip bg-[#f7f4ed]">
      <Header />
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
