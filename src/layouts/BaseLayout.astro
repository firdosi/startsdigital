---
import '@fontsource/sora/400.css';
import '@fontsource/sora/600.css';
import '@fontsource/sora/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/500.css';

import '../styles/global.css';

import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SEO from '../components/seo/SEO.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import { site } from '../site.config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const seo = Astro.props;
---

<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${site.basePath}/favicon.svg`} />
    <link rel="sitemap" href={`${site.basePath}/sitemap-index.xml`} />
    <SEO {...seo} />
    <StructuredData />
    <slot name="head" />
  </head>
  <body class="bg-[#f7f4ed] text-[#061d33] antialiased selection:bg-[#ff762b] selection:text-white font-body">
    <div class="max-w-full overflow-x-clip bg-[#f7f4ed]">
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
