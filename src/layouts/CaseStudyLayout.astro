---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { site } from '../site.config';

interface Props {
  entry: {
    id: string;
    data: {
      title: string;
      description: string;
      industry: string;
      services: string[];
      outcomeSummary: string;
      metrics: Array<{ value: string; label: string }>;
      responsibilities: string[];
      seoTitle: string;
      seoDescription: string;
      ogImage?: string;
      heroImage?: { src: string; alt: string; caption?: string };
      gallery?: Array<{ src: string; alt: string; caption?: string }>;
    };
  };
}

const { entry } = Astro.props;
const { data } = entry;
---

<BaseLayout 
  title={`${data.seoTitle} — Starts Digital`} 
  description={data.seoDescription}
  type="article"
  image={data.ogImage}
>
  <div class="bg-paper min-h-screen">
    <!-- Hero Header Section -->
    <section class="bg-linear-160 from-navy to-navy-deep text-cloud py-16 sm:py-20 border-b-4 border-ink">
      <Container class="max-w-[1000px] px-6 sm:px-8 space-y-6">
        <span class="inline-flex items-center gap-2 rounded-full bg-orange px-3.5 py-1 text-xs font-bold font-display uppercase tracking-wider text-cloud">
          ✦ {data.industry}
        </span>
        <h1 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-cloud leading-tight">
          {data.title}
        </h1>
        <p class="font-body text-lg sm:text-xl text-sky leading-relaxed max-w-3xl">
          {data.description}
        </p>
      </Container>
    </section>

    <!-- Key Metrics Cards -->
    <section class="py-10 bg-orange-soft border-b-2 border-ink">
      <Container class="max-w-[1000px] px-6 sm:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {
            data.metrics.map((metric) => (
              <div class="rounded-tile border-2 border-ink bg-cloud p-6 shadow-pop">
                <span class="font-display text-3xl sm:text-4xl font-bold text-orange block">
                  {metric.value}
                </span>
                <p class="font-display text-sm font-bold text-navy uppercase tracking-wider mt-2">
                  {metric.label}
                </p>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- Specifications & Content -->
    <section class="py-16 sm:py-20 bg-paper">
      <Container class="max-w-[1000px] px-6 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Sidebar -->
        <div class="lg:col-span-4 space-y-6">
          <div class="rounded-card border-2 border-ink bg-cloud p-6 shadow-pop space-y-6">
            <div>
              <span class="block font-display text-xs font-bold tracking-widest text-orange uppercase mb-1">
                Industry
              </span>
              <p class="font-body text-base font-bold text-navy">
                {data.industry}
              </p>
            </div>

            <div class="border-t border-line pt-4">
              <span class="block font-display text-xs font-bold tracking-widest text-orange uppercase mb-2">
                Services Delivered
              </span>
              <ul class="space-y-1.5 text-sm font-body font-semibold text-slate-700">
                {
                  data.services.map((service) => (
                    <li class="flex items-center gap-2">
                      <span class="text-orange">✓</span> {service}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-8 space-y-8">
          <div class="rounded-card border-2 border-ink bg-cloud p-8 shadow-pop space-y-6">
            <h2 class="font-display text-2xl font-bold text-navy border-b border-line pb-4">
              Campaign Execution & Responsibilities
            </h2>
            <ul class="space-y-3 font-body text-base text-slate-700 leading-relaxed">
              {
                data.responsibilities.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="text-orange font-bold text-lg leading-none mt-0.5">•</span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="prose max-w-none pt-2">
            <slot />
          </div>
        </div>
      </Container>
    </section>

    <!-- Bottom CTA Banner -->
    <section class="bg-linear-160 from-navy to-navy-deep text-cloud py-16 border-t-4 border-ink">
      <Container class="max-w-[800px] px-6 sm:px-8 text-center space-y-6">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-cloud">
          Ready to scale your commercial digital growth?
        </h2>
        <p class="font-body text-lg text-sky-mist">
          Speak directly with our team to evaluate your ad campaigns and web strategy.
        </p>
        <div>
          <a 
            href={`${site.basePath}/#contact`} 
            class="inline-block rounded-full bg-orange px-8 py-4 font-bold text-cloud shadow-pop-white transition-transform hover:-translate-x-0.5 hover:-translate-y-0.5"
          >
            Discuss Your Project →
          </a>
        </div>
      </Container>
    </section>
  </div>
</BaseLayout>
