---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import MotionController from '../components/common/MotionController.astro';
import { site } from '../site.config';
import { ArrowRight, CheckCircle2, Sparkles, ArrowLeft } from '@lucide/astro';

interface Props {
  entry: {
    id: string;
    data: {
      title: string;
      description: string;
      industry: string;
      services: string[];
      outcomeSummary: string;
      metrics: Array<{ value: string; label: string }>;
      responsibilities: string[];
      seoTitle: string;
      seoDescription: string;
      ogImage?: string;
      heroImage?: { src: string; alt: string; caption?: string };
      gallery?: Array<{ src: string; alt: string; caption?: string }>;
    };
  };
}

const { entry } = Astro.props;
const { data } = entry;
---

<BaseLayout 
  title={`${data.seoTitle} — Starts Digital`} 
  description={data.seoDescription}
  type="article"
  image={data.ogImage}
>
  <div class="bg-[#f7f4ed] min-h-screen text-[#061d33]">
    <!-- Deep Navy Hero Header Section -->
    <section class="bg-[#061d33] text-white py-16 sm:py-24 border-b border-white/10 relative overflow-hidden rounded-b-[40px] shadow-2xl">
      <Container class="relative max-w-[1000px] px-6 sm:px-8 space-y-6">
        <div class="flex items-center justify-between gap-4">
          <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-mono font-bold uppercase tracking-wider text-[#ddff35]">
            <Sparkles class="size-3.5 text-[#ddff35]" />
            <span>{data.industry}</span>
          </span>

          <a 
            href={`${site.basePath}/work/`}
            class="inline-flex items-center gap-2 text-xs font-mono font-bold text-slate-300 hover:text-[#ddff35] transition-colors"
          >
            <ArrowLeft class="size-3.5" />
            <span>Back to All Work</span>
          </a>
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tight text-white leading-tight">
          {data.title}
        </h1>
        <p class="font-body text-lg sm:text-xl text-slate-200 leading-relaxed max-w-3xl font-medium">
          {data.description}
        </p>
      </Container>
    </section>

    <!-- Key Metrics Cards -->
    <section class="py-12 bg-white border-b border-[#061d33]/10">
      <Container class="max-w-[1000px] px-6 sm:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {
            data.metrics.map((metric) => (
              <div class="rounded-2xl border-2 border-[#061d33]/15 bg-[#f7f4ed] p-6 shadow-sm">
                <span class="font-display text-3xl sm:text-5xl font-black text-[#ff762b] uppercase block">
                  {metric.value}
                </span>
                <p class="font-display text-sm font-bold text-[#061d33] uppercase tracking-wider mt-2">
                  {metric.label}
                </p>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- Specifications & Content -->
    <section class="py-16 sm:py-20">
      <Container class="max-w-[1000px] px-6 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Sidebar -->
        <div class="lg:col-span-4 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
            <div>
              <span class="block font-mono text-xs font-bold tracking-wider text-[#ff762b] uppercase mb-1">
                Industry
              </span>
              <p class="font-display text-lg font-bold text-[#061d33]">
                {data.industry}
              </p>
            </div>

            <div class="border-t border-slate-100 pt-4">
              <span class="block font-mono text-xs font-bold tracking-wider text-[#ff762b] uppercase mb-3">
                Services Delivered
              </span>
              <ul class="space-y-2.5 text-sm font-body font-medium text-slate-700">
                {
                  data.services.map((service) => (
                    <li class="flex items-center gap-2">
                      <CheckCircle2 class="size-4 text-[#ff762b] shrink-0" />
                      <span>{service}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-8 space-y-8">
          <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm space-y-6">
            <h2 class="font-display text-2xl font-black uppercase text-[#061d33] border-b border-slate-100 pb-4">
              Campaign Execution & Responsibilities
            </h2>
            <ul class="space-y-3 font-body text-base text-slate-700 leading-relaxed font-medium">
              {
                data.responsibilities.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="text-[#ff762b] font-bold text-lg leading-none mt-0.5">•</span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="prose prose-slate max-w-none pt-2">
            <slot />
          </div>
        </div>
      </Container>
    </section>

    <!-- Approved Navy CTA Panel -->
    <FinalCta />
  </div>

  <MotionController />
</BaseLayout>
