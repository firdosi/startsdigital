---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import FinalCta from '../components/landing/FinalCta.astro';
import MotionController from '../components/common/MotionController.astro';
import { getCollection } from 'astro:content';
import { site } from '../site.config';
import { ArrowRight, CheckCircle, ArrowLeft, Image as ImageIcon } from '@lucide/astro';

interface Props {
  entry: {
    id: string;
    data: {
      title: string;
      description: string;
      industry: string;
      services: string[];
      outcomeSummary: string;
      metrics: Array<{ value: string; label: string }>;
      responsibilities: string[];
      seoTitle: string;
      seoDescription: string;
      ogImage?: string;
      heroImage?: { src: string; alt: string; caption?: string };
      gallery?: Array<{ src: string; alt: string; caption?: string }>;
    };
  };
}

const { entry } = Astro.props;
const { data } = entry;

// Fetch all case studies for previous / next project navigation
const allStudies = await getCollection('case-studies', ({ data }) => !data.draft);
const sortedStudies = allStudies.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sortedStudies.findIndex((s) => s.id === entry.id);

const prevStudy = currentIndex > 0 ? sortedStudies[currentIndex - 1] : sortedStudies[sortedStudies.length - 1];
const nextStudy = currentIndex < sortedStudies.length - 1 ? sortedStudies[currentIndex + 1] : sortedStudies[0];
---

<BaseLayout 
  title={`${data.seoTitle} — Starts Digital`} 
  description={data.seoDescription}
  type="article"
  image={data.ogImage}
>
  <div class="bg-[#f7f4ed] min-h-screen text-[#061d33] overflow-hidden">
    <!-- Deep Navy Hero Header Section -->
    <section class="bg-[#061d33] text-white pt-16 pb-20 sm:pt-20 sm:pb-24 border-b border-white/10 relative overflow-hidden rounded-b-[40px] shadow-2xl">
      <Container class="relative max-w-[1000px] px-6 sm:px-8 space-y-6">
        <div class="flex items-center justify-between gap-4">
          <div data-motion="scale-in">
            <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-mono font-medium uppercase tracking-[0.05em] text-[#ddff35]">
              <span>{data.industry}</span>
            </span>
          </div>

          <a 
            href={`${site.basePath}/work/`}
            class="inline-flex items-center gap-2 text-xs font-mono font-medium text-slate-300 hover:text-[#ddff35] transition-colors"
          >
            <ArrowLeft class="size-3.5" />
            <span>Back to all work</span>
          </a>
        </div>

        <!-- Headline Clip-Up -->
        <h1 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[32px] sm:text-[46px] lg:text-[54px] text-white leading-[1.12] tracking-[-0.025em]">
          {data.title}
        </h1>
        <p data-motion="fade-up" data-motion-delay="200" class="font-body text-lg sm:text-xl text-slate-200 leading-[1.65] max-w-3xl font-normal">
          {data.description}
        </p>
      </Container>
    </section>

    <!-- Key Metrics Cards (Pop-In) -->
    <section class="py-10 bg-white border-b border-[#061d33]/10">
      <Container class="max-w-[1000px] px-6 sm:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {
            data.metrics.map((metric, idx) => (
              <div data-motion="pop-in" data-motion-delay={idx * 100} class="rounded-2xl border-2 border-[#061d33]/15 bg-[#f7f4ed] p-6 shadow-sm font-body hover:shadow-md transition-shadow">
                <span class="font-heading font-bold text-3xl sm:text-4xl lg:text-5xl text-[#ff762b] block tracking-[-0.025em]">
                  {metric.value}
                </span>
                <p class="font-body font-semibold text-sm text-[#061d33] tracking-normal mt-2">
                  {metric.label}
                </p>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- Primary Hero Visual Component (heroImage) with Clip-Left Mask -->
    {data.heroImage && (
      <section class="pt-12 pb-4 bg-[#f7f4ed]">
        <Container class="max-w-[1000px] px-6 sm:px-8">
          <div class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-4 sm:p-6 shadow-xl overflow-hidden group">
            <div class="relative overflow-hidden rounded-2xl bg-[#061d33]/5 border border-slate-200">
              <img 
                src={`${site.basePath}${data.heroImage.src}`} 
                alt={data.heroImage.alt}
                width="1000"
                height="500"
                loading="eager"
                decoding="async"
                class="w-full max-h-[500px] object-cover sm:object-contain bg-slate-900/5 group-hover:scale-103 transition-transform duration-500"
              />
            </div>
            {data.heroImage.caption && (
              <div class="mt-4 flex items-center justify-between text-xs font-mono font-medium text-slate-600 px-2">
                <span class="inline-flex items-center gap-1.5 uppercase text-[#ff762b]">
                  <ImageIcon class="size-4" />
                  <span>Project visual</span>
                </span>
                <span>{data.heroImage.caption}</span>
              </div>
            )}
          </div>
        </Container>
      </section>
    )}

    <!-- Specifications & Main Case Content -->
    <section class="py-12 sm:py-16">
      <Container class="max-w-[1000px] px-6 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Sidebar -->
        <div data-motion="fade-right" data-motion-delay="200" class="lg:col-span-4 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6 sticky top-8">
            <div>
              <span class="block font-mono text-xs font-medium tracking-[0.05em] text-[#ff762b] uppercase mb-1">
                Industry
              </span>
              <p class="font-heading font-semibold text-lg text-[#061d33]">
                {data.industry}
              </p>
            </div>

            <div class="border-t border-slate-100 pt-4">
              <span class="block font-mono text-xs font-medium tracking-[0.05em] text-[#ff762b] uppercase mb-3">
                Services Delivered
              </span>
              <ul class="space-y-2.5 text-sm font-body font-normal text-slate-700">
                {
                  data.services.map((service) => (
                    <li class="flex items-center gap-2">
                      <CheckCircle class="size-4 text-[#ff762b] shrink-0" />
                      <span>{service}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <!-- Main Content -->
        <div data-motion="fade-left" data-motion-delay="250" class="lg:col-span-8 space-y-8">
          <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm space-y-6">
            <h2 class="font-heading font-semibold text-xl sm:text-2xl text-[#061d33] border-b border-slate-100 pb-4">
              Campaign execution and scope
            </h2>
            <ul class="space-y-3 font-body text-base text-slate-700 leading-[1.65] font-normal">
              {
                data.responsibilities.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="text-[#ff762b] font-bold text-lg leading-none mt-0.5">•</span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm space-y-6 prose prose-slate max-w-none font-body leading-[1.65]">
            <slot />
          </div>
        </div>
      </Container>
    </section>

    <!-- Project Gallery Visuals Component -->
    {data.gallery && data.gallery.length > 0 && (
      <section class="py-12 bg-white border-t border-b border-[#061d33]/10">
        <Container class="max-w-[1000px] px-6 sm:px-8 space-y-8">
          <div class="flex items-center justify-between">
            <h3 data-motion="clip-up" class="font-heading font-semibold text-xl sm:text-2xl text-[#061d33]">
              Project gallery
            </h3>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            {data.gallery.map((img, idx) => (
              <div data-motion="fade-up" data-motion-delay={idx * 100} class="rounded-2xl border border-slate-200 bg-[#f7f4ed] p-3 shadow-md overflow-hidden group">
                <div class="relative overflow-hidden rounded-xl bg-white border border-slate-200">
                  <img 
                    src={`${site.basePath}${img.src}`} 
                    alt={img.alt}
                    class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                {img.caption && (
                  <p class="mt-3 text-xs font-mono font-medium text-slate-600 px-1">
                    {img.caption}
                  </p>
                )}
              </div>
            ))}
          </div>
        </Container>
      </section>
    )}

    <!-- Previous / Next Project Navigation -->
    <section class="py-16 bg-[#f7f4ed] border-t border-[#061d33]/10">
      <Container class="max-w-[1000px] px-6 sm:px-8">
        <div data-motion="scale-in" class="text-xs font-mono font-medium uppercase tracking-[0.06em] text-slate-500 mb-6 text-center">
          EXPLORE MORE CASE STUDIES
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          {prevStudy && (
            <a 
              data-motion="fade-right"
              href={`${site.basePath}/work/${prevStudy.id}/`}
              class="rounded-2xl border-2 border-[#061d33]/15 bg-white p-6 shadow-md hover:border-[#ff762b] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group"
            >
              <div class="space-y-2">
                <span class="inline-flex items-center gap-1 text-xs font-mono font-medium uppercase text-[#ff762b]">
                  <ArrowLeft class="size-3.5 group-hover:-translate-x-1 transition-transform" />
                  <span>Previous case study</span>
                </span>
                <h4 class="font-heading font-semibold text-lg sm:text-xl text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-snug">
                  {prevStudy.data.title}
                </h4>
              </div>
              <p class="text-xs font-mono font-medium text-slate-500 uppercase mt-4">
                {prevStudy.data.industry}
              </p>
            </a>
          )}

          {nextStudy && (
            <a 
              data-motion="fade-left"
              href={`${site.basePath}/work/${nextStudy.id}/`}
              class="rounded-2xl border-2 border-[#061d33]/15 bg-white p-6 shadow-md hover:border-[#ff762b] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between text-right group"
            >
              <div class="space-y-2">
                <span class="inline-flex items-center gap-1 justify-end text-xs font-mono font-medium uppercase text-[#ff762b]">
                  <span>Next case study</span>
                  <ArrowRight class="size-3.5 group-hover:translate-x-1 transition-transform" />
                </span>
                <h4 class="font-heading font-semibold text-lg sm:text-xl text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-snug">
                  {nextStudy.data.title}
                </h4>
              </div>
              <p class="text-xs font-mono font-medium text-slate-500 uppercase mt-4">
                {nextStudy.data.industry}
              </p>
            </a>
          )}
        </div>
      </Container>
    </section>

    <!-- Approved Navy CTA Panel -->
    <FinalCta />
  </div>

  <MotionController />
</BaseLayout>
