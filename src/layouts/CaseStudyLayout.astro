---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { site } from '../site.config';
import { ArrowRight, CheckCircle2, Sparkles } from '@lucide/astro';

interface Props {
  entry: {
    id: string;
    data: {
      title: string;
      description: string;
      industry: string;
      services: string[];
      outcomeSummary: string;
      metrics: Array<{ value: string; label: string }>;
      responsibilities: string[];
      seoTitle: string;
      seoDescription: string;
      ogImage?: string;
      heroImage?: { src: string; alt: string; caption?: string };
      gallery?: Array<{ src: string; alt: string; caption?: string }>;
    };
  };
}

const { entry } = Astro.props;
const { data } = entry;
---

<BaseLayout 
  title={`${data.seoTitle} — Starts Digital`} 
  description={data.seoDescription}
  type="article"
  image={data.ogImage}
>
  <div class="bg-[#f8fafc] min-h-screen text-slate-900">
    <!-- Hero Header Section -->
    <section class="bg-[#090d16] text-white py-16 sm:py-24 border-b border-white/10 relative overflow-hidden">
      <div class="pointer-events-none absolute inset-0 bg-grid-pattern opacity-30"></div>
      <Container class="relative max-w-[1000px] px-6 sm:px-8 space-y-6">
        <span class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-xs font-bold font-mono uppercase tracking-wider text-blue-400">
          <Sparkles class="size-3.5" />
          <span>{data.industry}</span>
        </span>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight">
          {data.title}
        </h1>
        <p class="font-body text-lg sm:text-xl text-slate-300 leading-relaxed max-w-3xl">
          {data.description}
        </p>
      </Container>
    </section>

    <!-- Key Metrics Cards -->
    <section class="py-12 bg-white border-b border-slate-200/80">
      <Container class="max-w-[1000px] px-6 sm:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {
            data.metrics.map((metric) => (
              <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6 shadow-xs">
                <span class="font-display text-3xl sm:text-4xl font-extrabold text-blue-600 block">
                  {metric.value}
                </span>
                <p class="font-display text-sm font-bold text-slate-900 uppercase tracking-wider mt-2">
                  {metric.label}
                </p>
              </div>
            ))
          }
        </div>
      </Container>
    </section>

    <!-- Specifications & Content -->
    <section class="py-16 sm:py-20">
      <Container class="max-w-[1000px] px-6 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Sidebar -->
        <div class="lg:col-span-4 space-y-6">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
            <div>
              <span class="block font-mono text-xs font-bold tracking-wider text-blue-600 uppercase mb-1">
                Industry
              </span>
              <p class="font-display text-base font-bold text-slate-900">
                {data.industry}
              </p>
            </div>

            <div class="border-t border-slate-100 pt-4">
              <span class="block font-mono text-xs font-bold tracking-wider text-blue-600 uppercase mb-3">
                Services Delivered
              </span>
              <ul class="space-y-2 text-sm font-body font-medium text-slate-700">
                {
                  data.services.map((service) => (
                    <li class="flex items-center gap-2">
                      <CheckCircle2 class="size-4 text-blue-600 shrink-0" />
                      <span>{service}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-8 space-y-8">
          <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm space-y-6">
            <h2 class="font-display text-2xl font-bold text-slate-900 border-b border-slate-100 pb-4">
              Campaign Execution & Responsibilities
            </h2>
            <ul class="space-y-3 font-body text-base text-slate-700 leading-relaxed">
              {
                data.responsibilities.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="text-blue-600 font-bold text-lg leading-none mt-0.5">•</span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="prose prose-slate max-w-none pt-2">
            <slot />
          </div>
        </div>
      </Container>
    </section>

    <!-- Bottom CTA Banner -->
    <section class="bg-[#090d16] text-white py-16 border-t border-white/10">
      <Container class="max-w-[800px] px-6 sm:px-8 text-center space-y-6">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-white">
          Ready to scale your commercial digital growth?
        </h2>
        <p class="font-body text-lg text-slate-300">
          Speak directly with our team to evaluate your ad campaigns and web strategy.
        </p>
        <div>
          <a 
            href={`${site.basePath}/#contact`} 
            class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-8 py-4 font-display text-base font-bold text-white shadow-xl shadow-blue-600/30 hover:bg-blue-500 transition-all"
          >
            <span>Discuss Your Project</span>
            <ArrowRight class="size-5" />
          </a>
        </div>
      </Container>
    </section>
  </div>
</BaseLayout>
