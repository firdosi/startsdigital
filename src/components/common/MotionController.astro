---
// MotionController.astro — Reusable Hardware-Accelerated Intersection Observer Motion Architecture
---

<script>
  function initMotionArchitecture() {
    // 1. Mark motion as initialized so CSS pre-animation hidden states take effect safely
    document.documentElement.classList.add('motion-initialized');

    const motionElements = document.querySelectorAll<HTMLElement>('[data-motion], .reveal-on-scroll');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Safety Fallback: Guarantee reveal after 1.2s so no element is ever trapped invisible
    setTimeout(() => {
      motionElements.forEach((el) => {
        el.classList.add('is-motion-revealed', 'is-revealed');
      });
    }, 1200);

    if (prefersReducedMotion) {
      motionElements.forEach((el) => {
        el.classList.add('is-motion-revealed', 'is-revealed');
      });
      return;
    }

    if ('IntersectionObserver' in window) {
      // Single observer for all motion elements
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              
              // Handle group stagger if present
              const delayAttr = el.dataset.motionDelay || el.dataset.revealDelay || '0';
              const durationAttr = el.dataset.motionDuration || '700';

              el.style.setProperty('--motion-del', `${delayAttr}ms`);
              el.style.setProperty('--motion-dur', `${durationAttr}ms`);

              if (parseInt(delayAttr, 10) > 0) {
                setTimeout(() => {
                  el.classList.add('is-motion-revealed', 'is-revealed');
                }, parseInt(delayAttr, 10));
              } else {
                el.classList.add('is-motion-revealed', 'is-revealed');
              }

              // Disconnect observer after animation completes
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      motionElements.forEach((el) => observer.observe(el));

      // Handle grouped stagger elements automatically
      const groups = document.querySelectorAll<HTMLElement>('[data-motion-group]');
      groups.forEach((group) => {
        const staggerMs = parseInt(group.dataset.motionStagger || '80', 10);
        const children = group.querySelectorAll<HTMLElement>('[data-motion], .reveal-on-scroll');
        children.forEach((child, index) => {
          if (!child.dataset.motionDelay) {
            child.dataset.motionDelay = String(index * staggerMs);
          }
        });
      });

      // Counter Observer
      const counterElements = document.querySelectorAll<HTMLElement>('[data-counter-target]');
      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            const el = entry.target as HTMLElement;
            const targetNum = parseFloat(el.dataset.counterTarget || '0');
            const exactText = el.dataset.counterExact || el.textContent || '';
            const prefix = el.dataset.counterPrefix || '';
            const suffix = el.dataset.counterSuffix || '';
            const decimals = parseInt(el.dataset.counterDecimals || '0', 10);
            const duration = 1200;
            const startTime = performance.now();

            function formatValue(val: number) {
              return val.toLocaleString(undefined, {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals,
              });
            }

            function updateCounter(currentTime: number) {
              const elapsed = currentTime - startTime;
              const progress = Math.min(elapsed / duration, 1);
              // cubic-bezier(0.16, 1, 0.3, 1) easeOutQuint equivalent
              const eased = 1 - Math.pow(1 - progress, 4);
              const currentVal = targetNum * eased;

              if (progress < 1) {
                el.textContent = `${prefix}${formatValue(currentVal)}${suffix}`;
                requestAnimationFrame(updateCounter);
              } else {
                // Guaranteed final exact value string
                el.textContent = exactText;
              }
            }

            requestAnimationFrame(updateCounter);
            counterObserver.unobserve(el);
          });
        },
        { threshold: 0.15 }
      );

      counterElements.forEach((el) => counterObserver.observe(el));

      // Header Scroll Shadow Controller
      const header = document.getElementById('main-header');
      if (header) {
        let ticked = false;
        window.addEventListener('scroll', () => {
          if (!ticked) {
            requestAnimationFrame(() => {
              if (window.scrollY > 20) {
                header.classList.add('shadow-xl', 'bg-[#061d33]/95', 'backdrop-blur-md');
              } else {
                header.classList.remove('shadow-xl', 'bg-[#061d33]/95', 'backdrop-blur-md');
              }
              ticked = false;
            });
            ticked = true;
          }
        }, { passive: true });
      }

    } else {
      // Direct fallback for environments without IntersectionObserver
      motionElements.forEach((el) => {
        el.classList.add('is-motion-revealed', 'is-revealed');
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMotionArchitecture);
  } else {
    initMotionArchitecture();
  }
</script>
