---
import { site } from '../../site.config';

interface Props {
  href?: string;
  isDarkBackground?: boolean;
}

const { href = `${site.basePath}/`, isDarkBackground = true } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center font-body font-bold text-[22px] sm:text-[25px] leading-none tracking-normal transition-opacity hover:opacity-90"
  aria-label="Starts Digital Home"
>
  <span class={isDarkBackground ? 'text-white' : 'text-[#061d33]'}>Starts</span>
  <span class="text-[#2563eb]">Digital</span>
</a>
