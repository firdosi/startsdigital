---
import { site } from '../../site.config';

interface Props {
  size?: 'md' | 'sm';
  href?: string;
}
const { size = 'md', href = `${site.basePath}/` } = Astro.props;
const mark = size === 'md' ? 'size-8 rounded-lg' : 'size-7 rounded-md';
const text = size === 'md' ? 'text-xl' : 'text-lg';
---

<a
  href={href}
  class:list={[
    'flex items-center gap-2.5 font-display font-bold tracking-tight text-white group',
    text,
  ]}
>
  <span class:list={['relative flex items-center justify-center bg-blue-600 text-white font-mono text-xs font-black shadow-md shadow-blue-500/25 transition-transform group-hover:scale-105', mark]}>
    <svg class="size-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
    </svg>
  </span>
  <span class="tracking-tight">Starts<span class="text-blue-500 font-extrabold">Digital</span></span>
</a>
