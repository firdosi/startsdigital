---
import { headerNavLinks } from '../../data/navigation';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div
  id={id}
  class="fixed inset-y-0 right-0 z-40 w-full max-w-sm translate-x-full bg-white border-l border-brand-light-border pt-24 px-8 pb-8 transition-transform duration-300 md:hidden flex flex-col justify-between shadow-2xl"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile Navigation"
>
  <nav class="flex flex-col gap-4">
    {
      headerNavLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link font-heading text-lg font-semibold text-brand-black hover:text-brand-blue py-3 border-b border-brand-light-border/60 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue"
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="mt-auto pt-6">
    <Button 
      href={siteConfig.links.contact} 
      variant="primary" 
      class="w-full text-center py-3 font-semibold" 
      id="mobile-menu-cta"
    >
      Discuss Your Project
    </Button>
  </div>
</div>
