---
import { headerNavLinks } from '../../data/navigation';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div
  id={id}
  class="fixed inset-y-0 right-0 z-40 w-full max-w-sm translate-x-full bg-slate-950 border-l border-white/10 pt-24 px-8 pb-8 transition-transform duration-300 md:hidden flex flex-col justify-between shadow-2xl"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile Navigation"
>
  <nav class="flex flex-col gap-2">
    {
      headerNavLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link font-heading text-lg font-bold text-slate-100 hover:text-blue-400 py-3.5 border-b border-white/10 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500"
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="mt-auto pt-6">
    <Button 
      href={siteConfig.links.contact} 
      variant="primary" 
      class="w-full text-center py-3.5 font-bold text-base !bg-blue-600 hover:!bg-blue-500 !text-white border-0 shadow-lg shadow-blue-600/30" 
      id="mobile-menu-cta"
    >
      Discuss Your Project
    </Button>
  </div>
</div>
