---
import { headerNavLinks } from '../../data/navigation';
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import MobileMenu from './MobileMenu.astro';
import { siteConfig } from '../../data/site';
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 w-full border-b border-white/10 bg-slate-950/80 backdrop-blur-md transition-all duration-300 shadow-lg shadow-slate-950/50"
>
  <Container class="flex h-20 items-center justify-between">
    <!-- Brand Logo -->
    <a
      href={`${siteConfig.basePath}/`}
      class="font-heading text-2xl font-extrabold tracking-tight text-white hover:opacity-90 transition-opacity focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded-md px-1 py-0.5"
      aria-label="Starts Digital Home"
    >
      Starts<span class="text-blue-500">Digital</span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main Navigation">
      {
        headerNavLinks.map((link) => (
          <a
            href={link.href}
            class="font-heading text-sm font-semibold text-slate-300 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 px-2 py-1 rounded-md"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Desktop Call to Action -->
    <div class="hidden md:block">
      <Button 
        href={siteConfig.links.contact} 
        variant="primary" 
        class="!px-5 !py-2.5 font-semibold text-sm !bg-blue-600 hover:!bg-blue-500 !text-white border-0 shadow-lg shadow-blue-600/25 transition-all hover:scale-[1.02]"
      >
        Discuss Your Project
      </Button>
    </div>

    <!-- Mobile Menu Toggle Button (44px min touch target) -->
    <button
      id="mobile-menu-toggle"
      class="relative z-50 w-11 h-11 flex items-center justify-center text-white hover:text-blue-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded-md md:hidden"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle Navigation Menu"
    >
      <span class="sr-only">Toggle navigation menu</span>
      <!-- Hamburger Icon Lines -->
      <div class="flex h-5 w-6 flex-col justify-between">
        <span class="hamburger-line h-[2px] w-full bg-current transition-all duration-300 origin-left"></span>
        <span class="hamburger-line h-[2px] w-full bg-current transition-all duration-300"></span>
        <span class="hamburger-line h-[2px] w-full bg-current transition-all duration-300 origin-left"></span>
      </div>
    </button>
  </Container>
</header>

<!-- Mobile Navigation Drawer -->
<MobileMenu id="mobile-menu" />

<!-- Overlay Backdrop for Mobile Menu -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-30 hidden bg-slate-950/80 backdrop-blur-sm transition-opacity duration-300"
  aria-hidden="true"
></div>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const lines = document.querySelectorAll('.hamburger-line');
  const navLinks = document.querySelectorAll('.mobile-nav-link');
  const body = document.body;

  let isOpen = false;

  function toggleMobileMenu(open: boolean) {
    if (!toggleBtn || !mobileMenu || !overlay) return;
    
    isOpen = open;
    toggleBtn.setAttribute('aria-expanded', String(isOpen));
    
    if (isOpen) {
      mobileMenu.classList.remove('translate-x-full');
      overlay.classList.remove('hidden');
      body.classList.add('overflow-hidden');
      
      if (lines[0] && lines[1] && lines[2]) {
        (lines[0] as HTMLElement).style.transform = 'rotate(45deg) translate(4px, 1.5px)';
        (lines[1] as HTMLElement).style.opacity = '0';
        (lines[2] as HTMLElement).style.transform = 'rotate(-45deg) translate(4px, -1.5px)';
      }
      
      setTimeout(() => {
        const firstLink = mobileMenu.querySelector('a');
        if (firstLink) firstLink.focus();
      }, 100);
    } else {
      mobileMenu.classList.add('translate-x-full');
      overlay.classList.add('hidden');
      body.classList.remove('overflow-hidden');
      
      if (lines[0] && lines[1] && lines[2]) {
        (lines[0] as HTMLElement).style.transform = 'none';
        (lines[1] as HTMLElement).style.opacity = '1';
        (lines[2] as HTMLElement).style.transform = 'none';
      }
      
      toggleBtn.focus();
    }
  }

  toggleBtn?.addEventListener('click', () => {
    toggleMobileMenu(!isOpen);
  });

  overlay?.addEventListener('click', () => {
    toggleMobileMenu(false);
  });

  navLinks.forEach((link) => {
    link.addEventListener('click', () => {
      toggleMobileMenu(false);
    });
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      toggleMobileMenu(false);
    }
  });
</script>
