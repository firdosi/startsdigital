---
import Logo from './Logo.astro';
import { site } from '../../site.config';

const links = [
  { href: `${site.basePath}/#services`, label: 'Services' },
  { href: `${site.basePath}/#work`, label: 'Featured Work' },
  { href: `${site.basePath}/#results`, label: 'Results' },
  { href: `${site.basePath}/#platforms`, label: 'Platforms' },
  { href: `${site.basePath}/#about`, label: 'Why Us' },
  { href: `${site.basePath}/#process`, label: 'Process' },
  { href: `${site.basePath}/#faq`, label: 'FAQ' },
];
---

<header
  id="main-header"
  class="sticky top-0 z-50 border-b border-white/10 bg-[#090d16]/85 backdrop-blur-md transition-all duration-200"
>
  <div class="mx-auto flex max-w-[1280px] items-center justify-between gap-8 px-6 sm:px-8 py-4">
    <Logo />
    
    <!-- Desktop Links -->
    <nav class="hidden gap-7 text-[14px] font-semibold md:flex text-slate-300">
      {links.map((link) => (
        <a href={link.href} class="hover:text-white transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right Actions -->
    <div class="flex items-center gap-4">
      <a
        href={site.contact.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-[14px] font-semibold text-slate-300 hover:text-white sm:inline"
      >
        WhatsApp
      </a>
      <a
        href={`${site.basePath}/#contact`}
        class="rounded-full bg-blue-600 px-5 py-2.5 text-[14px] font-bold text-white shadow-lg shadow-blue-600/20 hover:bg-blue-500 hover:shadow-blue-500/30 transition-all"
      >
        Discuss Your Project
      </a>

      <!-- Mobile Menu Toggle Button -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="flex size-10 items-center justify-center rounded-lg border border-white/10 bg-slate-900/60 text-slate-200 hover:border-white/20 hover:text-white md:hidden focus:outline-none"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div
    id="mobile-menu-drawer"
    class="hidden border-t border-white/10 bg-[#090d16] px-8 py-6 md:hidden"
  >
    <div class="flex flex-col gap-4 text-base font-semibold text-slate-200">
      {links.map((link) => (
        <a href={link.href} class="mobile-link hover:text-blue-400 py-1 transition-colors">
          {link.label}
        </a>
      ))}
      <a
        href={site.contact.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-link text-blue-400 font-bold py-1 flex items-center gap-2"
      >
        <span>WhatsApp Chat</span>
        <span class="text-xs font-mono text-slate-400">(+92 339 4135544)</span>
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('main-header');
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const drawer = document.getElementById('mobile-menu-drawer');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 10) {
      nav.classList.add('shadow-xl', 'shadow-black/40', 'bg-[#090d16]/95');
    } else {
      nav.classList.remove('shadow-xl', 'shadow-black/40', 'bg-[#090d16]/95');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggleBtn?.addEventListener('click', () => {
    const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
    toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
    drawer?.classList.toggle('hidden');
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      toggleBtn?.setAttribute('aria-expanded', 'false');
      drawer?.classList.add('hidden');
    });
  });
</script>
