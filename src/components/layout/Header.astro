---
import Logo from './Logo.astro';
import { site } from '../../site.config';

const links = [
  { href: `${site.basePath}/#services`, label: 'Services' },
  { href: `${site.basePath}/#work`, label: 'Work' },
  { href: `${site.basePath}/#results`, label: 'Results' },
  { href: `${site.basePath}/#about`, label: 'About' },
  { href: `${site.basePath}/#faq`, label: 'FAQ' },
  { href: `${site.basePath}/#contact`, label: 'Contact' },
];
---

<nav
  id="main-header"
  class="sticky top-0 z-50 border-b-[3px] border-orange bg-ink/96 backdrop-blur-xl transition-shadow duration-250"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between gap-8 px-6 sm:px-8 py-4">
    <Logo />
    
    <!-- Desktop Links -->
    <div class="hidden gap-7 text-[15px] font-semibold md:flex">
      {links.map((link) => (
        <a href={link.href} class="text-sky hover:text-orange transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-3.5">
      <a
        href={site.contact.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden text-[15px] font-semibold text-cloud hover:text-orange sm:inline"
      >
        WhatsApp
      </a>
      <a
        href={`${site.basePath}/#contact`}
        class="rounded-full bg-orange px-5 py-2.5 text-[15px] font-bold text-cloud shadow-[3px_3px_0_var(--color-cloud)] transition-[transform,box-shadow] hover:-translate-x-px hover:-translate-y-px hover:shadow-[4px_4px_0_var(--color-cloud)]"
      >
        Discuss Your Project
      </a>

      <!-- Mobile Menu Toggle Button -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="flex size-10 items-center justify-center rounded-lg border-2 border-cloud/20 text-cloud hover:border-orange hover:text-orange md:hidden focus:outline-none"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div
    id="mobile-menu-drawer"
    class="hidden border-t border-white/10 bg-ink px-8 py-6 md:hidden"
  >
    <div class="flex flex-col gap-4 text-base font-semibold">
      {links.map((link) => (
        <a href={link.href} class="mobile-link text-sky hover:text-orange py-1">
          {link.label}
        </a>
      ))}
      <a
        href={site.contact.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="mobile-link text-orange font-bold py-1"
      >
        WhatsApp Chat (+92 339 4135544)
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-header');
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const drawer = document.getElementById('mobile-menu-drawer');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  const onScroll = () => {
    if (!nav) return;
    nav.style.boxShadow = window.scrollY > 8 ? '0 6px 20px rgb(15 30 66 / 0.25)' : 'none';
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggleBtn?.addEventListener('click', () => {
    const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
    toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
    drawer?.classList.toggle('hidden');
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      toggleBtn?.setAttribute('aria-expanded', 'false');
      drawer?.classList.add('hidden');
    });
  });
</script>
