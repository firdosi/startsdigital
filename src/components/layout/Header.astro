---
import Logo from './Logo.astro';
import { site } from '../../site.config';

const links = [
  { href: `${site.basePath}/`, label: 'Home' },
  { href: `${site.basePath}/services/`, label: 'Services' },
  { href: `${site.basePath}/work/`, label: 'Work' },
  { href: `${site.basePath}/about/`, label: 'About' },
  { href: `${site.basePath}/#faq`, label: 'FAQ' },
  { href: `${site.basePath}/contact/`, label: 'Contact' },
];
---

<header
  id="main-header"
  class="relative z-50 bg-[#061d33] text-white border-b border-white/10 transition-all duration-200 font-body"
>
  <div class="mx-auto flex max-w-[1280px] items-center justify-between gap-6 px-6 sm:px-8 py-5">
    <Logo />
    
    <!-- Desktop Navigation Links: Inter 500 15px -->
    <nav class="hidden gap-8 text-[15px] font-medium md:flex text-slate-200 font-body">
      {links.map((link) => (
        <a href={link.href} class="hover:text-[#ff762b] transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right Actions: Inter 600 button -->
    <div class="flex items-center gap-4 font-body">
      <a
        href={`${site.basePath}/contact/`}
        class="hidden sm:inline-flex items-center justify-center rounded-full bg-white px-6 py-2.5 text-[15px] font-semibold text-[#061d33] shadow-md hover:bg-[#ddff35] hover:text-[#061d33] transition-all transform hover:-translate-y-0.5"
      >
        Discuss your project
      </a>

      <!-- Mobile Menu Toggle Button -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="flex size-10 items-center justify-center rounded-full border border-white/20 bg-white/10 text-white hover:bg-white/20 md:hidden focus:outline-none"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Navigation -->
  <div
    id="mobile-menu-drawer"
    class="hidden border-t border-white/10 bg-[#061d33] px-8 py-6 md:hidden font-body"
  >
    <div class="flex flex-col gap-4 text-base font-semibold text-white">
      {links.map((link) => (
        <a href={link.href} class="mobile-link hover:text-[#ff762b] py-1 transition-colors">
          {link.label}
        </a>
      ))}
      <a
        href={`${site.basePath}/contact/`}
        class="mobile-link mt-2 rounded-full bg-[#ff762b] px-6 py-3 text-center text-[15px] font-semibold text-white shadow-md hover:bg-[#e56017] transition-all"
      >
        Discuss your project
      </a>
    </div>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const drawer = document.getElementById('mobile-menu-drawer');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  toggleBtn?.addEventListener('click', () => {
    const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
    toggleBtn.setAttribute('aria-expanded', String(!isExpanded));
    drawer?.classList.toggle('hidden');
  });

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      toggleBtn?.setAttribute('aria-expanded', 'false');
      drawer?.classList.add('hidden');
    });
  });
</script>
