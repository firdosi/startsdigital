---
import Container from '../ui/Container.astro';
import { footerNavLinks } from '../../data/navigation';
import { siteConfig } from '../../data/site';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-brand-light-border/10 bg-brand-navy py-16 md:py-20 text-brand-white">
  <Container class="grid grid-cols-1 md:grid-cols-12 gap-12">
    <!-- Left Column: Brandmark & Tagline -->
    <div class="md:col-span-5 space-y-4">
      <span class="font-heading text-2xl font-extrabold tracking-tight text-brand-white">
        Starts<span class="text-brand-blue">Digital</span>
      </span>
      <p class="font-body text-base font-normal leading-relaxed text-brand-muted-dark max-w-sm">
        Starts Digital helps businesses grow through performance marketing, custom websites, technical SEO, creative content and practical AI digital systems.
      </p>
      <div class="pt-2 text-sm text-brand-muted-dark space-y-1">
        <p><strong>Email:</strong> <a href={`mailto:${siteConfig.contact.email}`} class="hover:text-brand-white transition-colors">{siteConfig.contact.email}</a></p>
        <p><strong>WhatsApp:</strong> <a href={siteConfig.contact.whatsappUrl} target="_blank" rel="noopener noreferrer" class="hover:text-brand-white transition-colors">{siteConfig.contact.phone}</a></p>
      </div>
    </div>

    <!-- Middle Column: Services -->
    <div class="md:col-span-3 space-y-4">
      <span class="font-heading text-xs font-bold tracking-widest text-brand-teal uppercase">
        Services
      </span>
      <nav class="flex flex-col gap-2.5" aria-label="Footer Services Navigation">
        <a href={`${siteConfig.basePath}/#services`} class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors">Performance Marketing</a>
        <a href={`${siteConfig.basePath}/#services`} class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors">Website Development</a>
        <a href={`${siteConfig.basePath}/#services`} class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors">SEO & Organic Growth</a>
        <a href={`${siteConfig.basePath}/#services`} class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors">Creative Content & Video</a>
        <a href={`${siteConfig.basePath}/#services`} class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors">AI & Automation</a>
      </nav>
    </div>

    <!-- Right Column: Navigation Links -->
    <div class="md:col-span-4 space-y-4">
      <span class="font-heading text-xs font-bold tracking-widest text-brand-teal uppercase">
        Company
      </span>
      <nav class="flex flex-col gap-2.5" aria-label="Footer Navigation">
        {
          footerNavLinks.map((link) => (
            <a
              href={link.href}
              class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors"
            >
              {link.label}
            </a>
          ))
        }
        <a href={`${siteConfig.basePath}/#faq`} class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors">FAQ</a>
        <a href={`${siteConfig.basePath}/#contact`} class="font-body text-sm font-normal text-brand-muted-dark hover:text-brand-white transition-colors">Contact Us</a>
      </nav>
    </div>
  </Container>

  <!-- Copyright Area -->
  <Container class="mt-16 border-t border-brand-light-border/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-brand-muted-dark">
    <p>
      &copy; {currentYear} Starts Digital. All rights reserved.
    </p>
    <p>
      Digital Strategy &middot; Marketing &middot; Development &middot; Technology
    </p>
  </Container>
</footer>
