---
import Logo from './Logo.astro';
import { site } from '../../site.config';

const columns = [
  {
    heading: 'Services',
    links: [
      { href: `${site.basePath}/services/`, label: 'All services and capabilities' },
      { href: `${site.basePath}/services/`, label: 'Paid advertising and leads' },
      { href: `${site.basePath}/services/`, label: 'Website design and e-commerce' },
      { href: `${site.basePath}/services/`, label: 'SEO and local search' },
      { href: `${site.basePath}/services/`, label: 'Creative content' },
      { href: `${site.basePath}/services/`, label: 'AI marketing systems' },
    ],
  },
  {
    heading: 'Featured work',
    links: [
      { href: `${site.basePath}/work/black-gold-fertilizer/`, label: 'Black Gold Fertilizer' },
      { href: `${site.basePath}/work/qurbani-campaign/`, label: 'Wajib Livestock Qurbani' },
      { href: `${site.basePath}/work/rk-reno-solutions/`, label: 'RK Reno Solutions' },
      { href: `${site.basePath}/work/`, label: 'All case studies' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { href: `${site.basePath}/about/`, label: 'About Starts Digital' },
      { href: `${site.basePath}/#results`, label: 'Verified results' },
      { href: `${site.basePath}/services/`, label: 'Working method' },
      { href: `${site.basePath}/#faq`, label: 'FAQ' },
      { href: `${site.basePath}/contact/`, label: 'Discuss your project' },
    ],
  },
];
---

<footer class="bg-[#061d33] border-t border-white/10 text-slate-300 font-body relative overflow-hidden">
  <!-- Top Divider Highlight Sweep -->
  <div data-motion="clip-left" class="h-0.5 w-full bg-gradient-to-r from-[#ff762b] via-[#9a83f5] to-[#ddff35]"></div>

  <div class="mx-auto max-w-[1280px] px-6 sm:px-8 pt-16 pb-12">
    <div class="grid gap-10 md:grid-cols-12">
      
      <!-- Left Column: Agency Overview & Direct Contact -->
      <div data-motion="fade-up" data-motion-delay="0" class="md:col-span-5 space-y-6">
        <Logo />
        <p class="max-w-[380px] text-[15px] sm:text-[16px] leading-[1.65] text-slate-300 font-body font-normal">
          Starts Digital helps businesses grow through paid advertising, websites, SEO, creative content and practical AI-powered marketing systems.
        </p>
        
        <div class="pt-2 text-[15px] sm:text-[16px] space-y-2.5 font-body text-slate-300 font-normal">
          <div class="flex items-center gap-2">
            <span class="text-slate-400">Email:</span>
            <a href={`mailto:${site.contact.email}`} data-track="contact-email" class="text-[#ddff35] underline hover:text-white transition-colors font-medium">
              {site.contact.email}
            </a>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-slate-400">WhatsApp:</span>
            <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" data-track="contact-whatsapp" class="text-[#39c98a] underline hover:text-white transition-colors font-medium">
              {site.contact.phone}
            </a>
          </div>
        </div>
      </div>

      <!-- Right Columns: Navigation Links with Staggered Entrances -->
      <div class="md:col-span-7 grid grid-cols-1 sm:grid-cols-3 gap-8">
        {
          columns.map((col, idx) => (
            <div data-motion="fade-up" data-motion-delay={100 + idx * 80}>
              <!-- Column title: Sora 600 -->
              <h3 class="mb-4 font-heading font-semibold text-[17px] text-white">
                {col.heading}
              </h3>
              <!-- Links: Inter 400, min 15px -->
              <ul class="space-y-3 text-[15px] sm:text-[16px] font-body font-normal">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-slate-300 hover:text-[#ff762b] hover:underline transition-colors">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

    </div>

    <!-- Bottom Copyright & Legal Links Divider -->
    <div data-motion="fade-up" data-motion-delay="350" class="mt-16 pt-8 border-t border-white/10 flex flex-wrap items-center justify-between gap-4 text-[14px] sm:text-[15px] text-slate-400 font-body font-normal">
      <div>
        © {new Date().getFullYear()} Starts Digital. All rights reserved.
      </div>
      <div class="flex flex-wrap items-center gap-6 text-[14px] sm:text-[15px] font-body">
        <a href={`${site.basePath}/legal/`} class="hover:text-white transition-colors">Legal Notice</a>
        <a href={`${site.basePath}/privacy/`} class="hover:text-white transition-colors">Privacy Policy</a>
        <a href={`${site.basePath}/terms/`} class="hover:text-white transition-colors">Terms of Use</a>
        <a href={`${site.basePath}/contact/`} class="hover:text-white transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
