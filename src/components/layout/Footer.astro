---
import Logo from './Logo.astro';
import { site } from '../../site.config';

const columns = [
  {
    heading: 'Capabilities',
    links: [
      { href: `${site.basePath}/#services`, label: 'Paid Advertising & Leads' },
      { href: `${site.basePath}/#services`, label: 'Website Design & E-Commerce' },
      { href: `${site.basePath}/#services`, label: 'SEO & Local Search' },
      { href: `${site.basePath}/#services`, label: 'Creative Content' },
      { href: `${site.basePath}/#services`, label: 'AI Marketing Systems' },
      { href: `${site.basePath}/#services`, label: 'Campaign Strategy' },
    ],
  },
  {
    heading: 'Featured Work',
    links: [
      { href: `${site.basePath}/work/black-gold-fertilizer/`, label: 'Black Gold Fertilizer' },
      { href: `${site.basePath}/work/qurbani-campaign/`, label: 'Wajib Livestock Qurbani' },
      { href: `${site.basePath}/work/rk-reno-solutions/`, label: 'RK Reno Solutions' },
      { href: `${site.basePath}/work/`, label: 'All Case Studies' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { href: `${site.basePath}/#about`, label: 'Why Starts Digital' },
      { href: `${site.basePath}/#results`, label: 'Verified Results' },
      { href: `${site.basePath}/#process`, label: 'Working Process' },
      { href: `${site.basePath}/#faq`, label: 'FAQ' },
      { href: `${site.basePath}/#contact`, label: 'Contact Us' },
    ],
  },
];
---

<footer class="bg-[#07090e] border-t border-white/10 text-slate-400">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8 pt-16 pb-12">
    <div class="grid gap-10 md:grid-cols-12">
      <!-- Left Column: Agency Overview & Direct Contact -->
      <div class="md:col-span-5 space-y-5">
        <Logo size="md" />
        <p class="max-w-[360px] text-base leading-relaxed text-slate-400">
          Starts Digital helps businesses grow through paid advertising, websites, SEO, creative content and practical AI-powered marketing systems.
        </p>
        
        <div class="pt-2 text-sm space-y-2 font-mono text-slate-300">
          <div class="flex items-center gap-2">
            <span class="text-slate-500">Email:</span>
            <a href={`mailto:${site.contact.email}`} class="text-slate-200 hover:text-blue-400 transition-colors">
              {site.contact.email}
            </a>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-slate-500">WhatsApp:</span>
            <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="text-slate-200 hover:text-blue-400 transition-colors">
              {site.contact.phone}
            </a>
          </div>
        </div>
      </div>

      <!-- Right Columns: Links -->
      <div class="md:col-span-7 grid grid-cols-1 sm:grid-cols-3 gap-8">
        {
          columns.map((col) => (
            <div>
              <h4 class="mb-4 font-display text-sm font-bold uppercase tracking-wider text-white">
                {col.heading}
              </h4>
              <ul class="space-y-2.5 text-sm">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-slate-400 hover:text-white transition-colors">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Bottom Copyright Divider -->
    <div class="mt-14 pt-8 border-t border-white/10 flex flex-wrap items-center justify-between gap-4 text-sm text-slate-500">
      <div>
        © {new Date().getFullYear()} Starts Digital. All rights reserved.
      </div>
      <div class="flex gap-6">
        <a href={`${site.basePath}/#contact`} class="hover:text-slate-300 transition-colors">Contact</a>
        <a href={`${site.basePath}/work/`} class="hover:text-slate-300 transition-colors">Case Studies</a>
      </div>
    </div>
  </div>
</footer>
