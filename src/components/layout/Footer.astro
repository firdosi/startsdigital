---
import Logo from './Logo.astro';
import { site } from '../../site.config';

const columns = [
  {
    heading: 'Services',
    links: [
      { href: `${site.basePath}/#services`, label: 'Paid Advertising' },
      { href: `${site.basePath}/#services`, label: 'Websites & E-Commerce' },
      { href: `${site.basePath}/#services`, label: 'SEO & Local Search' },
      { href: `${site.basePath}/#services`, label: 'Creative Content' },
      { href: `${site.basePath}/#services`, label: 'AI Marketing Systems' },
      { href: `${site.basePath}/#services`, label: 'Campaign Strategy' },
    ],
  },
  {
    heading: 'Featured Work',
    links: [
      { href: `${site.basePath}/work/black-gold-fertilizer/`, label: 'Black Gold Fertilizer' },
      { href: `${site.basePath}/work/qurbani-campaign/`, label: 'Wajib Livestock' },
      { href: `${site.basePath}/work/rk-reno-solutions/`, label: 'RK Reno Solutions' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { href: `${site.basePath}/#about`, label: 'About Us' },
      { href: `${site.basePath}/#results`, label: 'Verified Results' },
      { href: `${site.basePath}/#faq`, label: 'FAQ' },
      { href: `${site.basePath}/#contact`, label: 'Contact Us' },
    ],
  },
];
---

<footer class="bg-ink text-sky-mist">
  <div
    class="mx-auto grid max-w-[1200px] gap-10 px-6 sm:px-8 pt-16 pb-12 md:grid-cols-[1.4fr_1fr_1fr_1fr]"
  >
    <div>
      <Logo size="sm" />
      <p class="mt-4 max-w-[320px] text-[15px] leading-7 text-slate-300">
        {site.description}
      </p>
      <div class="mt-5 space-y-2 text-sm font-mono text-slate-300">
        <div>Email: <a href={`mailto:${site.contact.email}`} class="text-sky hover:text-orange">{site.contact.email}</a></div>
        <div>Phone: <a href={site.contact.whatsapp} class="text-sky hover:text-orange">{site.contact.phone}</a></div>
      </div>
    </div>
    {
      columns.map((col) => (
        <div>
          <div class="mb-4 font-display text-[15px] font-bold text-cloud uppercase tracking-wider">{col.heading}</div>
          <div class="flex flex-col gap-3 text-[15px] leading-6">
            {col.links.map((link) => (
              <a href={link.href} class="text-sky-mist hover:text-orange transition-colors">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
  <div class="border-t border-white/10">
    <div
      class="mx-auto flex max-w-[1200px] flex-wrap justify-between gap-3 px-6 sm:px-8 py-6 text-sm text-slate-400"
    >
      <span>© {new Date().getFullYear()} Starts Digital. All rights reserved.</span>
      <span>Built with Astro ✦ Kepler Theme (MIT License)</span>
    </div>
  </div>
</footer>
