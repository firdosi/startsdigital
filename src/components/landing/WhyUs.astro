---
import { 
  Layers, 
  Globe2, 
  Cpu, 
  ShieldCheck, 
  Quote,
  Sparkles
} from '@lucide/astro';

const proofPoints = [
  {
    num: '01',
    title: 'Strategy and execution managed together',
    body: 'Single-point ownership. We engineer ad campaigns, website checkout, and landing pages in unison without blame-shifting between teams.',
    Icon: Layers,
  },
  {
    num: '02',
    title: 'Multi-industry campaign experience',
    body: 'Proven execution across e-commerce brands, agricultural suppliers, seasonal livestock retail, and local service contractors in Pakistan, Malaysia, and the Gulf.',
    Icon: Globe2,
  },
  {
    num: '03',
    title: 'Marketing and technical capabilities',
    body: 'Custom lightweight web architecture, technical SEO schema, and conversion architecture combined with performance media buying.',
    Icon: Cpu,
  },
  {
    num: '04',
    title: 'Direct communication & transparency',
    body: 'Work directly with senior strategists and founders. No junior account managers, fake dashboards, or hidden data layers.',
    Icon: ShieldCheck,
  },
];
---

<section id="about" class="relative py-24 bg-[#090d16] text-white border-b border-white/10 overflow-hidden">
  <!-- Subtle Radial Glow Background -->
  <div class="pointer-events-none absolute bottom-0 right-0 size-[500px] rounded-full bg-blue-600/10 blur-[130px]"></div>

  <div class="relative mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <div class="grid gap-12 lg:grid-cols-12 items-start">
      
      <!-- Left Side: Large Editorial Statement & Founder Perspective Card -->
      <div class="lg:col-span-5 space-y-8">
        
        <div>
          <span class="inline-flex items-center gap-2 text-xs font-bold font-mono uppercase tracking-widest text-blue-400 mb-3">
            <Sparkles class="size-3.5 text-blue-400" />
            <span>EDITORIAL CREDIBILITY</span>
          </span>
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white leading-tight">
            Why Starts Digital
          </h2>
          <p class="mt-4 text-xl font-display font-semibold text-blue-400 leading-snug">
            We replace fragmented freelancer teams with a cohesive growth architecture.
          </p>
        </div>

        <p class="text-base text-slate-300 font-body leading-relaxed">
          Most marketing failures happen in the gaps between the ad creator, the developer, and the business operator. Starts Digital closes those gaps by taking single-point responsibility for campaign strategy, technical web infrastructure, and conversion optimization.
        </p>

        <!-- Founder / Operator Perspective Glass Card -->
        <div class="rounded-2xl border border-white/15 bg-slate-900/90 p-7 shadow-xl backdrop-blur-xl space-y-4">
          <div class="flex items-center gap-3 text-blue-400">
            <Quote class="size-6 text-blue-400" />
            <span class="text-xs font-mono font-bold uppercase tracking-wider text-slate-300">OPERATOR PERSPECTIVE</span>
          </div>
          <p class="text-sm sm:text-base text-slate-200 font-body leading-relaxed italic">
            "We don’t treat ad campaigns as isolated experiments. Every ad dollar spent is connected directly to your landing page speed, offer positioning, and actual sales volume."
          </p>
          <div class="pt-2 border-t border-white/10 flex items-center justify-between text-xs font-mono text-slate-400">
            <span>Direct Founder Oversight</span>
            <span class="text-blue-400 font-bold">100% Account Ownership</span>
          </div>
        </div>

      </div>

      <!-- Right Side: 4 Numbered Editorial Proof Points -->
      <div class="lg:col-span-7 space-y-6">
        {
          proofPoints.map((point, idx) => (
            <div
              class="reveal-on-scroll rounded-2xl border border-white/10 bg-slate-900/60 p-7 backdrop-blur-md hover:border-blue-500/40 hover:bg-slate-900/90 transition-all duration-200 group"
              data-reveal-delay={idx * 80}
            >
              <div class="flex items-start gap-5">
                <div class="size-11 shrink-0 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center text-blue-400 font-mono font-bold text-sm group-hover:scale-105 transition-transform">
                  {point.num}
                </div>
                <div class="space-y-2">
                  <h3 class="font-display text-xl font-bold text-white group-hover:text-blue-400 transition-colors">
                    {point.title}
                  </h3>
                  <p class="text-sm sm:text-base text-slate-300 font-body leading-relaxed">
                    {point.body}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

    </div>

  </div>
</section>
