---
import { site } from '../../site.config';
import { 
  Layers, 
  Globe2, 
  Cpu, 
  ShieldCheck, 
  TrendingUp, 
  ShoppingBag, 
  Award, 
  HeartHandshake 
} from '@lucide/astro';

const trustPillars = [
  {
    num: '01',
    title: 'Strategy & Execution Managed Together',
    body: 'Single-point ownership. We engineer ad campaigns, website checkout, and landing pages in unison without blame-shifting between teams.',
    Icon: Layers,
    accentColor: 'border-[#ff762b] text-[#ff762b]',
  },
  {
    num: '02',
    title: 'Multi-Industry Campaign Experience',
    body: 'Proven execution across e-commerce brands, agricultural suppliers, seasonal livestock retail, and local service contractors in Pakistan, Malaysia, and the Gulf.',
    Icon: Globe2,
    accentColor: 'border-[#9a83f5] text-[#9a83f5]',
  },
  {
    num: '03',
    title: 'Marketing & Technical Integration',
    body: 'Custom web architecture, technical SEO schema, and conversion architecture combined with performance media buying.',
    Icon: Cpu,
    accentColor: 'border-[#39c98a] text-[#39c98a]',
  },
  {
    num: '04',
    title: 'Direct Transparency & Account Ownership',
    body: 'Work directly with senior strategists and founders. No junior account managers, fake dashboards, or hidden data layers.',
    Icon: ShieldCheck,
    accentColor: 'border-[#ff514b] text-[#ff514b]',
  },
];
---

<section id="about" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10 overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Top Header Row: Heading Left, Paragraph Right -->
    <div class="grid gap-8 lg:grid-cols-12 items-end mb-16">
      <div class="lg:col-span-7 space-y-3">
        <span class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
          EDITORIAL CREDIBILITY
        </span>
        <h2 class="font-heading font-bold text-[28px] sm:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.12] tracking-[-0.025em]">
          Why brands trust Starts Digital
        </h2>
      </div>
      <div class="lg:col-span-5">
        <p class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal">
          Most marketing failures happen in the gaps between the ad creator, the developer, and the business operator. Starts Digital closes those gaps by taking single-point responsibility for campaign strategy, technical web infrastructure, and conversion optimization.
        </p>
      </div>
    </div>

    <!-- Central Real Visual Showcase with Floating Verified Metric Badges -->
    <div class="relative max-w-4xl mx-auto my-16">
      
      <!-- Main Center Visual Card -->
      <div class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-3.5 shadow-2xl relative z-10 overflow-hidden">
        <img
          src={`${site.basePath}/brands/rk-reno-solutions/screenshot.png`}
          alt="RK Reno Solutions Genuine Website Screenshot"
          width="900"
          height="500"
          loading="lazy"
          class="w-full h-[320px] sm:h-[420px] rounded-2xl object-cover"
        />
        <!-- External HTML Caption: Inter 600, 16px minimum -->
        <div class="p-4 bg-[#061d33] text-white rounded-xl mt-3 flex items-center justify-between font-body">
          <span class="text-base font-semibold text-[#ddff35]">RK Reno Solutions website and local SEO project</span>
          <span class="text-sm font-mono font-medium text-slate-300">E-Commerce & Local Services</span>
        </div>
      </div>

      <!-- Floating Verified Metric Badge 1 (Top Left) -->
      <div class="hidden sm:flex absolute -top-8 -left-6 z-20 items-center gap-3 rounded-2xl border-2 border-[#ff762b] bg-white p-4 shadow-xl text-[#061d33] animate-float font-body">
        <div class="size-10 rounded-xl bg-[#ff762b] text-white flex items-center justify-center font-bold">
          <TrendingUp class="size-5" />
        </div>
        <div>
          <div class="font-heading font-bold text-xl text-[#061d33]">PKR 30M+</div>
          <div class="text-[15px] font-semibold text-slate-700">Revenue Supported</div>
        </div>
      </div>

      <!-- Floating Verified Metric Badge 2 (Top Right) -->
      <div class="hidden sm:flex absolute -top-8 -right-6 z-20 items-center gap-3 rounded-2xl border-2 border-[#9a83f5] bg-white p-4 shadow-xl text-[#061d33] animate-float font-body" style="animation-delay: 1.2s;">
        <div class="size-10 rounded-xl bg-[#9a83f5] text-white flex items-center justify-center font-bold">
          <ShoppingBag class="size-5" />
        </div>
        <div>
          <div class="font-heading font-bold text-xl text-[#061d33]">29,000+</div>
          <div class="text-[15px] font-semibold text-slate-700">Product Sales</div>
        </div>
      </div>

      <!-- Floating Verified Metric Badge 3 (Bottom Left) -->
      <div class="hidden sm:flex absolute -bottom-8 -left-6 z-20 items-center gap-3 rounded-2xl border-2 border-[#ddff35] bg-[#061d33] p-4 shadow-xl text-white animate-float font-body" style="animation-delay: 2s;">
        <div class="size-10 rounded-xl bg-[#ddff35] text-[#061d33] flex items-center justify-center font-bold">
          <Award class="size-5" />
        </div>
        <div>
          <div class="font-heading font-bold text-xl text-[#ddff35]">PKR 4.2M+</div>
          <div class="text-[15px] font-semibold text-slate-200">Sales Supported</div>
        </div>
      </div>

      <!-- Floating Verified Metric Badge 4 (Bottom Right) -->
      <div class="hidden sm:flex absolute -bottom-8 -right-6 z-20 items-center gap-3 rounded-2xl border-2 border-[#ff514b] bg-white p-4 shadow-xl text-[#061d33] animate-float font-body" style="animation-delay: 2.8s;">
        <div class="size-10 rounded-xl bg-[#ff514b] text-white flex items-center justify-center font-bold">
          <HeartHandshake class="size-5" />
        </div>
        <div>
          <div class="font-heading font-bold text-xl text-[#061d33]">More Than 150</div>
          <div class="text-[15px] font-semibold text-slate-700">Animals Sold</div>
        </div>
      </div>

    </div>

    <!-- 4 Key Trust Pillars Cards -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 mt-20">
      {
        trustPillars.map((point, idx) => (
          <div
            class="reveal-on-scroll rounded-3xl border border-slate-200 bg-white p-7 shadow-md hover:shadow-xl transition-all duration-300 flex flex-col justify-between group"
            data-reveal-delay={idx * 80}
          >
            <div>
              <div class="flex items-center justify-between mb-6">
                <span class="font-mono text-xl font-medium text-[#061d33]/40 group-hover:text-[#ff762b] transition-colors">
                  {point.num}
                </span>
                <div class:list={['size-11 rounded-2xl border-2 flex items-center justify-center font-bold', point.accentColor]}>
                  <point.Icon class="size-5" />
                </div>
              </div>

              <!-- Card Title: Sora 600 -->
              <h3 class="font-heading font-semibold text-lg sm:text-xl text-[#061d33] mb-3 leading-[1.25]">
                {point.title}
              </h3>
              
              <!-- Body: Inter 400, leading 1.65 -->
              <p class="text-base text-slate-700 font-body leading-[1.65] font-normal">
                {point.body}
              </p>
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>
