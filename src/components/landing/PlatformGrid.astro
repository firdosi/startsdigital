---
import { platforms } from '../../data/platforms';
import SectionHeader from './SectionHeader.astro';
---

<section id="platforms" class="py-20 bg-linear-160 from-navy to-navy-deep text-cloud border-b-4 border-ink relative overflow-hidden">
  <!-- Kepler Orbit Decorative Stars (Task 10) -->
  <span class="absolute top-10 right-[6%] text-[30px] text-orange pointer-events-none" aria-hidden="true">✦</span>
  <span class="absolute bottom-12 left-[5%] size-4 rotate-[15deg] rounded-md bg-orange pointer-events-none" aria-hidden="true"></span>

  <div class="mx-auto max-w-[1200px] px-6 sm:px-8">
    <SectionHeader
      eyebrow="Tech Stack & Ecosystem"
      title="Platforms & Tools We Work With"
      sub="Engineered integration across advertising networks, analytics engines, CMS platforms, and customer channels."
      on="navy"
      class="max-w-[680px] mb-14"
    />

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
      {
        platforms.map((p, idx) => (
          <div
            class="reveal-on-scroll rounded-tile border-2 border-ink bg-cloud p-5 shadow-pop hover:shadow-pop-lg transition-[transform,box-shadow] hover:-translate-y-1 flex flex-col items-center justify-center text-center group"
            data-reveal-delay={idx * 50}
          >
            <div class="size-12 mb-3 flex items-center justify-center">
              <img
                src={p.logo}
                alt={`${p.name} logo`}
                width="48"
                height="48"
                loading="lazy"
                class="max-size-10 object-contain group-hover:scale-110 transition-transform duration-200"
              />
            </div>
            <h3 class="font-display font-bold text-sm text-navy group-hover:text-orange transition-colors">
              {p.name}
            </h3>
            <span class="mt-1 font-mono text-[11px] text-slate-500">
              {p.category}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
