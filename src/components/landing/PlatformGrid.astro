---
import { platforms } from '../../data/platforms';
import { site } from '../../site.config';

const logoSrc = (logo: string) => logo.startsWith('http') ? logo : `${site.basePath}${logo}`;
---

<section id="platforms" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 text-center mx-auto">
      <span class="text-xs font-bold font-mono uppercase tracking-widest text-[#ff762b] mb-3 block">
        TECH STACK & ECOSYSTEM
      </span>
      <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl font-black tracking-tight text-[#061d33] uppercase leading-tight">
        PLATFORMS & TOOLS WE WORK WITH
      </h2>
      <p class="mt-4 text-base sm:text-xl text-slate-700 font-body">
        Engineered integration across advertising networks, analytics engines, CMS platforms, and customer channels.
      </p>
    </div>

    <!-- Clean Cream Minimal Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
      {
        platforms.map((p, idx) => (
          <div
            class="reveal-on-scroll rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-lg hover:border-[#ff762b] transition-all duration-300 flex flex-col items-center justify-center text-center group"
            data-reveal-delay={idx * 40}
          >
            <div class="size-14 mb-3 flex items-center justify-center bg-[#f7f4ed] rounded-xl p-2 group-hover:scale-105 transition-transform">
              <img
                src={logoSrc(p.logo)}
                alt={`${p.name} logo`}
                width="48"
                height="48"
                loading="lazy"
                class="max-h-9 max-w-9 object-contain"
              />
            </div>
            <h3 class="font-display font-bold text-base text-[#061d33] group-hover:text-[#ff762b] transition-colors uppercase">
              {p.name}
            </h3>
            <span class="mt-1 font-mono text-xs text-slate-500 font-medium">
              {p.category}
            </span>
          </div>
        ))
      }
    </div>

  </div>
</section>
