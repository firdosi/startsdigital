---
import { platforms } from '../../data/platforms';
import { site } from '../../site.config';

const logoSrc = (logo: string) => logo.startsWith('http') ? logo : `${site.basePath}${logo}`;
---

<section id="platforms" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 text-center mx-auto space-y-3">
      <span data-motion="scale-in" class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
        TECH STACK & ECOSYSTEM
      </span>
      <h2 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
        Platforms and tools we work with
      </h2>
      <p data-motion="fade-up" data-motion-delay="200" class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal max-w-2xl mx-auto">
        Engineered integration across advertising networks, analytics engines, CMS platforms, and customer channels.
      </p>
    </div>

    <!-- Clean Cream Minimal Grid with Staggered Row Entrances -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6">
      {
        platforms.map((p, idx) => (
          <div
            data-motion="scale-in"
            data-motion-delay={(idx % 6) * 60 + Math.floor(idx / 6) * 100}
            class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-xl hover:border-[#ff762b] hover:-translate-y-1 transition-all duration-300 flex flex-col items-center justify-center text-center group"
          >
            <div class="size-14 mb-3 flex items-center justify-center bg-[#f7f4ed] rounded-xl p-2 group-hover:scale-110 group-hover:-translate-y-0.5 transition-transform duration-300">
              <img
                src={logoSrc(p.logo)}
                alt={`${p.name} logo`}
                width="48"
                height="48"
                loading="lazy"
                class="max-h-9 max-w-9 object-contain"
              />
            </div>
            <!-- Title: Inter 600 16px -->
            <h3 class="font-body font-semibold text-base text-[#061d33] group-hover:text-[#ff762b] transition-colors">
              {p.name}
            </h3>
            <!-- Category Tag: JetBrains Mono 500 -->
            <span class="mt-1 font-mono text-[12px] text-slate-500 font-medium">
              {p.category}
            </span>
          </div>
        ))
      }
    </div>

  </div>
</section>
