---
import { brands } from '../../data/brands';
import { site } from '../../site.config';

// Verified logo brands vs Unverified typography brands
const verifiedBrands = brands.filter((b) => b.logoApproved && b.logo);
const unverifiedBrands = brands.filter((b) => !b.logoApproved || !b.logo);
---

<section id="brands" class="py-20 bg-[#f7f4ed] text-[#061d33] overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8 mb-12 text-center space-y-3">
    <span class="text-xs font-bold font-mono uppercase tracking-widest text-[#ff762b] block">
      TRUSTED ACROSS INDUSTRIES
    </span>
    <h2 class="font-body font-bold text-3xl sm:text-4xl lg:text-5xl text-[#061d33] leading-tight">
      Clients, brands & business partners
    </h2>
    <p class="text-base sm:text-lg text-slate-700 max-w-2xl mx-auto font-body leading-[1.6] font-normal">
      Proven execution delivered across growth-stage e-commerce, agriculture, regional services, and international consultation.
    </p>
  </div>

  <!-- Row 1: Verified Brand Logos Marquee -->
  <div class="marquee-container overflow-hidden py-6 bg-white border-y border-[#061d33]/10">
    <div class="animate-marquee-left flex items-center gap-8 px-4">
      {
        [...verifiedBrands, ...verifiedBrands, ...verifiedBrands, ...verifiedBrands].map((b) => (
          <div class="h-24 w-[240px] shrink-0 rounded-2xl border border-slate-200 bg-[#f7f4ed]/50 px-6 py-4 flex items-center justify-center hover:border-[#ff762b] hover:bg-white transition-all shadow-sm group">
            <img
              src={`${site.basePath}${b.logo}`}
              alt={`${b.name} logo`}
              width="200"
              height="60"
              loading="lazy"
              class="max-h-[56px] w-auto object-contain filter grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-200"
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Row 2: Unverified Brands Typography Strip -->
  <div class="marquee-container overflow-hidden py-4 bg-[#efece4] border-b border-[#061d33]/10">
    <div class="animate-marquee-right flex items-center gap-6 px-4">
      {
        [...unverifiedBrands, ...unverifiedBrands, ...unverifiedBrands].map((b) => (
          <div class="h-14 shrink-0 rounded-xl border border-slate-300 bg-white px-6 py-2.5 flex items-center justify-center shadow-xs hover:border-[#ff762b] transition-colors">
            <!-- Brand name in Manrope 600 -->
            <span class="font-body font-semibold text-base text-[#061d33] tracking-wide whitespace-nowrap">
              {b.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>