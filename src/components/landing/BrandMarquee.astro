---
import { brands } from '../../data/brands';
import { site } from '../../site.config';

// Verified logo brands vs Unverified typography brands
const verifiedBrands = brands.filter((b) => b.logoApproved && b.logo);
const unverifiedBrands = brands.filter((b) => !b.logoApproved || !b.logo);
---

<section id="brands" class="py-16 bg-[#f8fafc] border-b border-slate-200/80 text-slate-900 overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8 mb-10 text-center">
    <span class="text-xs font-bold font-mono uppercase tracking-widest text-blue-600 mb-2 block">
      TRUSTED ACROSS INDUSTRIES
    </span>
    <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight text-slate-900">
      Clients, Brands & Business Partners
    </h2>
    <p class="mt-2 text-sm sm:text-base text-slate-600 max-w-xl mx-auto">
      Proven execution delivered across growth-stage e-commerce, agriculture, regional services, and international consultation.
    </p>
  </div>

  <!-- Row 1: Verified Brand Logos Marquee -->
  <div class="marquee-container overflow-hidden py-5 bg-white border-y border-slate-200/80">
    <div class="animate-marquee-left flex items-center gap-8 px-4">
      {
        [...verifiedBrands, ...verifiedBrands, ...verifiedBrands, ...verifiedBrands].map((b) => (
          <div class="h-20 w-[220px] shrink-0 rounded-xl border border-slate-200/80 bg-slate-50/60 px-5 py-3 flex items-center justify-center hover:border-blue-500/50 hover:bg-white transition-all shadow-xs group">
            <img
              src={`${site.basePath}${b.logo}`}
              alt={`${b.name} logo`}
              width="180"
              height="50"
              loading="lazy"
              class="max-h-[50px] w-auto object-contain grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-200"
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Row 2: Unverified Brands Typography Strip -->
  <div class="marquee-container overflow-hidden py-3.5 bg-slate-100/70 border-b border-slate-200/80">
    <div class="animate-marquee-right flex items-center gap-6 px-4">
      {
        [...unverifiedBrands, ...unverifiedBrands, ...unverifiedBrands].map((b) => (
          <div class="h-12 shrink-0 rounded-lg border border-slate-200 bg-white px-5 py-2 flex items-center justify-center shadow-xs hover:border-blue-400 transition-colors">
            <span class="font-display font-semibold text-sm text-slate-700 tracking-tight whitespace-nowrap">
              {b.name}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>