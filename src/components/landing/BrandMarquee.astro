---
import { brands } from '../../data/brands';
import SectionHeader from './SectionHeader.astro';

// Split brands into 2 rows for opposite marquees
const row1 = brands.slice(0, 8);
const row2 = brands.slice(8);
---

<section id="brands" class="py-18 bg-paper border-b-4 border-ink overflow-hidden">
  <div class="mx-auto max-w-[1200px] px-6 sm:px-8 mb-10 text-center">
    <SectionHeader
      eyebrow="Trust & Experience"
      title="Clients, Brands & Business Partners"
      sub="Commercial execution delivered across growth-stage businesses, regional enterprises, and specialized providers."
      on="orange"
      class="max-w-[680px] mb-8"
    />
  </div>

  <!-- Row 1: Left Marquee -->
  <div class="marquee-container overflow-hidden py-3 mb-5 border-y-2 border-line bg-cloud">
    <div class="animate-marquee-left flex items-center gap-6">
      {
        [...row1, ...row1, ...row1].map((b) => (
          <div class="h-16 w-52 shrink-0 rounded-tile border-2 border-ink bg-paper px-4 py-2 flex items-center justify-center shadow-pop-sm hover:border-orange transition-colors">
            {b.logoApproved && b.logo ? (
              <img
                src={b.logo}
                alt={`${b.name} logo`}
                width="160"
                height="44"
                loading="lazy"
                class="max-h-10 w-auto object-contain filter drop-shadow-sm"
              />
            ) : (
              <span class="font-display font-bold text-sm text-navy text-center leading-tight">
                {b.name}
              </span>
            )}
          </div>
        ))
      }
    </div>
  </div>

  <!-- Row 2: Right Marquee (Opposite Direction) -->
  <div class="marquee-container overflow-hidden py-3 border-b-2 border-line bg-cloud">
    <div class="animate-marquee-right flex items-center gap-6">
      {
        [...row2, ...row2, ...row2].map((b) => (
          <div class="h-16 w-52 shrink-0 rounded-tile border-2 border-ink bg-paper px-4 py-2 flex items-center justify-center shadow-pop-sm hover:border-orange transition-colors">
            {b.logoApproved && b.logo ? (
              <img
                src={b.logo}
                alt={`${b.name} logo`}
                width="160"
                height="44"
                loading="lazy"
                class="max-h-10 w-auto object-contain filter drop-shadow-sm"
              />
            ) : (
              <span class="font-display font-bold text-sm text-navy text-center leading-tight">
                {b.name}
              </span>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
