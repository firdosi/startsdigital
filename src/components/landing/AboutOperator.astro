---
import { site } from '../../site.config';
import SectionEyebrow from '../common/SectionEyebrow.astro';
import { CheckCircle, ArrowRight } from '@lucide/astro';

const experiencePoints = [
  {
    title: 'Multi-Channel Media Buying',
    desc: 'Planning and managing Meta Ads and Google Search campaigns around clear business objectives and measurable outcomes.',
  },
  {
    title: 'Custom Web & E-Commerce Engineering',
    desc: 'Building responsive websites and e-commerce experiences structured for usability, performance and clear customer journeys.',
  },
  {
    title: 'Search Architecture & Local Intent',
    desc: 'Creating structured, location-focused service pages and technical SEO foundations for relevant commercial searches.',
  },
  {
    title: 'AI Workflow Integration',
    desc: 'Building practical workflows for lead routing, content support and customer-response processes.',
  },
];
---

<section id="operator" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10 overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <div class="grid gap-12 lg:grid-cols-12 items-center">
      
      <!-- Left Side: Editorial Content with Fade-Left -->
      <div data-motion="fade-left" data-motion-delay="0" class="lg:col-span-7 space-y-8">
        <div class="space-y-3">
          <SectionEyebrow
          label="HONEST OPERATOR CREDIBILITY"
          align="left"
          delay={0}
        />
          <!-- Sora 700 section heading -->
          <h2 class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
            Hands-on experience across marketing, websites and business growth
          </h2>
        </div>

        <p class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal">
          Starts Digital supports businesses across paid advertising, websites, e-commerce, SEO, creative production and AI-enabled marketing workflows. Each project is scoped around the client’s goals, available assets and required deliverables.
        </p>

        <!-- Experience Pillars Grid: Staggered Fade-Up -->
        <div class="grid gap-4 sm:grid-cols-2 pt-2">
          {experiencePoints.map((item, idx) => (
            <div data-motion="fade-up" data-motion-delay={150 + idx * 80} class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm space-y-2 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
              <div class="flex items-center gap-2.5 font-heading font-semibold text-[18px] text-[#061d33] leading-snug">
                <div>
                  <CheckCircle class="size-5 text-[#ff762b] shrink-0" />
                </div>
                <span>{item.title}</span>
              </div>
              <p class="text-base text-slate-600 font-body leading-[1.6] font-normal">
                {item.desc}
              </p>
            </div>
          ))}
        </div>

        <div class="pt-4 flex flex-wrap items-center gap-4">
          <a
            href={`${site.basePath}/contact/`}
            data-track="primary-cta"
            class="group inline-flex items-center gap-2 rounded-full bg-[#061d33] px-8 py-4 font-body font-semibold text-base text-white shadow-md hover:bg-[#ff762b] transition-all"
          >
            <span>Discuss your project</span>
            <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
          </a>
        </div>
      </div>

      <!-- Right Side: Typography-Led Information Panel with Fade-Right -->
      <div data-motion="fade-right" data-motion-delay="150" class="lg:col-span-5">
        <div class="rounded-3xl border-2 border-[#061d33]/15 bg-[#061d33] p-7 sm:p-8 shadow-2xl text-white space-y-6">
          <div class="space-y-3">
            <span class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
              PROJECT DELIVERY
            </span>
            <h3 class="font-heading font-bold text-2xl sm:text-3xl text-white leading-tight">
              Strategy, execution and technical support in one workflow.
            </h3>
          </div>

          <div class="space-y-3 pt-2 font-body">
            <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm font-semibold text-slate-100">
              <div class="size-2 rounded-full bg-[#ff762b] shrink-0"></div>
              <span>Paid Advertising</span>
            </div>
            <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm font-semibold text-slate-100">
              <div class="size-2 rounded-full bg-[#ff762b] shrink-0"></div>
              <span>Websites & E-Commerce</span>
            </div>
            <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm font-semibold text-slate-100">
              <div class="size-2 rounded-full bg-[#ff762b] shrink-0"></div>
              <span>SEO & Local Search</span>
            </div>
            <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3 text-sm font-semibold text-slate-100">
              <div class="size-2 rounded-full bg-[#ff762b] shrink-0"></div>
              <span>Creative & AI Workflows</span>
            </div>
          </div>

          <p class="text-xs sm:text-sm text-slate-300 font-body leading-relaxed font-normal pt-1 border-t border-white/10">
            The exact scope depends on the selected services, project requirements and available client assets.
          </p>
        </div>
      </div>

    </div>

  </div>
</section>
