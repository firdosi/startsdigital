---
import { site } from '../../site.config';
import { ShieldCheck, CheckCircle2, Award, Zap, ArrowRight } from '@lucide/astro';

const experiencePoints = [
  {
    title: 'Multi-Channel Media Buying',
    desc: 'Hands-on management of Meta Ads and Google Search campaigns with zero outsourced middleman layers.',
  },
  {
    title: 'Custom Web & E-Commerce Engineering',
    desc: 'Building fast-loading WooCommerce and Shopify platforms structured specifically for mobile conversion velocity.',
  },
  {
    title: 'Search Architecture & Local Intent',
    desc: 'Engineering schema-marked, localized landing pages that index for commercial search queries in target markets.',
  },
  {
    title: 'AI Workflow Integration',
    desc: 'Deploying practical AI automation for lead qualification, content pipelines, and customer response routing.',
  },
];
---

<section id="operator" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <div class="grid gap-12 lg:grid-cols-12 items-center">
      
      <!-- Left Side: Editorial Content -->
      <div class="lg:col-span-7 space-y-8">
        <div>
          <span class="text-xs font-bold font-mono uppercase tracking-widest text-[#ff762b] mb-3 block">
            HONEST OPERATOR CREDIBILITY
          </span>
          <h2 class="font-display text-3xl sm:text-5xl lg:text-6xl font-black tracking-tight text-[#061d33] uppercase leading-tight">
            BUILT WITH HANDS-ON EXPERIENCE ACROSS MARKETING, WEBSITES AND BUSINESS GROWTH
          </h2>
        </div>

        <p class="text-base sm:text-lg text-slate-700 font-body leading-relaxed font-medium">
          We don't operate like a bloated agency with junior account managers. Starts Digital was built by active marketers and developers who work directly on your campaigns, code, and growth strategy.
        </p>

        <!-- Experience Pillars Grid -->
        <div class="grid gap-4 sm:grid-cols-2 pt-2">
          {experiencePoints.map((item) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              <div class="flex items-center gap-2 font-display text-base font-black uppercase text-[#061d33] mb-2">
                <CheckCircle2 class="size-5 text-[#ff762b] shrink-0" />
                <span>{item.title}</span>
              </div>
              <p class="text-sm text-slate-600 font-body leading-relaxed font-medium">
                {item.desc}
              </p>
            </div>
          ))}
        </div>

        <div class="pt-4 flex flex-wrap items-center gap-4">
          <a
            href={`${site.basePath}/#contact`}
            class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-8 py-4 font-display text-base font-bold text-white shadow-md hover:bg-[#ff762b] transition-all"
          >
            <span>Work With Us Directly</span>
            <ArrowRight class="size-4" />
          </a>
        </div>
      </div>

      <!-- Right Side: Real Project Visual Card -->
      <div class="lg:col-span-5">
        <div class="rounded-3xl border-2 border-[#061d33]/15 bg-[#061d33] p-4 shadow-2xl text-white space-y-6">
          <div class="relative overflow-hidden rounded-2xl bg-slate-900 p-2">
            <img
              src={`${site.basePath}/images/black-gold-official.png`}
              alt="Starts Digital Campaign Strategy Packaging Visual"
              width="500"
              height="340"
              loading="lazy"
              class="w-full h-[280px] rounded-xl object-cover"
            />
          </div>

          <div class="p-4 space-y-3 bg-white/5 rounded-2xl border border-white/10">
            <div class="flex items-center justify-between text-xs font-mono text-[#ddff35] font-bold uppercase">
              <span>DIRECT FOUNDER OVERSIGHT</span>
              <span>100% ACCOUNT OWNERSHIP</span>
            </div>
            <p class="text-sm font-body text-slate-200 leading-relaxed italic">
              "We take personal responsibility for performance. Every ad campaign, landing page, and automated workflow is reviewed directly against real revenue metrics."
            </p>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>
