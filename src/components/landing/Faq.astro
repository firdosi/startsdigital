---
import { Plus, Minus } from '@lucide/astro';

const items = [
  {
    q: 'What specific industries and business types do you work with?',
    a: 'We specialize in growth-stage e-commerce brands, agricultural suppliers, seasonal retail (such as Qurbani campaigns), local service contractors (renovation & HVAC), and professional services across Pakistan, Malaysia, and the Gulf region.',
  },
  {
    q: 'How do you track commercial results instead of vanity metrics?',
    a: 'We set up clean conversion tracking via Meta Pixel, Conversions API (CAPI), and Google Analytics 4. We measure success on actual bank revenue, cost-per-lead, and customer acquisition cost—not impressions or clicks.',
  },
  {
    q: 'What is your typical project timeframe?',
    a: 'Media campaigns and lead generation funnels can launch within 7–10 days after strategy approval. Custom website builds and SEO architectures typically take 2 to 4 weeks depending on scope.',
  },
  {
    q: 'Can Starts Digital manage our complete digital marketing end-to-end?',
    a: 'Yes. Our single-point operating model handles media buying, creative ad design, landing page engineering, conversion architecture, and technical SEO as one unified system.',
  },
];
---

<section id="faq" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <div class="grid gap-12 lg:grid-cols-12 items-start">
      
      <!-- Left Column: Boost-Style Title & Subtitle -->
      <div class="lg:col-span-5 space-y-4 lg:sticky lg:top-28">
        <span class="text-xs font-bold font-mono uppercase tracking-widest text-[#ff762b] block">
          CLEAR ANSWERS
        </span>
        <h2 class="font-body font-bold text-[28px] sm:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15]">
          Your questions answered
        </h2>
        <p class="text-base sm:text-lg text-slate-700 font-body leading-[1.6] font-normal">
          Everything you need to know about working with Starts Digital. Clear timelines, transparent tracking systems, and direct senior execution.
        </p>
      </div>

      <!-- Right Column: Plus/Minus Accordion Rows -->
      <div class="lg:col-span-7 space-y-4" id="faq-list">
        {
          items.map((item, i) => (
            <div 
              class="reveal-on-scroll overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:border-[#ff762b]"
              data-reveal-delay={i * 70}
            >
              <!-- FAQ Question (Manrope 600) -->
              <button
                type="button"
                data-faq-toggle
                aria-expanded={i === 0 ? 'true' : 'false'}
                class="flex w-full cursor-pointer items-center justify-between gap-4 px-7 py-6 text-left font-body text-base sm:text-lg font-semibold text-[#061d33] hover:text-[#ff762b] transition-colors"
              >
                <span>{item.q}</span>
                <span
                  data-faq-icon
                  class:list={[
                    'shrink-0 size-9 rounded-full bg-[#f7f4ed] flex items-center justify-center text-[#061d33] font-bold transition-all duration-200',
                    i === 0 && 'bg-[#ff762b] text-white rotate-180',
                  ]}
                >
                  <Plus class:list={['size-5', i === 0 && 'hidden']} data-icon-plus />
                  <Minus class:list={['size-5', i !== 0 && 'hidden']} data-icon-minus />
                </span>
              </button>
              
              <!-- FAQ Answer (Manrope 400 leading 1.6) -->
              <div
                data-faq-answer
                hidden={i !== 0}
                class="px-7 pb-6 text-base leading-[1.6] text-slate-700 font-body border-t border-slate-100 pt-4 font-normal"
              >
                {item.a}
              </div>
            </div>
          ))
        }
      </div>

    </div>

  </div>
</section>

<script>
  const list = document.getElementById('faq-list');
  const toggles = list?.querySelectorAll<HTMLButtonElement>('[data-faq-toggle]') ?? [];

  toggles.forEach((btn) => {
    btn.addEventListener('click', () => {
      const wasOpen = btn.getAttribute('aria-expanded') === 'true';
      
      toggles.forEach((other) => {
        const open = other === btn && !wasOpen;
        other.setAttribute('aria-expanded', String(open));
        
        const icon = other.querySelector('[data-faq-icon]');
        const plusIcon = other.querySelector('[data-icon-plus]');
        const minusIcon = other.querySelector('[data-icon-minus]');

        if (icon) {
          icon.classList.toggle('bg-[#ff762b]', open);
          icon.classList.toggle('text-white', open);
          icon.classList.toggle('bg-[#f7f4ed]', !open);
          icon.classList.toggle('text-[#061d33]', !open);
        }

        if (plusIcon && minusIcon) {
          plusIcon.classList.toggle('hidden', open);
          minusIcon.classList.toggle('hidden', !open);
        }

        const answer = other.parentElement?.querySelector<HTMLElement>('[data-faq-answer]');
        if (answer) answer.hidden = !open;
      });
    });
  });
</script>
