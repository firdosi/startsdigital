---
import { Plus, Minus } from '@lucide/astro';

const items = [
  {
    q: 'What specific industries and business types do you work with?',
    a: 'We specialize in growth-stage e-commerce brands, agricultural suppliers, seasonal retail (such as Qurbani campaigns), local service contractors (renovation & HVAC), and professional services across Pakistan, Malaysia, and the Gulf region.',
  },
  {
    q: 'How do you track commercial results instead of vanity metrics?',
    a: 'We set up clean conversion tracking via Meta Pixel, Conversions API (CAPI), and Google Analytics 4. We measure success on actual bank revenue, cost-per-lead, and customer acquisition cost—not impressions or clicks.',
  },
  {
    q: 'What is your typical project timeframe?',
    a: 'Media campaigns and lead generation funnels can launch within 7–10 days after strategy approval. Custom website builds and SEO architectures typically take 2 to 4 weeks depending on scope.',
  },
  {
    q: 'Can Starts Digital manage our complete digital marketing end-to-end?',
    a: 'Yes. Our single-point operating model handles media buying, creative ad design, landing page engineering, conversion architecture, and technical SEO as one unified system.',
  },
];
---

<section id="faq" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10 overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <div class="grid gap-12 lg:grid-cols-12 items-start">
      
      <!-- Left Column: Title & Subtitle -->
      <div class="lg:col-span-5 space-y-4 lg:sticky lg:top-28">
        <span data-motion="scale-in" class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
          CLEAR ANSWERS
        </span>
        <!-- Sora 700 section heading -->
        <h2 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
          Your questions answered
        </h2>
        <p data-motion="fade-up" data-motion-delay="200" class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal">
          Everything you need to know about working with Starts Digital. Clear timelines, transparent tracking systems, and direct senior execution.
        </p>
      </div>

      <!-- Right Column: Smooth Grid Height Accordion Rows -->
      <div class="lg:col-span-7 space-y-4" id="faq-list">
        {
          items.map((item, i) => (
            <div 
              data-motion="fade-up"
              data-motion-delay={i * 80}
              class:list={[
                'faq-item overflow-hidden rounded-2xl border-2 transition-all duration-300 shadow-sm',
                i === 0 ? 'border-[#ff762b] bg-white shadow-md' : 'border-slate-200 bg-white hover:border-[#ff762b]'
              ]}
            >
              <!-- FAQ Question -->
              <button
                type="button"
                data-faq-toggle
                aria-expanded={i === 0 ? 'true' : 'false'}
                class="flex w-full cursor-pointer items-center justify-between gap-4 px-7 py-6 text-left font-body text-[16px] sm:text-[17px] leading-[1.45] font-semibold text-[#061d33] hover:text-[#ff762b] transition-colors focus:outline-none"
              >
                <span>{item.q}</span>
                <span
                  data-faq-icon
                  class:list={[
                    'shrink-0 size-9 rounded-full flex items-center justify-center font-bold transition-all duration-300',
                    i === 0 ? 'bg-[#ff762b] text-white rotate-180' : 'bg-[#f7f4ed] text-[#061d33]'
                  ]}
                >
                  <Plus class:list={['size-5', i === 0 && 'hidden']} data-icon-plus />
                  <Minus class:list={['size-5', i !== 0 && 'hidden']} data-icon-minus />
                </span>
              </button>
              
              <!-- FAQ Answer: CSS Grid Interpolation -->
              <div
                data-faq-answer-wrapper
                class:list={[
                  'grid transition-[grid-template-rows,opacity] duration-300 ease-out px-7',
                  i === 0 ? 'grid-rows-[1fr] opacity-100 pb-6 pt-0' : 'grid-rows-[0fr] opacity-0 pb-0 pt-0'
                ]}
              >
                <div class="overflow-hidden text-base leading-[1.65] text-slate-700 font-body border-t border-slate-100 pt-4 font-normal">
                  {item.a}
                </div>
              </div>
            </div>
          ))
        }
      </div>

    </div>

  </div>
</section>

<script>
  const faqList = document.getElementById('faq-list');
  const faqItems = faqList?.querySelectorAll('.faq-item') ?? [];

  faqItems.forEach((item) => {
    const toggleBtn = item.querySelector<HTMLButtonElement>('[data-faq-toggle]');
    const wrapper = item.querySelector<HTMLElement>('[data-faq-answer-wrapper]');
    const icon = item.querySelector<HTMLElement>('[data-faq-icon]');
    const plusIcon = item.querySelector<HTMLElement>('[data-icon-plus]');
    const minusIcon = item.querySelector<HTMLElement>('[data-icon-minus]');

    toggleBtn?.addEventListener('click', () => {
      const isOpen = toggleBtn.getAttribute('aria-expanded') === 'true';

      // Close all other items
      faqItems.forEach((other) => {
        const otherBtn = other.querySelector<HTMLButtonElement>('[data-faq-toggle]');
        const otherWrapper = other.querySelector<HTMLElement>('[data-faq-answer-wrapper]');
        const otherIcon = other.querySelector<HTMLElement>('[data-faq-icon]');
        const otherPlus = other.querySelector<HTMLElement>('[data-icon-plus]');
        const otherMinus = other.querySelector<HTMLElement>('[data-icon-minus]');

        otherBtn?.setAttribute('aria-expanded', 'false');
        otherWrapper?.classList.remove('grid-rows-[1fr]', 'opacity-100', 'pb-6');
        otherWrapper?.classList.add('grid-rows-[0fr]', 'opacity-0', 'pb-0');

        other.classList.remove('border-[#ff762b]', 'shadow-md');
        other.classList.add('border-slate-200');

        otherIcon?.classList.remove('bg-[#ff762b]', 'text-white', 'rotate-180');
        otherIcon?.classList.add('bg-[#f7f4ed]', 'text-[#061d33]');

        otherPlus?.classList.remove('hidden');
        otherMinus?.classList.add('hidden');
      });

      // Toggle clicked item if it was closed
      if (!isOpen) {
        toggleBtn.setAttribute('aria-expanded', 'true');
        wrapper?.classList.remove('grid-rows-[0fr]', 'opacity-0', 'pb-0');
        wrapper?.classList.add('grid-rows-[1fr]', 'opacity-100', 'pb-6');

        item.classList.remove('border-slate-200');
        item.classList.add('border-[#ff762b]', 'shadow-md');

        icon?.classList.remove('bg-[#f7f4ed]', 'text-[#061d33]');
        icon?.classList.add('bg-[#ff762b]', 'text-white', 'rotate-180');

        plusIcon?.classList.add('hidden');
        minusIcon?.classList.remove('hidden');
      }
    });
  });
</script>
