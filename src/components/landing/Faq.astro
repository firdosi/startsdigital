---
import { HelpCircle } from '@lucide/astro';

const items = [
  {
    q: 'What specific industries and business types do you work with?',
    a: 'We specialize in growth-stage e-commerce brands, agricultural suppliers, seasonal retail (such as Qurbani campaigns), local service contractors (renovation & HVAC), and professional services across Pakistan, Malaysia, and the Gulf region.',
  },
  {
    q: 'How do you track commercial results instead of vanity metrics?',
    a: 'We set up clean conversion tracking via Meta Pixel, Conversions API (CAPI), and Google Analytics 4. We measure success on actual bank revenue, cost-per-lead, and customer acquisition cost—not impressions or clicks.',
  },
  {
    q: 'What is your typical project timeframe?',
    a: 'Media campaigns and lead generation funnels can launch within 7–10 days after strategy approval. Custom website builds and SEO architectures typically take 2 to 4 weeks depending on scope.',
  },
  {
    q: 'Can Starts Digital manage our complete digital marketing end-to-end?',
    a: 'Yes. Our single-point operating model handles media buying, creative ad design, landing page engineering, conversion rate optimization, and technical SEO as one unified system.',
  },
];
---

<section id="faq" class="py-24 bg-[#fafafa] border-b border-slate-200/80 text-slate-900 overflow-hidden">
  <div class="mx-auto max-w-[860px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-xl mx-auto mb-14">
      <span class="inline-flex items-center gap-2 text-xs font-bold font-mono uppercase tracking-widest text-blue-600 mb-2">
        <HelpCircle class="size-3.5 text-blue-600" />
        <span>CLEAR ANSWERS</span>
      </span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">
        Frequently Asked Questions
      </h2>
      <p class="mt-3 text-sm sm:text-base text-slate-600 font-body">
        Everything you need to know about working with Starts Digital.
      </p>
    </div>

    <!-- Premium Accordion List -->
    <div id="faq-list" class="space-y-4">
      {
        items.map((item, i) => (
          <div 
            class="reveal-on-scroll overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-xs transition-all duration-200 hover:border-slate-300"
            data-reveal-delay={i * 70}
          >
            <button
              type="button"
              data-faq-toggle
              aria-expanded={i === 0 ? 'true' : 'false'}
              class="flex w-full cursor-pointer items-center justify-between gap-4 px-6 sm:px-8 py-5 text-left font-display text-base sm:text-lg font-bold text-slate-900 hover:text-blue-600 transition-colors"
            >
              <span>{item.q}</span>
              <span
                data-faq-icon
                class:list={[
                  'shrink-0 size-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 transition-transform duration-200',
                  i === 0 && 'rotate-180 bg-blue-50 text-blue-600',
                ]}
              >
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </button>
            <div data-faq-answer hidden={i !== 0} class="px-6 sm:px-8 pb-6 text-sm sm:text-base leading-relaxed text-slate-600 font-body border-t border-slate-100 pt-4">
              {item.a}
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>

<script>
  const list = document.getElementById('faq-list');
  const toggles = list?.querySelectorAll<HTMLButtonElement>('[data-faq-toggle]') ?? [];

  toggles.forEach((btn) => {
    btn.addEventListener('click', () => {
      const wasOpen = btn.getAttribute('aria-expanded') === 'true';
      toggles.forEach((other) => {
        const open = other === btn && !wasOpen;
        other.setAttribute('aria-expanded', String(open));
        const icon = other.querySelector('[data-faq-icon]');
        if (icon) {
          icon.classList.toggle('rotate-180', open);
          icon.classList.toggle('bg-blue-50', open);
          icon.classList.toggle('text-blue-600', open);
        }
        const answer = other.parentElement?.querySelector<HTMLElement>('[data-faq-answer]');
        if (answer) answer.hidden = !open;
      });
    });
  });
</script>
