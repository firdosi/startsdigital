---
import { site } from '../../site.config';
import { 
  TrendingUp, 
  ShoppingBag, 
  Award, 
  CheckCircle2, 
  ArrowRight,
  Sparkles
} from '@lucide/astro';

const verifiedLogos = [
  { name: 'Black Gold Fertilizer', logo: '/brands/black-gold-fertilizer/logo.webp' },
  { name: 'RK Reno Solutions', logo: '/brands/rk-reno-solutions/logo.webp' },
  { name: 'Convort AI', logo: '/brands/convort-ai/logo.webp' },
];

const platforms = [
  { name: 'Meta Ads', logo: '/platforms/meta-ads.svg' },
  { name: 'Google Ads', logo: '/platforms/google-ads.svg' },
  { name: 'GA4', logo: '/platforms/ga4.svg' },
  { name: 'Shopify', logo: '/platforms/shopify.svg' },
];
---

<section id="hero" class="relative overflow-hidden bg-[#090d16] text-white py-16 sm:py-24 border-b border-white/10">
  <!-- Subtle Mesh Grid & Ambient Radial Glow -->
  <div class="pointer-events-none absolute inset-0 bg-grid-pattern opacity-40"></div>
  <div class="pointer-events-none absolute -top-40 right-0 size-[600px] rounded-full bg-blue-600/15 blur-[120px]"></div>
  <div class="pointer-events-none absolute bottom-0 left-0 size-[500px] rounded-full bg-blue-500/10 blur-[100px]"></div>

  <div class="relative mx-auto max-w-[1280px] px-6 sm:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      
      <!-- Left Column: Headline, Supporting Copy, CTAs & 4 Verified Proof Badges -->
      <div class="lg:col-span-7 space-y-8">
        
        <!-- Eyebrow Badge -->
        <div class="reveal-on-scroll">
          <span class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-blue-400 backdrop-blur-md">
            <Sparkles class="size-3.5 text-blue-400" />
            <span>GROWTH AGENCY & PERFORMANCE SYSTEMS</span>
          </span>
        </div>

        <!-- Main Headline -->
        <h1 class="reveal-on-scroll font-display text-4xl sm:text-5xl lg:text-[60px] font-bold leading-[1.06] tracking-tight text-white" data-reveal-delay="100">
          Digital marketing built to scale <span class="bg-gradient-to-r from-blue-400 via-blue-500 to-indigo-400 bg-clip-text text-transparent">real businesses</span>.
        </h1>

        <!-- Supporting Text -->
        <p class="reveal-on-scroll text-lg sm:text-xl leading-relaxed text-slate-300 font-body max-w-2xl" data-reveal-delay="200">
          Starts Digital helps businesses grow through paid advertising, websites, SEO, creative content and practical AI-powered marketing systems.
        </p>

        <!-- Action Buttons -->
        <div class="reveal-on-scroll flex flex-wrap gap-4 pt-2" data-reveal-delay="300">
          <a
            href={`${site.basePath}/#contact`}
            class="group inline-flex items-center gap-2 rounded-full bg-blue-600 px-7 py-4 font-display text-base font-bold text-white shadow-xl shadow-blue-600/25 hover:bg-blue-500 hover:shadow-blue-500/35 hover:-translate-y-0.5 transition-all"
          >
            <span>Discuss Your Project</span>
            <ArrowRight class="size-4 text-white group-hover:translate-x-1 transition-transform" />
          </a>
          <a
            href={`${site.basePath}/#work`}
            class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-slate-900/60 px-7 py-4 font-display text-base font-bold text-slate-200 hover:border-white/30 hover:bg-slate-800/80 hover:text-white transition-all backdrop-blur-sm"
          >
            View Our Work
          </a>
        </div>

        <!-- 4 Verified Commercial Metrics -->
        <div class="reveal-on-scroll pt-6 border-t border-white/10" data-reveal-delay="400">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            
            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <TrendingUp class="size-4 shrink-0" />
                <span>PKR 30M+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Revenue Supported</p>
            </div>

            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <ShoppingBag class="size-4 shrink-0" />
                <span>29,000+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Product Sales</p>
            </div>

            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <Award class="size-4 shrink-0" />
                <span>PKR 4.2M+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Qurbani Sales Supported</p>
            </div>

            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <CheckCircle2 class="size-4 shrink-0" />
                <span>150+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Animals Sold</p>
            </div>

          </div>
        </div>

      </div>

      <!-- Right Column: Original Layered Composition (Client Logos, Campaign Creatives, Website Screens, Platform Icons) -->
      <div class="lg:col-span-5 relative reveal-on-scroll" data-reveal-delay="200">
        <div class="relative mx-auto max-w-[480px] lg:max-w-none space-y-4">
          
          <!-- Outer Glass Container Card -->
          <div class="rounded-3xl border border-white/15 bg-slate-900/90 p-6 shadow-2xl backdrop-blur-xl space-y-6">
            
            <!-- Top Bar: Approved Client Logos -->
            <div class="space-y-2">
              <div class="text-[11px] font-mono font-semibold uppercase tracking-wider text-slate-400">
                Verified Client Brands
              </div>
              <div class="flex items-center justify-between gap-3 rounded-xl border border-white/10 bg-slate-950/60 p-3">
                {verifiedLogos.map((brand) => (
                  <div class="flex items-center justify-center h-8 px-2 rounded bg-white/5">
                    <img
                      src={`${site.basePath}${brand.logo}`}
                      alt={brand.name}
                      width="100"
                      height="30"
                      class="max-h-6 w-auto object-contain filter grayscale opacity-90 hover:grayscale-0 hover:opacity-100 transition-all"
                    />
                  </div>
                ))}
              </div>
            </div>

            <!-- Middle: Real Campaign & Website Screenshots Layer -->
            <div class="grid grid-cols-2 gap-3">
              <div class="relative overflow-hidden rounded-xl border border-white/10 bg-slate-950 p-1.5">
                <img
                  src={`${site.basePath}/images/meta-ads.webp`}
                  alt="Meta Advertising Creative"
                  width="280"
                  height="200"
                  loading="eager"
                  class="w-full h-28 object-cover rounded-lg"
                />
                <div class="mt-1 text-[10px] font-mono text-slate-400 text-center">Paid Media Creative</div>
              </div>

              <div class="relative overflow-hidden rounded-xl border border-white/10 bg-slate-950 p-1.5">
                <img
                  src={`${site.basePath}/images/project-seo.webp`}
                  alt="SEO & Search Architecture"
                  width="280"
                  height="200"
                  loading="eager"
                  class="w-full h-28 object-cover rounded-lg"
                />
                <div class="mt-1 text-[10px] font-mono text-slate-400 text-center">Search & Web Screens</div>
              </div>
            </div>

            <!-- Bottom: Platform Icons Strip & Verified Stat Pill -->
            <div class="pt-2 border-t border-white/10 flex items-center justify-between gap-3">
              <div class="flex items-center gap-2">
                {platforms.map((p) => (
                  <div class="size-8 rounded-lg bg-white/5 border border-white/10 p-1.5 flex items-center justify-center" title={p.name}>
                    <img src={`${site.basePath}${p.logo}`} alt={p.name} class="size-5 object-contain" />
                  </div>
                ))}
              </div>

              <div class="inline-flex items-center gap-2 rounded-lg border border-blue-500/30 bg-blue-600/20 px-3 py-1.5 text-xs font-bold font-display text-blue-400">
                <TrendingUp class="size-3.5 text-blue-400" />
                <span>PKR 30M+ Revenue Supported</span>
              </div>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</section>
