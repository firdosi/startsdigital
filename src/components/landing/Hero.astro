---
import { brands } from '../../data/brands';
import { site } from '../../site.config';
---

<section id="hero" class="bg-linear-160 from-navy to-navy-deep text-cloud overflow-hidden">
  <header
    id="top"
    class="relative mx-auto grid max-w-[1200px] items-center gap-10 px-6 sm:px-8 pt-16 pb-12 lg:grid-cols-[1.05fr_.95fr]"
  >
    <!-- Color Glows -->
    <span
      class="pointer-events-none absolute -top-[90px] -right-[70px] z-0 size-[660px] bg-radial from-orange/55 to-transparent to-62%"
      aria-hidden="true"
    ></span>
    <span
      class="pointer-events-none absolute -bottom-40 -left-[100px] z-0 size-[560px] bg-radial from-[rgb(96_165_250/0.45)] to-transparent to-64%"
      aria-hidden="true"
    ></span>

    <!-- Floating Stickers -->
    <span
      class="absolute top-14 left-[44%] z-1 size-[22px] rounded-md bg-orange [--r:18deg] animate-drift hidden sm:inline-block"
      aria-hidden="true"
    ></span>
    <span
      class="absolute top-50 left-1.5 z-1 size-4 rounded-full bg-cloud [--r:0deg] animate-drift-alt hidden sm:inline-block"
      aria-hidden="true"
    ></span>

    <div class="relative z-2">
      <!-- Eyebrow Pill -->
      <span
        class="inline-flex items-center gap-2 rounded-full bg-orange px-3.5 py-[7px] text-[13px] font-bold tracking-[0.03em] text-cloud shadow-sm"
      >
        ✦ DIGITAL MARKETING, CREATIVE & TECHNOLOGY
      </span>

      <!-- Headline -->
      <h1
        class="mt-5 font-display text-4xl sm:text-5xl lg:text-[64px] font-bold leading-[1.05] tracking-[-0.03em] text-cloud"
      >
        Digital marketing built to scale <span class="relative inline-block whitespace-nowrap text-orange-bright"
          >real businesses<svg
            viewBox="0 0 220 20"
            width="100%"
            height="16"
            class="absolute -bottom-2 left-0"
            preserveAspectRatio="none"
            aria-hidden="true"
            ><path
              d="M4 13 C60 4 160 4 216 11"
              stroke="var(--color-orange)"
              stroke-width="5"
              fill="none"
              stroke-linecap="round"></path></svg
          ></span
        >.
      </h1>

      <!-- Supporting Copy -->
      <p class="mt-6.5 max-w-[480px] text-lg sm:text-[19px] leading-[1.55] text-sky font-body">
        Starts Digital helps businesses grow through paid advertising, websites, SEO, creative content and practical AI-powered marketing systems.
      </p>

      <!-- Action Buttons -->
      <div class="mt-8 flex flex-wrap gap-3.5">
        <a
          href={`${site.basePath}/#contact`}
          class="rounded-full bg-orange px-7 py-[15px] font-bold text-cloud shadow-pop-white transition-[transform,box-shadow] hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[7px_7px_0_var(--color-cloud)]"
        >
          Discuss Your Project →
        </a>
        <a
          href={`${site.basePath}/#work`}
          class="rounded-full border-2 border-cloud bg-cloud px-7 py-[15px] font-bold text-navy transition-transform hover:-translate-x-0.5 hover:-translate-y-0.5"
        >
          View Our Work
        </a>
      </div>

      <!-- Quick Verified Metric Pills -->
      <div class="mt-8.5 flex flex-wrap items-center gap-4 text-xs font-semibold text-sky-mist">
        <span class="rounded-full border border-white/20 bg-white/10 px-3.5 py-1.5 text-cloud">PKR 30M+ Revenue Supported</span>
        <span class="rounded-full border border-white/20 bg-white/10 px-3.5 py-1.5 text-cloud">29,000+ Product Sales</span>
      </div>
    </div>

    <!-- ORBIT GRAPHIC (Kepler Theme Signature Component) -->
    <div class="relative z-2 flex aspect-square items-center justify-center max-w-[420px] mx-auto lg:max-w-none">
      <div
        class="absolute h-[88%] w-[88%] rounded-full border-2 border-dashed border-white/40 animate-orbit-spin"
      >
        <span
          class="absolute -top-[9px] left-1/2 -ml-[9px] size-[18px] rounded-full bg-orange shadow-[0_0_0_4px_rgb(249_115_22/0.3)]"
        ></span>
      </div>
      <div
        class="absolute h-[62%] w-[62%] rounded-full border-2 border-white/30 animate-orbit-spin-rev"
      >
        <span
          class="absolute -bottom-[7px] left-1/2 -ml-[7px] size-3.5 rounded bg-cloud"
        ></span>
      </div>
      <div
        class="relative flex h-[40%] w-[40%] items-center justify-center rounded-[26px] bg-orange shadow-pop-lg"
      >
        <span
          class="absolute h-5 w-11 -rotate-[28deg] rounded-full border-[3px] border-cloud"
        ></span>
        <span class="size-4 rounded-full bg-cloud"></span>
      </div>
      <span class="absolute top-[8%] right-[10%] text-[26px] text-orange">✦</span>
      <span class="absolute bottom-[10%] left-[6%] text-xl text-cloud">✦</span>
    </div>
  </header>

  <!-- KEPLER LOGO STRIP (15 Approved Brand Names as Normal Typography) -->
  <div class="mx-auto max-w-[1200px] px-6 sm:px-8 pt-2 pb-16">
    <p
      class="mb-6 text-center text-[13px] font-bold tracking-[0.14em] text-white/70 uppercase font-display"
    >
      BRANDS & PROJECTS WE HAVE WORKED WITH
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
      {
        brands.map((brand) => (
          <span class="font-display text-lg sm:text-[21px] font-bold text-white/85 hover:text-orange transition-colors">
            {brand.name}
          </span>
        ))
      }
    </div>
  </div>
</section>
