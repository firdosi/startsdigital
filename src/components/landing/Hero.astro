---
import { site } from '../../site.config';
import { 
  TrendingUp, 
  ShoppingBag, 
  Award, 
  CheckCircle2, 
  ArrowRight,
  Sparkles
} from '@lucide/astro';
---

<section id="hero" class="relative overflow-hidden bg-[#090d16] text-white py-16 sm:py-24 border-b border-white/10">
  <!-- Subtle Mesh Grid & Radial Glow Background -->
  <div class="pointer-events-none absolute inset-0 bg-grid-pattern opacity-40"></div>
  <div class="pointer-events-none absolute -top-40 right-0 size-[600px] rounded-full bg-blue-600/15 blur-[120px]"></div>
  <div class="pointer-events-none absolute bottom-0 left-0 size-[500px] rounded-full bg-orange-500/10 blur-[100px]"></div>

  <div class="relative mx-auto max-w-[1280px] px-6 sm:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      
      <!-- Left Column: Copy & CTAs & Proof Points -->
      <div class="lg:col-span-7 space-y-8">
        
        <!-- Eyebrow Badge -->
        <div class="reveal-on-scroll">
          <span class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-blue-400 backdrop-blur-md">
            <Sparkles class="size-3.5 text-blue-400" />
            <span>GROWTH AGENCY & PERFORMANCE SYSTEMS</span>
          </span>
        </div>

        <!-- Main Headline -->
        <h1 class="reveal-on-scroll font-display text-4xl sm:text-5xl lg:text-[60px] font-bold leading-[1.06] tracking-tight text-white" data-reveal-delay="100">
          Digital marketing built to scale <span class="bg-gradient-to-r from-blue-400 via-blue-500 to-indigo-400 bg-clip-text text-transparent">real businesses</span>.
        </h1>

        <!-- Supporting Text -->
        <p class="reveal-on-scroll text-lg sm:text-xl leading-relaxed text-slate-300 font-body max-w-2xl" data-reveal-delay="200">
          Starts Digital helps businesses grow through paid advertising, websites, SEO, creative content and practical AI-powered marketing systems.
        </p>

        <!-- Primary & Secondary CTA Buttons -->
        <div class="reveal-on-scroll flex flex-wrap gap-4 pt-2" data-reveal-delay="300">
          <a
            href={`${site.basePath}/#contact`}
            class="group inline-flex items-center gap-2 rounded-full bg-blue-600 px-7 py-4 font-display text-base font-bold text-white shadow-xl shadow-blue-600/25 hover:bg-blue-500 hover:shadow-blue-500/35 hover:-translate-y-0.5 transition-all"
          >
            <span>Discuss Your Project</span>
            <ArrowRight class="size-4 text-white group-hover:translate-x-1 transition-transform" />
          </a>
          <a
            href={`${site.basePath}/#work`}
            class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-slate-900/60 px-7 py-4 font-display text-base font-bold text-slate-200 hover:border-white/30 hover:bg-slate-800/80 hover:text-white transition-all backdrop-blur-sm"
          >
            View Our Work
          </a>
        </div>

        <!-- Verified Proof Points Grid (4 Verified Proof Items) -->
        <div class="reveal-on-scroll pt-6 border-t border-white/10" data-reveal-delay="400">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            
            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <TrendingUp class="size-4 shrink-0" />
                <span>PKR 30M+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Revenue Supported</p>
            </div>

            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <ShoppingBag class="size-4 shrink-0" />
                <span>29,000+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Product Sales</p>
            </div>

            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <Award class="size-4 shrink-0" />
                <span>PKR 4.2M+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Qurbani Sales</p>
            </div>

            <div class="rounded-xl border border-white/10 bg-slate-900/40 p-3.5 backdrop-blur-sm">
              <div class="flex items-center gap-1.5 text-blue-400 font-display text-lg sm:text-xl font-bold">
                <CheckCircle2 class="size-4 shrink-0" />
                <span>150+</span>
              </div>
              <p class="text-xs text-slate-400 font-medium mt-1">Animals Sold</p>
            </div>

          </div>
        </div>

      </div>

      <!-- Right Column: Premium Layered Visual Composition -->
      <div class="lg:col-span-5 relative reveal-on-scroll" data-reveal-delay="200">
        <div class="relative mx-auto max-w-[480px] lg:max-w-none">
          
          <!-- Base Card Window (Realistic Browser Frame) -->
          <div class="overflow-hidden rounded-2xl border border-white/15 bg-slate-900/90 shadow-2xl shadow-blue-950/50 backdrop-blur-xl">
            <!-- Browser Header Bar -->
            <div class="flex items-center justify-between border-b border-white/10 bg-slate-950/80 px-4 py-3">
              <div class="flex items-center gap-1.5">
                <span class="size-3 rounded-full bg-red-500/80"></span>
                <span class="size-3 rounded-full bg-yellow-500/80"></span>
                <span class="size-3 rounded-full bg-green-500/80"></span>
              </div>
              <div class="rounded-md border border-white/10 bg-slate-900/80 px-3 py-1 text-[11px] font-mono text-slate-400">
                startsdigital.com/work/black-gold-fertilizer
              </div>
              <div class="text-xs text-slate-500 font-mono">LIVE</div>
            </div>

            <!-- Browser Content Frame -->
            <div class="relative p-2 bg-slate-950/60">
              <img
                src={`${site.basePath}/images/hero-business.webp`}
                alt="Starts Digital Campaign Showcase"
                width="600"
                height="400"
                loading="eager"
                class="w-full h-auto rounded-lg object-cover border border-white/10 shadow-md"
              />
            </div>
          </div>

          <!-- Overlaid Floating Glass Card 1 (Bottom Left) -->
          <div class="absolute -bottom-6 -left-6 z-20 hidden sm:flex items-center gap-3 rounded-xl border border-white/15 bg-slate-900/90 p-4 shadow-xl shadow-black/50 backdrop-blur-xl animate-float">
            <div class="size-10 rounded-lg bg-blue-600/20 border border-blue-500/30 flex items-center justify-center text-blue-400">
              <TrendingUp class="size-5" />
            </div>
            <div>
              <div class="text-xs font-mono text-slate-400 uppercase tracking-wider">E-Commerce Scale</div>
              <div class="text-sm font-bold text-white font-display">PKR 30M+ Revenue Managed</div>
            </div>
          </div>

          <!-- Overlaid Floating Glass Card 2 (Top Right) -->
          <div class="absolute -top-6 -right-6 z-20 hidden sm:flex items-center gap-3 rounded-xl border border-white/15 bg-slate-900/90 p-4 shadow-xl shadow-black/50 backdrop-blur-xl">
            <div class="size-10 rounded-lg bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center text-emerald-400">
              <CheckCircle2 class="size-5" />
            </div>
            <div>
              <div class="text-xs font-mono text-slate-400 uppercase tracking-wider">Verified Campaigns</div>
              <div class="text-sm font-bold text-white font-display">29,000+ Orders Processed</div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
