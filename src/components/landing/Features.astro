---
import { 
  Megaphone, 
  ShoppingBag, 
  Search, 
  Video, 
  Bot, 
  BarChart3, 
  ArrowUpRight
} from '@lucide/astro';

const services = [
  {
    id: '01',
    title: 'Paid Advertising and Lead Generation',
    description: 'Precision Meta Ads and Google Ads campaigns engineered for commercial customer acquisition, lead funnels, and performance scaling.',
    colorClass: 'bg-[#ff762b] text-white hover:bg-[#e56017]',
    badgeClass: 'bg-white/20 text-white',
    Icon: Megaphone,
  },
  {
    id: '02',
    title: 'Website Design and E-Commerce',
    description: 'Custom high-converting websites, WooCommerce platforms, and Shopify stores built for lightning speed and checkout friction reduction.',
    colorClass: 'bg-[#9a83f5] text-white hover:bg-[#8b5cf6]',
    badgeClass: 'bg-white/20 text-white',
    Icon: ShoppingBag,
  },
  {
    id: '03',
    title: 'SEO and Local Search',
    description: 'Technical search engine optimization, structured schema markup, and local service landing pages to capture high-intent search demand.',
    colorClass: 'bg-[#ff514b] text-white hover:bg-[#e6453f]',
    badgeClass: 'bg-white/20 text-white',
    Icon: Search,
  },
  {
    id: '04',
    title: 'Creative Content',
    description: 'Performance ad creatives, short-form video editing, product graphics, and social content tailored for audience engagement and conversion.',
    colorClass: 'bg-[#39c98a] text-white hover:bg-[#32b57c]',
    badgeClass: 'bg-white/20 text-white',
    Icon: Video,
  },
  {
    id: '05',
    title: 'AI Marketing Systems',
    description: 'Practical use of AI for lead qualification workflows, avatar video creation, content pipelines, and automated customer routing.',
    colorClass: 'bg-[#061d33] text-white hover:bg-[#0a2540]',
    badgeClass: 'bg-white/20 text-white',
    Icon: Bot,
  },
  {
    id: '06',
    title: 'Campaign Strategy',
    description: 'Commercial positioning, marketing budget allocation, multi-channel rollout plans, and data-backed performance advisory.',
    colorClass: 'bg-[#ddff35] text-[#061d33] hover:bg-[#c9eb1e]',
    badgeClass: 'bg-[#061d33]/15 text-[#061d33]',
    Icon: BarChart3,
  },
];
---

<section id="services" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 text-center mx-auto space-y-3">
      <!-- JetBrains Mono 500 eyebrow -->
      <span class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
        OUR SERVICES
      </span>
      <!-- Sora 700 heading -->
      <h2 class="font-heading font-bold text-[28px] sm:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.12] tracking-[-0.025em]">
        Services designed to drive real results
      </h2>
      <!-- Inter 400 subtitle -->
      <p class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal max-w-2xl mx-auto">
        We replace fragmented workflows with unified growth capabilities spanning paid media, web engineering, SEO, and AI automation.
      </p>
    </div>

    <!-- 6 Colourful Cards Grid (Responsive 3x2 Desktop Layout) -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s, idx) => (
          <div
            class:list={[
              'reveal-on-scroll rounded-3xl p-8 lg:p-10 shadow-xl flex flex-col justify-between transition-all duration-300 transform hover:-translate-y-1.5 group cursor-pointer',
              s.colorClass
            ]}
            data-reveal-delay={idx * 80}
          >
            <div>
              <!-- Top Row: Icon & Step Badge -->
              <div class="flex items-center justify-between mb-8">
                <div class="size-14 rounded-2xl bg-white/20 flex items-center justify-center backdrop-blur-md">
                  <s.Icon class="size-7" />
                </div>
                <span class:list={['text-xs font-mono font-medium px-3.5 py-1 rounded-full uppercase tracking-[0.05em]', s.badgeClass]}>
                  PHASE {s.id}
                </span>
              </div>

              <!-- Title: Sora 600, 19-22px, leading 1.25 -->
              <h3 class="font-heading font-semibold text-[19px] sm:text-[22px] leading-[1.25] mb-3">
                {s.title}
              </h3>

              <!-- Description: Inter 400, min 16px, leading 1.65 -->
              <p class="text-base leading-[1.65] opacity-95 font-body font-normal">
                {s.description}
              </p>
            </div>

            <!-- Bottom Action Link: Inter 600, min 14px -->
            <div class="mt-10 pt-6 border-t border-current/20 flex items-center justify-between font-body">
              <span class="text-[14px] sm:text-[15px] font-semibold tracking-normal">Explore capability</span>
              <div class="size-10 rounded-full bg-white/20 flex items-center justify-center group-hover:scale-110 transition-transform">
                <ArrowUpRight class="size-5" />
              </div>
            </div>

          </div>
        ))
      }
    </div>

  </div>
</section>
