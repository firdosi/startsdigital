---
import MotionIconTile from '../motion/MotionIconTile.astro';
import { site } from '../../site.config';
import { 
  Megaphone, 
  ShoppingBag, 
  Search, 
  Video, 
  Bot, 
  BarChart3, 
  ArrowUpRight
} from '@lucide/astro';

const services = [
  {
    id: '01',
    slug: 'paid-advertising',
    title: 'Paid Advertising and Lead Generation',
    description: 'Precision Meta Ads and Google Ads campaigns engineered for commercial customer acquisition, lead funnels, and performance scaling.',
    colorClass: 'bg-[#ff762b] text-white hover:bg-[#e56017]',
    badgeClass: 'bg-white/20 text-white',
    offsetClass: 'translate-y-0',
    Icon: Megaphone,
  },
  {
    id: '02',
    slug: 'website-development',
    title: 'Website Design and E-Commerce',
    description: 'Custom high-converting websites, WooCommerce platforms, and Shopify stores built for lightning speed and checkout friction reduction.',
    colorClass: 'bg-[#9a83f5] text-white hover:bg-[#8b5cf6]',
    badgeClass: 'bg-white/20 text-white',
    offsetClass: 'translate-y-0 sm:translate-y-3',
    Icon: ShoppingBag,
  },
  {
    id: '03',
    slug: 'seo',
    title: 'SEO and Local Search',
    description: 'Technical search engine optimization, structured schema markup, and local service landing pages to capture high-intent search demand.',
    colorClass: 'bg-[#ff514b] text-white hover:bg-[#e6453f]',
    badgeClass: 'bg-white/20 text-white',
    offsetClass: 'translate-y-0 lg:translate-y-1',
    Icon: Search,
  },
  {
    id: '04',
    slug: 'creative-content',
    title: 'Creative Content',
    description: 'Performance ad creatives, short-form video editing, product graphics, and social content tailored for audience engagement and conversion.',
    colorClass: 'bg-[#39c98a] text-white hover:bg-[#32b57c]',
    badgeClass: 'bg-white/20 text-white',
    offsetClass: 'translate-y-0',
    Icon: Video,
  },
  {
    id: '05',
    slug: 'ai-marketing-systems',
    title: 'AI Marketing Systems',
    description: 'Practical use of AI for lead qualification workflows, avatar video creation, content pipelines, and automated customer routing.',
    colorClass: 'bg-[#061d33] text-white hover:bg-[#0a2540]',
    badgeClass: 'bg-white/20 text-white',
    offsetClass: 'translate-y-0 sm:translate-y-3',
    Icon: Bot,
  },
  {
    id: '06',
    slug: 'multiple-services',
    title: 'Campaign Strategy',
    description: 'Commercial positioning, marketing budget allocation, multi-channel rollout plans, and data-backed performance advisory.',
    colorClass: 'bg-[#ddff35] text-[#061d33] hover:bg-[#c9eb1e]',
    badgeClass: 'bg-[#061d33]/15 text-[#061d33]',
    offsetClass: 'translate-y-0 lg:translate-y-1',
    Icon: BarChart3,
  },
];
---

<section id="services" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] relative">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <div class="mb-16 text-center max-w-3xl mx-auto space-y-4">
      <div data-motion="scale-in">
        <span class="inline-flex items-center gap-2 rounded-full border border-[#061d33]/20 bg-white px-4 py-1.5 text-xs font-mono font-medium uppercase tracking-[0.06em] text-[#ff762b] shadow-xs">
          <span>OUR CAPABILITIES</span>
        </span>
      </div>

      <h2 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[33px] sm:text-[42px] lg:text-[50px] text-[#061d33] leading-[1.12] tracking-[-0.025em]">
        End-to-end digital services built for business growth.
      </h2>

      <p data-motion="fade-up" data-motion-delay="200" class="text-base sm:text-lg text-slate-700 font-body leading-[1.65] font-normal">
        From customer acquisition campaigns to high-performing web platforms, we build and manage digital infrastructure.
      </p>
    </div>

    <!-- 6-Card Services Grid with Staggered Entrance -->
    <div data-motion-group data-motion-stagger="100" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s, idx) => (
          <a
            href={`${site.basePath}/contact/?service=${s.slug}`}
            data-track="service-contact"
            data-motion="fade-up"
            data-motion-delay={idx * 100}
            class:list={[
              'rounded-3xl p-8 lg:p-10 shadow-xl flex flex-col justify-between transition-all duration-300 transform hover:-translate-y-2 hover:shadow-2xl group cursor-pointer border border-white/10 no-underline',
              s.colorClass,
              s.offsetClass
            ]}
          >
            <div>
              <!-- Top Row: Layered 3D Icon Tile & Step Badge -->
              <div class="flex items-center justify-between mb-8">
                <MotionIconTile iconBg="bg-white/20">
                  <s.Icon class="size-7" />
                </MotionIconTile>
                <span class:list={['text-xs font-mono font-medium px-3.5 py-1 rounded-full uppercase tracking-[0.05em]', s.badgeClass]}>
                  PHASE {s.id}
                </span>
              </div>

              <!-- Title -->
              <h3 class="font-heading font-semibold text-[20px] sm:text-[21px] leading-[1.3] mb-3">
                {s.title}
              </h3>

              <!-- Description -->
              <p class="text-base leading-[1.65] opacity-95 font-body font-normal">
                {s.description}
              </p>
            </div>

            <!-- Bottom Action Link -->
            <div class="mt-10 pt-6 border-t border-current/20 flex items-center justify-between font-body">
              <span class="text-[15px] sm:text-[16px] font-semibold tracking-normal">Start a Project</span>
              <div class="size-10 rounded-full bg-white/20 flex items-center justify-center group-hover:scale-115 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300">
                <ArrowUpRight class="size-5" />
              </div>
            </div>

          </a>
        ))
      }
    </div>

  </div>
</section>
