---
import SectionHeader from './SectionHeader.astro';
import { 
  Megaphone, 
  ShoppingBag, 
  Search, 
  Video, 
  Bot, 
  BarChart3, 
  MousePointerClick, 
  MapPin, 
  Workflow, 
  TrendingUp,
  Image as ImageIcon,
  Target
} from '@lucide/astro';

const services = [
  {
    title: 'Paid Advertising and Lead Generation',
    body: 'Precision Meta Ads and Google Ads campaigns engineered for immediate customer acquisition, lead volume, and high ROAS.',
    chip: 'bg-orange-soft',
    IconComponent: Megaphone,
    subIcon: Target,
    iconColor: 'text-orange-deep',
  },
  {
    title: 'Website Design and E-Commerce',
    body: 'Custom high-converting websites and WooCommerce platforms designed for fast load speed, mobile checkout, and SEO.',
    chip: 'bg-sky',
    IconComponent: ShoppingBag,
    subIcon: MousePointerClick,
    iconColor: 'text-navy',
  },
  {
    title: 'SEO and Local Search',
    body: 'Technical search engine optimization and local service landing pages built to capture organic demand across commercial keywords.',
    chip: 'bg-orange-soft',
    IconComponent: Search,
    subIcon: MapPin,
    iconColor: 'text-orange-deep',
  },
  {
    title: 'Creative Content',
    body: 'Performance ad creatives, short-form video editing, product graphics, and social content tailored for feed conversion.',
    chip: 'bg-sky',
    IconComponent: Video,
    subIcon: ImageIcon,
    iconColor: 'text-navy',
  },
  {
    title: 'AI Marketing Systems',
    body: 'Automated lead qualification workflows, AI content pipelines, and automated customer routing systems for operational scale.',
    chip: 'bg-orange-soft',
    IconComponent: Bot,
    subIcon: Workflow,
    iconColor: 'text-orange-deep',
  },
  {
    title: 'Campaign Strategy',
    body: 'Commercial positioning, marketing budget allocation, multi-channel rollout plans, and data-backed scale advisory.',
    chip: 'bg-sky',
    IconComponent: BarChart3,
    subIcon: TrendingUp,
    iconColor: 'text-navy',
  },
];
---

<section
  id="services"
  class="border-y-4 border-ink bg-linear-160 from-orange-bright from-0% via-orange via-55% to-orange-deep text-ink relative overflow-hidden"
>
  <!-- Decorative Kepler Corner Elements -->
  <span class="absolute top-10 left-[4%] text-[32px] text-cloud pointer-events-none" aria-hidden="true">✦</span>
  <span class="absolute bottom-12 right-[5%] size-5 rotate-[22deg] rounded-md bg-cloud pointer-events-none" aria-hidden="true"></span>

  <div class="mx-auto max-w-[1200px] px-6 sm:px-8 pt-18 pb-21">
    <SectionHeader
      eyebrow="Capabilities"
      title="End-to-End Growth System"
      sub="No fragmented freelancers or blame-shifting. We manage media, web architecture, search, and creative as one system."
      on="orange"
    />
    <div class="grid gap-6 md:grid-cols-3">
      {
        services.map((s, i) => (
          <div
            class:list={[
              'reveal-on-scroll rounded-card border-2 border-ink bg-cloud p-7 shadow-pop transition-[transform,box-shadow] duration-180 hover:translate-y-[-4px] hover:rotate-0 hover:shadow-pop-lg flex flex-col justify-between',
              i % 2 === 0 ? '-rotate-1' : 'rotate-1',
            ]}
            data-reveal-delay={i * 80}
          >
            <div>
              <div class="flex items-center justify-between mb-5">
                <span
                  class:list={[
                    'flex size-14 items-center justify-center rounded-chip border-2 border-ink shadow-pop-sm',
                    s.chip,
                  ]}
                >
                  <s.IconComponent class:list={['size-7', s.iconColor]} />
                </span>
                <span class="flex size-8 items-center justify-center rounded-full bg-paper border border-line">
                  <s.subIcon class="size-4 text-slate-500" />
                </span>
              </div>
              <h3 class="font-display text-[21px] font-bold text-navy leading-snug">{s.title}</h3>
              <p class="mt-3 text-[15px] sm:text-[16px] leading-relaxed text-slate-700 font-body">{s.body}</p>
            </div>

            <div class="mt-6 pt-3 border-t border-line flex items-center justify-between text-xs font-mono text-slate-500">
              <span>Kepler Capability</span>
              <span class="text-orange font-bold">✦ Active</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
