---
import { TrendingUp, ShoppingBag, Award, HeartHandshake, CheckCircle } from '@lucide/astro';

const metrics = [
  {
    target: '30',
    prefix: 'PKR ',
    suffix: 'M+',
    exact: 'PKR 30M+',
    label: 'Revenue Supported',
    description: 'Total revenue supported across managed commercial campaigns and e-commerce stores.',
    blockClass: 'bg-[#ff762b] text-white',
    badgeClass: 'bg-white/20 text-white',
    Icon: TrendingUp,
  },
  {
    target: '29000',
    prefix: '',
    suffix: '+',
    exact: '29,000+',
    label: 'Product Sales',
    description: '29,000+ product sales supported across multiple product categories.',
    blockClass: 'bg-[#9a83f5] text-white',
    badgeClass: 'bg-white/20 text-white',
    Icon: ShoppingBag,
  },
  {
    target: '4.2',
    prefix: 'PKR ',
    suffix: 'M+',
    exact: 'PKR 4.2M+',
    label: 'Sales Supported',
    description: 'PKR 4.2M+ sales supported during the seasonal Wajib Livestock Qurbani campaign.',
    blockClass: 'bg-[#ddff35] text-[#061d33]',
    badgeClass: 'bg-[#061d33]/15 text-[#061d33]',
    Icon: Award,
  },
  {
    target: '150',
    prefix: '',
    suffix: '+',
    exact: 'More Than 150',
    label: 'Animals Sold',
    description: 'More than 150 animals sold through seasonal campaign execution.',
    blockClass: 'bg-[#ff514b] text-white',
    badgeClass: 'bg-white/20 text-white',
    Icon: HeartHandshake,
  },
];
---

<section id="results" class="py-20 lg:py-28 bg-[#061d33] text-white border-b border-white/10 overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-flex items-center gap-2 text-xs font-bold font-mono uppercase tracking-widest text-[#ddff35] mb-3">
        <CheckCircle class="size-4 text-[#ddff35]" />
        <span>VERIFIED PERFORMANCE</span>
      </span>
      <h2 class="font-display text-4xl sm:text-6xl font-black uppercase tracking-tight text-white leading-none">
        VERIFIED COMMERCIAL RESULTS
      </h2>
      <p class="mt-4 text-lg text-slate-300 font-body">
        Commercial milestones achieved across client accounts with 100% verified first-party metrics.
      </p>
    </div>

    <!-- 4 Large Colourful Metric Blocks -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        metrics.map((m, idx) => (
          <div
            class:list={[
              'reveal-on-scroll rounded-3xl p-8 lg:p-10 shadow-2xl flex flex-col justify-between transition-all duration-300 transform hover:-translate-y-2 group',
              m.blockClass
            ]}
            data-reveal-delay={idx * 100}
          >
            <div>
              <div class="flex items-center justify-between mb-8">
                <div class="size-14 rounded-2xl bg-current/15 flex items-center justify-center backdrop-blur-md">
                  <m.Icon class="size-7" />
                </div>
                <span class:list={['text-xs font-mono font-extrabold px-3 py-1 rounded-full uppercase tracking-wider', m.badgeClass]}>
                  VERIFIED
                </span>
              </div>

              <!-- Oversized Condensed Counter Typography -->
              <div
                class="font-display text-4xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tight leading-none counter-value mb-4"
                data-counter-target={m.target}
                data-counter-prefix={m.prefix}
                data-counter-suffix={m.suffix}
                data-counter-exact={m.exact}
              >
                {m.exact}
              </div>

              <h3 class="font-display text-xl sm:text-2xl font-black uppercase leading-tight mb-2">
                {m.label}
              </h3>
              
              <p class="text-sm leading-relaxed font-body font-medium opacity-90">
                {m.description}
              </p>
            </div>

            <div class="mt-8 pt-4 border-t border-current/20 flex items-center justify-between text-xs font-mono font-bold uppercase tracking-wider">
              <span>Performance Track</span>
              <span>100% Verified</span>
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>
