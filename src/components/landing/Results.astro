---
import { TrendingUp, ShoppingBag, Award, HeartHandshake, CheckCircle2 } from '@lucide/astro';

const metrics = [
  {
    target: '30',
    prefix: 'PKR ',
    suffix: 'M+',
    exact: 'PKR 30M+',
    label: 'Revenue Supported',
    description: 'Total revenue supported across managed commercial campaigns and e-commerce stores.',
    Icon: TrendingUp,
  },
  {
    target: '29000',
    prefix: '',
    suffix: '+',
    exact: '29,000+',
    label: 'Product Sales',
    description: '29,000+ product sales supported across multiple product categories.',
    Icon: ShoppingBag,
  },
  {
    target: '4.2',
    prefix: 'PKR ',
    suffix: 'M+',
    exact: 'PKR 4.2M+',
    label: 'Sales Supported',
    description: 'PKR 4.2M+ sales supported during the seasonal Wajib Livestock Qurbani campaign.',
    Icon: Award,
  },
  {
    target: '150',
    prefix: '',
    suffix: '+',
    exact: 'More than 150',
    label: 'Animals Sold',
    description: 'More than 150 animals sold through seasonal campaign execution.',
    Icon: HeartHandshake,
  },
];
---

<section id="results" class="relative py-24 bg-[#090d16] text-white border-b border-white/10 overflow-hidden">
  <!-- Ambient Radial Glow -->
  <div class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[650px] rounded-full bg-blue-600/10 blur-[140px]"></div>

  <div class="relative mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-flex items-center gap-2 text-xs font-bold font-mono uppercase tracking-widest text-blue-400 mb-3">
        <CheckCircle2 class="size-3.5 text-blue-400" />
        <span>VERIFIED PERFORMANCE</span>
      </span>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white leading-tight">
        Verified Commercial Results
      </h2>
      <p class="mt-4 text-base sm:text-lg text-slate-300 font-body leading-relaxed">
        Commercial milestones achieved across client accounts with 100% verified metrics.
      </p>
    </div>

    <!-- Metrics Grid -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        metrics.map((m, idx) => (
          <div
            class="reveal-on-scroll rounded-2xl border border-white/15 bg-slate-900/80 p-8 shadow-xl backdrop-blur-xl hover:border-blue-500/40 transition-all duration-300 flex flex-col justify-between group"
            data-reveal-delay={idx * 100}
          >
            <div>
              <div class="flex items-center justify-between mb-6">
                <div class="size-11 rounded-xl bg-blue-600/20 border border-blue-500/30 flex items-center justify-center text-blue-400 group-hover:scale-110 transition-transform">
                  <m.Icon class="size-5.5" />
                </div>
                <span class="text-[11px] font-mono text-slate-400 uppercase tracking-wider bg-white/5 px-2.5 py-1 rounded-md border border-white/10">
                  VERIFIED
                </span>
              </div>

              <!-- Oversized Counter Typography -->
              <div
                class="font-display text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white tracking-tight leading-none counter-value group-hover:text-blue-400 transition-colors"
                data-counter-target={m.target}
                data-counter-prefix={m.prefix}
                data-counter-suffix={m.suffix}
                data-counter-exact={m.exact}
              >
                {m.exact}
              </div>

              <h3 class="mt-4 font-display text-lg font-bold text-slate-100">
                {m.label}
              </h3>
              
              <p class="mt-2 text-sm text-slate-400 font-body leading-relaxed">
                {m.description}
              </p>
            </div>

            <div class="mt-8 pt-4 border-t border-white/10 flex items-center justify-between text-xs font-mono text-slate-400">
              <span>Performance Track</span>
              <span class="text-blue-400">Supported Metrics</span>
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>
