---
import { site } from '../../site.config';
import { 
  Sprout, 
  TrendingUp, 
  Wrench, 
  MapPin, 
  ArrowRight,
  ShoppingBag,
  HeartHandshake,
  ExternalLink
} from '@lucide/astro';
---

<section id="work" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div class="space-y-3">
        <span data-motion="scale-in" class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
          FEATURED WORK & CASE STUDIES
        </span>
        <!-- Sora 700 section heading: 31px mobile, 36px tablet, 44px desktop -->
        <h2 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
          Our featured projects
        </h2>
      </div>
      <div data-motion="pop-in" data-motion-delay="200">
        <a
          href={`${site.basePath}/work/`}
          class="inline-flex items-center gap-2 rounded-full border-2 border-[#061d33] bg-white px-7 py-3.5 font-body font-semibold text-[15px] text-[#061d33] hover:bg-[#ff762b] hover:border-[#ff762b] hover:text-white transition-all shadow-md group/cta"
        >
          <span>View all client work</span>
          <ArrowRight class="size-4 group-hover/cta:translate-x-1 transition-transform" />
        </a>
      </div>
    </div>

    <!-- 3 Large Image-Led Editorial Project Cards with Alternating Entrances -->
    <div class="space-y-16">
      
      <!-- PROJECT 1: BLACK GOLD FERTILIZER (Fade Left) -->
      <article data-motion="fade-left" data-motion-delay="0" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-12 lg:p-14 shadow-xl hover:shadow-2xl hover:-translate-y-1.5 transition-all duration-300 group">
        <div class="grid gap-12 lg:grid-cols-12 items-center">
          
          <div class="lg:col-span-6 space-y-6">
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-[#ff762b]/15 border border-[#ff762b]/30 px-4 py-1 text-[13px] sm:text-[14px] font-mono font-medium text-[#ff762b] uppercase tracking-[0.05em] group-hover:translate-x-0.5 transition-transform">
                E-COMMERCE & AGRICULTURE
              </span>
              <span class="text-[13px] font-mono font-medium text-slate-400">01 / FEATURED CASE</span>
            </div>

            <!-- Brand Logo & Title -->
            <div class="space-y-3">
              <img
                src={`${site.basePath}/brands/black-gold-fertilizer/logo.webp`}
                alt="Black Gold Fertilizer logo"
                width="200"
                height="56"
                loading="lazy"
                class="max-h-12 w-auto object-contain"
              />
              <!-- Project Title: Sora 700, 23px mobile, 28px desktop -->
              <h3 class="font-heading font-bold text-[23px] sm:text-[28px] text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-[1.2]">
                Black Gold Fertilizer
              </h3>
            </div>

            <!-- Project Result: Inter 400 16px -->
            <p class="text-base text-slate-700 font-body leading-[1.65] font-normal">
              Contributed to PKR 30M+ in delivered-order revenue and 29,000+ product sales across multiple product categories through managed digital campaigns.
            </p>

            <!-- Verified Metrics Badges (Pop-In) -->
            <div data-motion="pop-in" data-motion-delay="200" class="flex flex-wrap items-center gap-3 pt-2 font-body">
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#ff762b]/10 border border-[#ff762b]/30 px-4 py-2.5 text-[14px] font-semibold text-[#061d33]">
                <TrendingUp class="size-4 text-[#ff762b]" />
                <span>PKR 30M+ revenue supported</span>
              </div>
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#9a83f5]/10 border border-[#9a83f5]/30 px-4 py-2.5 text-[14px] font-semibold text-[#061d33]">
                <ShoppingBag class="size-4 text-[#9a83f5]" />
                <span>29,000+ product sales</span>
              </div>
            </div>

            <!-- Action Buttons: Case study, Official Website, Facebook -->
            <div class="flex flex-wrap items-center gap-3 pt-4 font-body">
              <a
                href={`${site.basePath}/work/black-gold-fertilizer/`}
                class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-7 py-3.5 text-sm font-semibold text-white shadow-md hover:bg-[#ff762b] transition-all"
              >
                <span>Read case study</span>
                <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
              </a>
              <a
                href="https://blackgoldfertilizer.com"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Black Gold Fertilizer official website"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-5 py-3.5 text-sm font-semibold text-[#061d33] hover:border-[#061d33] hover:bg-white transition-all shadow-xs"
              >
                <span>Visit Website</span>
                <ExternalLink class="size-3.5" />
              </a>
              <a
                href="https://www.facebook.com/profile.php?id=61561083447093"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Black Gold Fertilizer official Facebook page"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-5 py-3.5 text-sm font-semibold text-[#1877f2] hover:border-[#1877f2] hover:bg-white transition-all shadow-xs"
              >
                <img src={`${site.basePath}/platforms/facebook.svg`} alt="" class="size-3.5" />
                <span>Facebook</span>
              </a>
            </div>
          </div>

          <!-- Visual Side: Mask Clip-Left Reveal & Image Scale 1.04 -->
          <div data-motion="clip-left" data-motion-delay="150" class="lg:col-span-6">
            <div class="relative overflow-hidden rounded-2xl border-2 border-[#061d33]/15 bg-[#061d33] p-4 shadow-2xl font-body">
              <img
                src={`${site.basePath}/images/black-gold-official.png`}
                alt="Official Black Gold Fertilizer Product Packaging"
                width="640"
                height="400"
                loading="lazy"
                class="w-full h-[320px] rounded-xl object-contain bg-white/5 p-4 group-hover:scale-104 transition-transform duration-500"
              />
              <div class="absolute bottom-6 right-6 rounded-xl border border-white/20 bg-[#061d33]/90 p-4 backdrop-blur-md shadow-lg hidden sm:flex items-center gap-3 text-white">
                <Sprout class="size-6 text-[#39c98a] shrink-0" />
                <div>
                  <div class="text-[13px] font-body font-medium text-slate-300">Agriculture & E-Commerce</div>
                  <div class="text-sm font-semibold text-white">Multi-Category Product Growth</div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </article>

      <!-- PROJECT 2: WAJIB LIVESTOCK QURBANI CAMPAIGN (Fade Right) -->
      <article data-motion="fade-right" data-motion-delay="0" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-12 lg:p-14 shadow-xl hover:shadow-2xl hover:-translate-y-1.5 transition-all duration-300 group">
        <div class="grid gap-12 lg:grid-cols-12 items-center">
          
          <!-- Branded Colour Composition Visual Side -->
          <div data-motion="clip-left" data-motion-delay="150" class="lg:col-span-6 order-2 lg:order-1">
            <div class="relative overflow-hidden rounded-2xl border-2 border-[#061d33]/15 bg-[#061d33] p-8 sm:p-10 shadow-2xl flex flex-col justify-between min-h-[320px]">
              <div class="space-y-4">
                <span class="inline-block rounded-full bg-[#39c98a]/20 border border-[#39c98a]/40 px-4 py-1.5 text-[13px] sm:text-[14px] font-mono font-medium text-[#39c98a] uppercase tracking-[0.05em]">
                  Verified Outcome Summary
                </span>
                <h4 class="font-heading font-semibold text-[22px] sm:text-[25px] text-white leading-[1.2]">
                  Wajib Livestock Eid Qurbani
                </h4>
              </div>

              <div class="grid grid-cols-2 gap-4 pt-6 border-t border-white/10 font-body">
                <div class="rounded-xl bg-white/10 p-4 border border-white/10">
                  <span class="font-heading font-bold text-2xl sm:text-3xl text-[#ddff35] block">150+</span>
                  <span class="text-xs font-body font-semibold text-slate-200 uppercase">Animals Sold</span>
                </div>
                <div class="rounded-xl bg-white/10 p-4 border border-white/10">
                  <span class="font-heading font-bold text-2xl sm:text-3xl text-[#ff762b] block">PKR 4.2M+</span>
                  <span class="text-xs font-body font-semibold text-slate-200 uppercase">Sales Supported</span>
                </div>
              </div>
            </div>
          </div>

          <div class="lg:col-span-6 order-1 lg:order-2 space-y-6">
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-[#39c98a]/15 border border-[#39c98a]/30 px-4 py-1 text-[13px] sm:text-[14px] font-mono font-medium text-[#39c98a] uppercase tracking-[0.05em] group-hover:translate-x-0.5 transition-transform">
                LIVESTOCK & SEASONAL E-COMMERCE
              </span>
              <span class="text-[13px] font-mono font-medium text-slate-400">02 / FEATURED CASE</span>
            </div>

            <!-- Project Title: Sora 700, 23px mobile, 28px desktop -->
            <h3 class="font-heading font-bold text-[23px] sm:text-[28px] text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-[1.2]">
              Wajib Livestock Qurbani Campaign
            </h3>

            <p class="text-base text-slate-700 font-body leading-[1.65] font-normal">
              Helped sell more than 150 animals and supported PKR 4.2M+ in sales during the Eid Qurbani campaign.
            </p>

            <!-- Verified Metrics Badges -->
            <div data-motion="pop-in" data-motion-delay="150" class="flex flex-wrap items-center gap-3 pt-2 font-body">
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#ddff35]/20 border border-[#ddff35]/40 px-4 py-2.5 text-[14px] font-semibold text-[#061d33]">
                <HeartHandshake class="size-4 text-[#061d33]" />
                <span>More than 150 animals sold</span>
              </div>
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#ff762b]/10 border border-[#ff762b]/30 px-4 py-2.5 text-[14px] font-semibold text-[#061d33]">
                <TrendingUp class="size-4 text-[#ff762b]" />
                <span>PKR 4.2M+ sales supported</span>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-wrap items-center gap-3 pt-4 font-body">
              <a
                href={`${site.basePath}/work/qurbani-campaign/`}
                class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-7 py-3.5 text-sm font-semibold text-white shadow-md hover:bg-[#ff762b] transition-all"
              >
                <span>Read case study</span>
                <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
              </a>
              <a
                href="https://wajib.pk"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Wajib Livestock official website"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-5 py-3.5 text-sm font-semibold text-[#061d33] hover:border-[#061d33] hover:bg-white transition-all shadow-xs"
              >
                <span>Visit Website</span>
                <ExternalLink class="size-3.5" />
              </a>
              <a
                href="https://www.facebook.com/profile.php?id=61579219484606"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Wajib Livestock official Facebook page"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-5 py-3.5 text-sm font-semibold text-[#1877f2] hover:border-[#1877f2] hover:bg-white transition-all shadow-xs"
              >
                <img src={`${site.basePath}/platforms/facebook.svg`} alt="" class="size-3.5" />
                <span>Facebook</span>
              </a>
            </div>
          </div>

        </div>
      </article>

      <!-- PROJECT 3: RK RENO SOLUTIONS (Fade Left) -->
      <article data-motion="fade-left" data-motion-delay="0" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-8 sm:p-12 lg:p-14 shadow-xl hover:shadow-2xl hover:-translate-y-1.5 transition-all duration-300 group">
        <div class="grid gap-12 lg:grid-cols-12 items-center">
          
          <div class="lg:col-span-6 space-y-6">
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-[#9a83f5]/15 border border-[#9a83f5]/30 px-4 py-1 text-[13px] sm:text-[14px] font-mono font-medium text-[#9a83f5] uppercase tracking-[0.05em] group-hover:translate-x-0.5 transition-transform">
                RENOVATION & LOCAL SERVICES
              </span>
              <span class="text-[13px] font-mono font-medium text-slate-400">03 / FEATURED CASE</span>
            </div>

            <!-- Brand Logo & Title -->
            <div class="space-y-3">
              <img
                src={`${site.basePath}/brands/rk-reno-solutions/logo.webp`}
                alt="RK Reno Solutions logo"
                width="200"
                height="56"
                loading="lazy"
                class="max-h-12 w-auto object-contain"
              />
              <h3 class="font-heading font-bold text-[23px] sm:text-[28px] text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-[1.2]">
                RK Reno Solutions
              </h3>
            </div>

            <p class="text-base text-slate-700 font-body leading-[1.65] font-normal">
              Built a structured SEO foundation targeting renovation and air-conditioning services in Kuala Lumpur and Selangor.
            </p>

            <!-- Scope Badges -->
            <div data-motion="pop-in" data-motion-delay="350" class="flex flex-wrap items-center gap-3 pt-2 font-body">
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#061d33]/10 border border-[#061d33]/20 px-4 py-2.5 text-[14px] font-semibold text-[#061d33]">
                <MapPin class="size-4 text-[#ff762b]" />
                <span>Kuala Lumpur & Selangor SEO Scope</span>
              </div>
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#ff514b]/10 border border-[#ff514b]/30 px-4 py-2.5 text-[14px] font-semibold text-[#061d33]">
                <Wrench class="size-4 text-[#ff514b]" />
                <span>Renovation & HVAC Architecture</span>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-wrap items-center gap-3 pt-4 font-body">
              <a
                href={`${site.basePath}/work/rk-reno-solutions/`}
                class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-7 py-3.5 text-sm font-semibold text-white shadow-md hover:bg-[#ff762b] transition-all"
              >
                <span>Read case study</span>
                <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
              </a>
              <a
                href="https://rkrenosolution.com"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit RK Reno Solutions official website"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-5 py-3.5 text-sm font-semibold text-[#061d33] hover:border-[#061d33] hover:bg-white transition-all shadow-xs"
              >
                <span>Visit Website</span>
                <ExternalLink class="size-3.5" />
              </a>
            </div>
          </div>

          <!-- Visual Side: Genuine Website Screenshot from rkrenosolution.com -->
          <div data-motion="clip-left" data-motion-delay="300" class="lg:col-span-6">
            <div class="relative overflow-hidden rounded-2xl border-2 border-[#061d33]/15 bg-[#061d33] p-2.5 shadow-2xl font-body">
              <img
                src={`${site.basePath}/brands/rk-reno-solutions/screenshot.png`}
                alt="Genuine RK Reno Solutions Official Website Screenshot (rkrenosolution.com)"
                width="640"
                height="400"
                loading="lazy"
                class="w-full h-[320px] rounded-xl object-cover object-top group-hover:scale-104 transition-transform duration-500"
              />
              <div class="absolute bottom-6 right-6 rounded-xl border border-white/20 bg-[#061d33]/90 p-4 backdrop-blur-md shadow-lg hidden sm:flex items-center gap-3 text-white">
                <Wrench class="size-6 text-[#ddff35] shrink-0" />
                <div>
                  <div class="text-[13px] font-body font-medium text-slate-300">Renovation & Local Search</div>
                  <div class="text-sm font-semibold text-white">rkrenosolution.com</div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </article>

    </div>

  </div>
</section>

