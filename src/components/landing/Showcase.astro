---
import { site } from '../../site.config';
import { 
  Sprout, 
  TrendingUp, 
  Wrench, 
  MapPin, 
  ArrowRight,
  ShoppingBag,
  ExternalLink
} from '@lucide/astro';

interface Props {
  showAllWorkButton?: boolean;
}

const { showAllWorkButton = true } = Astro.props;
---

<section id="work" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33] border-b border-[#061d33]/10">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div class="space-y-3">
        <span data-motion="scale-in" class="text-xs font-medium font-mono uppercase tracking-[0.06em] text-[#ff762b] block">
          FEATURED WORK & CASE STUDIES
        </span>
        <!-- Sora 700 section heading: 31px mobile, 36px tablet, 44px desktop -->
        <h2 data-motion="clip-up" data-motion-delay="100" class="font-heading font-bold text-[31px] md:text-[36px] lg:text-[44px] text-[#061d33] leading-[1.15] tracking-[-0.025em]">
          Our featured projects
        </h2>
      </div>
      {showAllWorkButton && (
        <div data-motion="pop-in" data-motion-delay="200">
          <a
            href={`${site.basePath}/work/`}
            class="inline-flex items-center gap-2 rounded-full border-2 border-[#061d33] bg-white px-7 py-3.5 font-body font-semibold text-[15px] text-[#061d33] hover:bg-[#ff762b] hover:border-[#ff762b] hover:text-white transition-all shadow-md group/cta"
          >
            <span>View all client work</span>
            <ArrowRight class="size-4 group-hover/cta:translate-x-1 transition-transform" />
          </a>
        </div>
      )}
    </div>

    <!-- 3 Featured Case-Study Cards -->
    <div class="space-y-12">
      
      <!-- PROJECT 1: BLACK GOLD FERTILIZER -->
      <article data-motion="fade-left" data-motion-delay="0" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 sm:p-10 lg:p-12 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group">
        <div class="grid gap-8 lg:grid-cols-12 items-center">
          
          <div class="lg:col-span-6 space-y-5">
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-[#ff762b]/15 border border-[#ff762b]/30 px-3.5 py-1 text-xs font-mono font-bold text-[#ff762b] uppercase tracking-wider">
                AGRICULTURE
              </span>
              <span class="text-xs font-mono font-medium text-slate-400">01 / FEATURED CASE</span>
            </div>

            <!-- Brand Logo & Title -->
            <div class="space-y-2.5">
              <div class="h-14 w-44 rounded-xl bg-[#061d33] px-3 py-2 flex items-center justify-center border border-[#061d33]/20 shadow-xs">
                <img
                  src={`${site.basePath}/brands/black-gold-fertilizer/logo.webp`}
                  alt="Black Gold Fertilizer logo"
                  width="180"
                  height="48"
                  loading="lazy"
                  class="max-h-10 w-auto object-contain"
                />
              </div>
              <h3 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-tight">
                Black Gold Fertilizer
              </h3>
            </div>

            <!-- Summary -->
            <p class="text-base text-slate-700 font-body leading-relaxed font-normal">
              Contributed to PKR 30M+ in delivered-order revenue and 29,000+ product sales across multiple product categories through managed digital campaigns.
            </p>

            <!-- Verified Metrics Badges -->
            <div data-motion="pop-in" data-motion-delay="200" class="flex flex-wrap items-center gap-3 font-body">
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#ff762b]/10 border border-[#ff762b]/30 px-3.5 py-2 text-xs sm:text-sm font-semibold text-[#061d33]">
                <TrendingUp class="size-4 text-[#ff762b]" />
                <span>PKR 30M+ revenue supported</span>
              </div>
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#9a83f5]/10 border border-[#9a83f5]/30 px-3.5 py-2 text-xs sm:text-sm font-semibold text-[#061d33]">
                <ShoppingBag class="size-4 text-[#9a83f5]" />
                <span>29,000+ product sales</span>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-wrap items-center gap-3 pt-2 font-body">
              <a
                href={`${site.basePath}/work/black-gold-fertilizer/`}
                data-track="case-study-open"
                class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-6 py-3 text-xs sm:text-sm font-semibold text-white shadow-md hover:bg-[#ff762b] transition-all"
              >
                <span>Read case study</span>
                <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
              </a>
              <a
                href="https://blackgoldfertilizer.com"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Black Gold Fertilizer official website"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-4.5 py-3 text-xs sm:text-sm font-semibold text-[#061d33] hover:border-[#061d33] hover:bg-white transition-all shadow-xs"
              >
                <span>Visit Website</span>
                <ExternalLink class="size-3.5" />
              </a>
              <a
                href="https://www.facebook.com/profile.php?id=61561083447093"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit Black Gold Fertilizer official Facebook page"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-4.5 py-3 text-xs sm:text-sm font-semibold text-[#1877f2] hover:border-[#1877f2] hover:bg-white transition-all shadow-xs"
              >
                <img src={`${site.basePath}/platforms/facebook.svg`} alt="" class="size-3.5" />
                <span>Facebook</span>
              </a>
            </div>
          </div>

          <!-- Genuine Product Visual Frame -->
          <div class="lg:col-span-6">
            <div class="relative overflow-hidden rounded-2xl border-2 border-[#061d33]/15 bg-gradient-to-br from-[#061d33] to-[#0d3459] p-3 shadow-xl font-body">
              <picture>
                <source srcset={`${site.basePath}/images/black-gold-official.avif`} type="image/avif" />
                <source srcset={`${site.basePath}/images/black-gold-official-sm.webp`} type="image/webp" />
                <img
                  src={`${site.basePath}/images/black-gold-official.png`}
                  alt="Official Black Gold Fertilizer Product Packaging"
                  width="640"
                  height="400"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-[280px] sm:h-[320px] rounded-xl object-contain bg-white/10 p-4 group-hover:scale-103 transition-transform duration-500"
                />
              </picture>
              <div class="absolute bottom-5 right-5 rounded-xl border border-white/20 bg-[#061d33]/90 px-3.5 py-2.5 backdrop-blur-md shadow-lg hidden sm:flex items-center gap-2.5 text-white">
                <Sprout class="size-5 text-[#39c98a] shrink-0" />
                <div>
                  <div class="text-xs font-body font-medium text-slate-300">Agriculture E-Commerce</div>
                  <div class="text-xs font-semibold text-white">Genuine Product Line</div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </article>

      <!-- PROJECT 2: WAJIB LIVESTOCK QURBANI CAMPAIGN (Compact Text-Led Case Study Card) -->
      <article data-motion="fade-right" data-motion-delay="0" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 sm:p-10 lg:p-12 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group">
        <div class="space-y-6">
          
          <div class="flex flex-wrap items-center justify-between gap-4 pb-4 border-b border-slate-100">
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-[#39c98a]/15 border border-[#39c98a]/30 px-3.5 py-1 text-xs font-mono font-bold text-[#2e9e6c] uppercase tracking-wider">
                LIVESTOCK
              </span>
              <span class="text-xs font-mono font-medium text-slate-400">02 / FEATURED CASE</span>
            </div>

            <!-- Dark Navy Container for White Logo -->
            <div class="h-12 w-40 rounded-xl bg-[#061d33] px-3 py-2 flex items-center justify-center border border-[#061d33]/20 shadow-xs">
              <img 
                src={`${site.basePath}/brands/wajib-livestock/logo.webp`}
                alt="Wajib Livestock logo"
                width="140"
                height="40"
                loading="lazy"
                class="max-h-8 w-auto object-contain"
              />
            </div>
          </div>

          <div class="grid gap-8 lg:grid-cols-12 items-center">
            <div class="lg:col-span-7 space-y-4">
              <h3 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-tight">
                Wajib Livestock Qurbani Campaign
              </h3>
              <p class="text-base text-slate-700 font-body leading-relaxed font-normal">
                Supported seasonal Qurbani marketing through paid social advertising, lead generation, campaign creative, WhatsApp routing, and digital sales support.
              </p>
            </div>

            <!-- Compact Metrics Grid (Replaces Empty Image Area) -->
            <div class="lg:col-span-5 grid grid-cols-2 gap-4 bg-[#f7f4ed] p-5 rounded-2xl border border-slate-200">
              <div class="space-y-1">
                <span class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33] block">150+</span>
                <span class="text-xs font-body font-semibold text-slate-600 uppercase tracking-wide">Animals Sold</span>
              </div>
              <div class="space-y-1">
                <span class="font-heading font-bold text-2xl sm:text-3xl text-[#ff762b] block">PKR 4.2M+</span>
                <span class="text-xs font-body font-semibold text-slate-600 uppercase tracking-wide">Sales Supported</span>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-wrap items-center gap-3 pt-2 border-t border-slate-100 font-body">
            <a
              href={`${site.basePath}/work/qurbani-campaign/`}
              data-track="case-study-open"
              class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-6 py-3 text-xs sm:text-sm font-semibold text-white shadow-md hover:bg-[#ff762b] transition-all"
            >
              <span>Read case study</span>
              <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
            </a>
            <a
              href="https://wajib.pk"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit Wajib Livestock official website"
              class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-4.5 py-3 text-xs sm:text-sm font-semibold text-[#061d33] hover:border-[#061d33] hover:bg-white transition-all shadow-xs"
            >
              <span>Visit Website</span>
              <ExternalLink class="size-3.5" />
            </a>
            <a
              href="https://www.facebook.com/profile.php?id=61579219484606"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Visit Wajib Livestock official Facebook page"
              class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-4.5 py-3 text-xs sm:text-sm font-semibold text-[#1877f2] hover:border-[#1877f2] hover:bg-white transition-all shadow-xs"
            >
              <img src={`${site.basePath}/platforms/facebook.svg`} alt="" class="size-3.5" />
              <span>Facebook</span>
            </a>
          </div>

        </div>
      </article>

      <!-- PROJECT 3: RK RENO SOLUTIONS -->
      <article data-motion="fade-left" data-motion-delay="0" class="rounded-3xl border-2 border-[#061d33]/15 bg-white p-7 sm:p-10 lg:p-12 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 group">
        <div class="grid gap-8 lg:grid-cols-12 items-center">
          
          <div class="lg:col-span-6 space-y-5">
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-[#9a83f5]/15 border border-[#9a83f5]/30 px-3.5 py-1 text-xs font-mono font-bold text-[#7352eb] uppercase tracking-wider">
                RENOVATION
              </span>
              <span class="text-xs font-mono font-medium text-slate-400">03 / FEATURED CASE</span>
            </div>

            <!-- Brand Logo & Title -->
            <div class="space-y-2.5">
              <div class="h-14 w-44 rounded-xl bg-white p-2 flex items-center border border-slate-200 shadow-xs">
                <img
                  src={`${site.basePath}/brands/rk-reno-solutions/logo.webp`}
                  alt="RK Reno Solutions logo"
                  width="180"
                  height="48"
                  loading="lazy"
                  class="max-h-10 w-auto object-contain"
                />
              </div>
              <h3 class="font-heading font-bold text-2xl sm:text-3xl text-[#061d33] group-hover:text-[#ff762b] transition-colors leading-tight">
                RK Reno Solutions
              </h3>
            </div>

            <p class="text-base text-slate-700 font-body leading-relaxed font-normal">
              Built a structured SEO foundation targeting renovation and air-conditioning services in Kuala Lumpur and Selangor.
            </p>

            <!-- Scope Badges -->
            <div data-motion="pop-in" data-motion-delay="350" class="flex flex-wrap items-center gap-3 font-body">
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#061d33]/10 border border-[#061d33]/20 px-3.5 py-2 text-xs sm:text-sm font-semibold text-[#061d33]">
                <MapPin class="size-4 text-[#ff762b]" />
                <span>Kuala Lumpur & Selangor SEO Scope</span>
              </div>
              <div class="inline-flex items-center gap-2 rounded-xl bg-[#ff514b]/10 border border-[#ff514b]/30 px-3.5 py-2 text-xs sm:text-sm font-semibold text-[#061d33]">
                <Wrench class="size-4 text-[#ff514b]" />
                <span>Renovation & HVAC Architecture</span>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-wrap items-center gap-3 pt-2 font-body">
              <a
                href={`${site.basePath}/work/rk-reno-solutions/`}
                data-track="case-study-open"
                class="inline-flex items-center gap-2 rounded-full bg-[#061d33] px-6 py-3 text-xs sm:text-sm font-semibold text-white shadow-md hover:bg-[#ff762b] transition-all"
              >
                <span>Read case study</span>
                <ArrowRight class="size-4 group-hover:translate-x-1 transition-transform" />
              </a>
              <a
                href="https://rkrenosolution.com"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Visit RK Reno Solutions official website"
                class="inline-flex items-center gap-1.5 rounded-full border border-slate-300 bg-[#f7f4ed] px-4.5 py-3 text-xs sm:text-sm font-semibold text-[#061d33] hover:border-[#061d33] hover:bg-white transition-all shadow-xs"
              >
                <span>Visit Website</span>
                <ExternalLink class="size-3.5" />
              </a>
            </div>
          </div>

          <!-- Genuine Website Screenshot Visual -->
          <div class="lg:col-span-6">
            <div class="relative overflow-hidden rounded-2xl border-2 border-[#061d33]/15 bg-slate-900 p-2.5 shadow-xl font-body">
              <!-- Browser Bar Mock -->
              <div class="flex items-center gap-1.5 pb-2 px-2 border-b border-slate-800 mb-1.5">
                <div class="size-2.5 rounded-full bg-red-500/80"></div>
                <div class="size-2.5 rounded-full bg-yellow-500/80"></div>
                <div class="size-2.5 rounded-full bg-green-500/80"></div>
                <span class="text-[11px] font-mono text-slate-400 ml-2">rkrenosolution.com</span>
              </div>
              <picture>
                <source srcset={`${site.basePath}/brands/rk-reno-solutions/screenshot.webp`} type="image/webp" />
                <img
                  src={`${site.basePath}/brands/rk-reno-solutions/screenshot.png`}
                  alt="Genuine RK Reno Solutions Official Website Screenshot (rkrenosolution.com)"
                  width="640"
                  height="400"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-[280px] sm:h-[320px] rounded-xl object-cover object-top group-hover:scale-103 transition-transform duration-500"
                />
              </picture>
            </div>
          </div>

        </div>
      </article>

    </div>

  </div>
</section>

