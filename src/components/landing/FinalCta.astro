---
import { site } from '../../site.config';
import { ArrowRight, MessageSquare, Sparkles } from '@lucide/astro';

const stickers = [
  'PAID ADVERTISING',
  'WEBSITES & SEO',
  'AI MARKETING SYSTEMS',
  'VERIFIED RESULTS'
];
---

<section id="contact" class="py-20 lg:py-28 bg-[#f7f4ed] text-[#061d33]">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Rounded Navy CTA Block -->
    <div class="reveal-on-scroll relative overflow-hidden rounded-[40px] bg-[#061d33] text-white p-10 sm:p-16 lg:p-20 shadow-2xl text-center">
      
      <!-- Decorative Sticker Chips Row -->
      <div class="flex flex-wrap items-center justify-center gap-3 mb-8">
        {stickers.map((sticker) => (
          <span class="inline-flex items-center gap-1.5 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-mono font-extrabold uppercase tracking-widest text-[#ddff35] backdrop-blur-md">
            <Sparkles class="size-3.5 text-[#ddff35]" />
            <span>{sticker}</span>
          </span>
        ))}
      </div>

      <div class="relative z-10 max-w-4xl mx-auto space-y-8">
        
        <h2 class="font-display text-4xl sm:text-6xl lg:text-7xl font-black uppercase leading-tight tracking-tight text-white">
          READY TO BUILD STRONGER DIGITAL GROWTH?
        </h2>

        <p class="text-base sm:text-xl leading-relaxed text-slate-200 font-body max-w-2xl mx-auto font-medium">
          Speak directly with our team to review your paid campaigns, website conversion architecture and growth opportunities.
        </p>

        <!-- Buttons -->
        <div class="flex flex-wrap items-center justify-center gap-5 pt-4">
          <a
            href={`mailto:${site.contact.email}`}
            class="group inline-flex items-center gap-3 rounded-full bg-[#ddff35] px-9 py-4 font-display text-lg font-bold text-[#061d33] shadow-xl hover:bg-[#c9eb1e] hover:shadow-2xl hover:-translate-y-1 transition-all"
          >
            <span>Discuss Your Project</span>
            <ArrowRight class="size-5 text-[#061d33] group-hover:translate-x-1 transition-transform" />
          </a>
          
          <a
            href={site.contact.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-full bg-[#39c98a] px-9 py-4 font-display text-lg font-bold text-white shadow-xl hover:bg-[#32b57c] hover:shadow-2xl hover:-translate-y-1 transition-all"
          >
            <MessageSquare class="size-5 text-white" />
            <span>Chat on WhatsApp</span>
          </a>
        </div>

        <!-- Contact Quick Details -->
        <div class="pt-6 text-xs sm:text-sm font-mono text-slate-300">
          Email: <a href={`mailto:${site.contact.email}`} class="text-white underline hover:text-[#ddff35]">{site.contact.email}</a>
          <span class="mx-3 text-slate-500">|</span>
          WhatsApp: <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="text-white underline hover:text-[#39c98a]">{site.contact.phone}</a>
        </div>

      </div>

    </div>

  </div>
</section>
