---
import { site } from '../../site.config';
import { ArrowRight, MessageSquare, Sparkles } from '@lucide/astro';
---

<section id="contact" class="relative py-24 bg-[#090d16] text-white border-b border-white/10 overflow-hidden">
  <!-- Radial Glow Backdrop Overlay -->
  <div class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[700px] rounded-full bg-blue-600/15 blur-[150px]"></div>

  <div class="relative mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Hero Container Card -->
    <div class="reveal-on-scroll relative overflow-hidden rounded-3xl border border-white/15 bg-slate-900/90 p-10 sm:p-16 lg:p-20 shadow-2xl text-center backdrop-blur-xl">
      <!-- Grid Texture -->
      <div class="pointer-events-none absolute inset-0 bg-grid-pattern opacity-30"></div>

      <div class="relative z-10 max-w-3xl mx-auto space-y-8">
        
        <span class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-xs font-bold font-mono uppercase tracking-wider text-blue-400">
          <Sparkles class="size-3.5 text-blue-400" />
          <span>START YOUR GROWTH STRATEGY</span>
        </span>

        <h2 class="font-display text-3xl sm:text-4xl lg:text-6xl font-bold tracking-tight text-white leading-tight">
          Ready to build stronger digital growth?
        </h2>

        <p class="text-base sm:text-xl leading-relaxed text-slate-300 font-body max-w-2xl mx-auto">
          Speak directly with our team to review your paid campaigns, website conversion architecture and growth opportunities.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center justify-center gap-4 pt-4">
          <a
            href={`mailto:${site.contact.email}`}
            class="group inline-flex items-center gap-2.5 rounded-full bg-blue-600 px-8 py-4 font-display text-base font-bold text-white shadow-xl shadow-blue-600/30 hover:bg-blue-500 hover:shadow-blue-500/40 hover:-translate-y-0.5 transition-all"
          >
            <span>Discuss Your Project</span>
            <ArrowRight class="size-5 text-white group-hover:translate-x-1 transition-transform" />
          </a>
          
          <a
            href={site.contact.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 rounded-full border border-emerald-500/40 bg-emerald-500/10 px-8 py-4 font-display text-base font-bold text-emerald-400 hover:bg-emerald-500/20 hover:border-emerald-500/60 transition-all backdrop-blur-sm"
          >
            <MessageSquare class="size-5 text-emerald-400" />
            <span>Chat on WhatsApp</span>
          </a>
        </div>

        <!-- Contact Quick Details -->
        <div class="pt-6 text-xs sm:text-sm font-mono text-slate-400">
          Email: <a href={`mailto:${site.contact.email}`} class="text-slate-200 underline hover:text-blue-400">{site.contact.email}</a>
          <span class="mx-3 text-slate-600">|</span>
          WhatsApp: <a href={site.contact.whatsapp} target="_blank" rel="noopener noreferrer" class="text-slate-200 underline hover:text-emerald-400">{site.contact.phone}</a>
        </div>

      </div>

    </div>

  </div>
</section>
