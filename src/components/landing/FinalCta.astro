---
import { site } from '../../site.config';
---

<section id="contact" class="relative overflow-hidden bg-linear-160 from-navy to-navy-deep text-cloud">
  <!-- Orbit Stickers -->
  <span class="absolute top-7.5 right-[12%] text-[30px] text-orange pointer-events-none" aria-hidden="true">✦</span>
  <span class="absolute bottom-10 left-[10%] size-[22px] rotate-[15deg] rounded-md bg-orange pointer-events-none" aria-hidden="true"></span>
  <span class="absolute top-15 left-[20%] size-3.5 rounded-full bg-cloud opacity-50 pointer-events-none" aria-hidden="true"></span>

  <div class="relative z-2 mx-auto max-w-[820px] px-6 sm:px-8 py-[90px] text-center">
    <h2 class="font-display text-3xl sm:text-4xl lg:text-[52px] font-bold tracking-[-0.02em] text-cloud leading-tight">
      Ready to build stronger digital growth?
    </h2>
    <p class="mx-auto mt-4.5 max-w-[520px] text-lg sm:text-[19px] text-sky-mist font-body">
      Speak directly with our team to review your paid ad campaigns, website conversion architecture, and search opportunities.
    </p>
    <div class="mt-8.5 flex flex-wrap justify-center gap-3.5">
      <a
        href={`mailto:${site.contact.email}`}
        class="rounded-full bg-orange px-8 py-4 font-bold text-cloud shadow-pop-white transition-transform hover:-translate-x-0.5 hover:-translate-y-0.5"
      >
        Discuss Your Project →
      </a>
      <a
        href={site.contact.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full border-2 border-white/50 bg-transparent px-8 py-4 font-bold text-cloud transition-colors hover:bg-white/10"
      >
        Chat on WhatsApp
      </a>
    </div>
  </div>
</section>
