---
import { processData } from '../../data/process';
import { Workflow, ArrowRight } from '@lucide/astro';
---

<section id="process" class="py-20 bg-[#f8fafc] border-b border-slate-200/80 text-slate-900 overflow-hidden">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="inline-flex items-center gap-2 text-xs font-bold font-mono uppercase tracking-widest text-blue-600 mb-2">
        <Workflow class="size-3.5 text-blue-600" />
        <span>EXECUTION FRAMEWORK</span>
      </span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">
        A Continuous Growth Journey
      </h2>
      <p class="mt-3 text-base text-slate-600 font-body leading-relaxed">
        Six disciplined phases designed to eliminate guesswork and turn strategy into measurable business outcomes.
      </p>
    </div>

    <!-- Desktop: Continuous Horizontal Connected Journey (6 Steps) -->
    <div class="hidden lg:block relative">
      <!-- Strong Gradient Journey Line passing behind all nodes -->
      <div class="absolute top-10 left-12 right-12 h-1.5 bg-gradient-to-r from-blue-600 via-blue-500 to-indigo-600 rounded-full z-0"></div>

      <div class="grid grid-cols-6 gap-4 relative z-10">
        {
          processData.map((p, idx) => (
            <div
              class="reveal-on-scroll rounded-2xl border border-slate-200 bg-white p-6 shadow-md hover:shadow-xl hover:border-blue-500/60 transition-all duration-200 flex flex-col justify-between group"
              data-reveal-delay={idx * 60}
            >
              <div>
                <!-- Node Step Badge -->
                <div class="size-12 rounded-xl bg-slate-900 border-2 border-blue-500 text-white font-mono font-extrabold text-base flex items-center justify-center mb-5 group-hover:bg-blue-600 group-hover:border-blue-400 transition-colors shadow-sm">
                  {p.step}
                </div>

                <h3 class="font-display font-bold text-xl text-slate-900 group-hover:text-blue-600 transition-colors mb-2.5 leading-snug">
                  {p.title}
                </h3>
                
                <p class="text-sm text-slate-600 font-body leading-relaxed">
                  {p.description}
                </p>
              </div>

              <div class="mt-6 pt-3 border-t border-slate-100 flex items-center justify-between text-xs font-mono font-bold text-slate-400">
                <span>Phase {p.step}</span>
                {idx < processData.length - 1 && (
                  <ArrowRight class="size-3.5 text-blue-500 group-hover:translate-x-1 transition-transform" />
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Mobile & Tablet: Continuous Vertical Journey Timeline -->
    <div class="lg:hidden relative pl-8 border-l-4 border-blue-600/40 space-y-6">
      {
        processData.map((p, idx) => (
          <div
            class="reveal-on-scroll relative rounded-2xl border border-slate-200 bg-white p-6 shadow-sm group"
            data-reveal-delay={idx * 50}
          >
            <!-- Timeline Node Indicator -->
            <div class="absolute -left-[43px] top-6 size-5 rounded-full border-4 border-blue-600 bg-white shadow-sm"></div>

            <div class="flex items-center gap-3 mb-2">
              <span class="text-xs font-mono font-extrabold text-blue-600 bg-blue-50 border border-blue-200 px-3 py-1 rounded-md">
                PHASE {p.step}
              </span>
              <h3 class="font-display font-bold text-xl text-slate-900">
                {p.title}
              </h3>
            </div>

            <p class="text-sm sm:text-base text-slate-600 font-body leading-relaxed">
              {p.description}
            </p>
          </div>
        ))
      }
    </div>

  </div>
</section>
