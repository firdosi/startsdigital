---
interface Props {
  eyebrow: string;
  title: string;
  sub?: string;
  on?: 'dark' | 'light' | 'orange' | 'navy';
  class?: string;
}
const { eyebrow, title, sub, on = 'dark', class: className = 'max-w-[640px] mb-12' } = Astro.props;
const isDark = on === 'dark' || on === 'navy';
---

<div class:list={['mx-auto text-center space-y-3', className]}>
  <span
    class:list={[
      'text-xs font-medium font-mono tracking-[0.06em] uppercase block',
      isDark ? 'text-[#ddff35]' : 'text-[#ff762b]',
    ]}>{eyebrow}</span
  >
  <h2
    class:list={[
      'font-heading font-bold text-[28px] sm:text-[36px] lg:text-[44px] leading-[1.12] tracking-[-0.025em]',
      isDark ? 'text-white' : 'text-[#061d33]',
    ]}
  >
    {title}
  </h2>
  {
    sub && (
      <p
        class:list={[
          'text-base sm:text-lg font-body leading-[1.65] font-normal max-w-2xl mx-auto',
          isDark ? 'text-slate-300' : 'text-slate-700',
        ]}
      >
        {sub}
      </p>
    )
  }
</div>
