---
interface Props {
  eyebrow: string;
  title: string;
  sub?: string;
  on?: 'dark' | 'light' | 'orange' | 'navy';
  class?: string;
}
const { eyebrow, title, sub, on = 'dark', class: className = 'max-w-[640px] mb-12' } = Astro.props;
const isDark = on === 'dark' || on === 'navy';
---

<div class:list={['mx-auto text-center', className]}>
  <span
    class:list={[
      'text-xs font-bold font-mono tracking-widest uppercase',
      isDark ? 'text-blue-400' : 'text-blue-600',
    ]}>{eyebrow}</span
  >
  <h2
    class:list={[
      'mt-2.5 text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight',
      isDark ? 'text-white' : 'text-slate-900',
    ]}
  >
    {title}
  </h2>
  {
    sub && (
      <p
        class:list={[
          'mt-3.5 text-base sm:text-lg font-body leading-relaxed',
          isDark ? 'text-slate-300' : 'text-slate-600',
        ]}
      >
        {sub}
      </p>
    )
  }
</div>
