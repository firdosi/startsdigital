---
import Container from '../ui/Container.astro';

const metrics = [
  {
    value: 'PKR 30M+',
    label: 'Revenue Supported',
    sublabel: 'E-commerce and consumer product campaigns',
  },
  {
    value: '29,000+',
    label: 'Product Sales',
    sublabel: 'Individual product units delivered across categories',
  },
  {
    value: 'PKR 4.2M+',
    label: 'Qurbani Sales',
    sublabel: 'Seasonal livestock campaign sales generated',
  },
  {
    value: '150+',
    label: 'Animals Sold',
    sublabel: 'Direct livestock sales closed via video marketing',
  },
];
---

<section class="py-24 md:py-36 bg-brand-navy text-white relative overflow-hidden border-y border-white/10">
  <!-- Subtle Background Glow Elements -->
  <div class="absolute -top-24 -left-24 w-96 h-96 bg-brand-blue/15 rounded-full blur-3xl" aria-hidden="true"></div>
  <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-brand-teal/15 rounded-full blur-3xl" aria-hidden="true"></div>

  <Container class="space-y-16 relative z-10">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <span class="text-xs font-extrabold tracking-[0.2em] text-brand-teal uppercase font-heading bg-brand-teal/10 px-3.5 py-1.5 rounded-md">
        VERIFIED COMMERCIAL IMPACT
      </span>
      <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-extrabold text-white">
        Commercial Performance Figures
      </h2>
      <p class="font-body text-base text-brand-muted-dark leading-relaxed">
        We track our performance against real commercial outcomes delivered across client campaigns.
      </p>
    </div>

    <!-- Wide Editorial Metric Layout (Dividers instead of 4 standard cards) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 divide-y sm:divide-y-0 sm:divide-x divide-white/10 pt-4">
      {metrics.map((item, idx) => (
        <div class={`space-y-3 ${idx !== 0 ? 'pt-6 sm:pt-0 sm:pl-8' : ''}`}>
          <span class="font-heading text-4xl sm:text-5xl font-extrabold text-brand-blue tracking-tight block">
            {item.value}
          </span>
          <h3 class="font-heading text-lg font-bold text-white">
            {item.label}
          </h3>
          <p class="font-body text-sm text-brand-muted-dark leading-relaxed">
            {item.sublabel}
          </p>
        </div>
      ))}
    </div>
  </Container>
</section>
