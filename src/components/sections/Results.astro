---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { resultsData } from '../../data/results';
---

<section id="results" class="bg-brand-white text-brand-black py-20 md:py-28 scroll-mt-20">
  <Container class="space-y-12 md:space-y-16">
    <SectionHeading
      eyebrow="REAL WORK. MEASURABLE OUTCOMES."
      title="Marketing decisions backed by practical execution."
      description="Our experience covers digital campaigns, e-commerce, lead generation, websites, SEO and AI-powered content across multiple industries."
      theme="light"
    />

    <!-- Metrics Strip Grid: 2-column mobile layout, 4-column desktop layout -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10 sm:gap-8 pt-10 border-t border-brand-grey/25">
      {
        resultsData.map((item) => (
          <div class="flex flex-col space-y-2">
            <span class="font-heading text-5xl sm:text-6xl font-bold tracking-tight text-brand-blue leading-none">
              {item.value}
            </span>
            <p class="font-body text-base font-normal text-brand-text leading-snug">
              {item.wording}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
