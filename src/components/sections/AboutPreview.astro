---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="about" class="bg-brand-navy text-brand-white py-20 md:py-28 scroll-mt-20">
  <Container class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
    <!-- Left Column: Headings -->
    <div class="lg:col-span-6">
      <SectionHeading
        eyebrow="ABOUT STARTS DIGITAL"
        title="Built from hands-on experience across marketing, websites and business growth."
        theme="dark"
      />
    </div>

    <!-- Right Column: Strategic Pitch split copy & label -->
    <div class="lg:col-span-6">
      <div class="border-t border-brand-grey/10 pt-6 lg:border-t-0 lg:pt-0 space-y-6">
        <span class="block text-xs font-bold tracking-[0.25em] text-brand-teal uppercase font-heading">
          MARKETING &plus; TECHNOLOGY &plus; EXECUTION
        </span>
        <div class="space-y-4">
          <p class="font-body text-base sm:text-lg font-normal text-brand-muted-dark leading-relaxed">
            Starts Digital is an AI-powered digital marketing agency combining strategy, advertising, SEO, website development, creative content and practical automation.
          </p>
          <p class="font-body text-base sm:text-lg font-normal text-brand-muted-dark leading-relaxed">
            Our approach connects marketing decisions with real implementation, helping businesses strengthen their digital presence without managing several disconnected providers.
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>
