---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';

const faqs = [
  {
    question: "What specific industries and business types do you work with?",
    answer: "We specialize in growth-stage e-commerce brands, agricultural suppliers, seasonal retail (such as Qurbani campaigns), local service contractors (renovation & HVAC), and professional services across Pakistan, Malaysia, and the Gulf region."
  },
  {
    question: "How do you track commercial results instead of vanity metrics?",
    answer: "We set up clean conversion tracking via Meta Pixel, Conversions API (CAPI), and Google Analytics 4. We measure success on actual bank revenue, cost-per-lead, and customer acquisition cost—not impressions or clicks."
  },
  {
    question: "What is your typical project timeframe?",
    answer: "Media campaigns and lead generation funnels can launch within 7–10 days after strategy approval. Custom website builds and SEO architectures typically take 2 to 4 weeks depending on scope."
  },
  {
    question: "Can Starts Digital manage our complete digital marketing end-to-end?",
    answer: "Yes. Our single-point operating model handles media buying, creative ad design, landing page engineering, conversion rate optimization, and technical SEO as one unified system."
  }
];
---

<section class="py-20 md:py-32 bg-slate-950 text-white border-b border-white/10 relative">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <!-- Left Column: Title & Quick Consultation Card (5 Cols) -->
      <div class="lg:col-span-5 space-y-6">
        <span class="inline-flex items-center gap-2 text-xs font-extrabold tracking-[0.2em] text-teal-400 uppercase font-heading bg-teal-500/10 px-3.5 py-1.5 rounded-full border border-teal-500/20">
          CLEAR ANSWERS
        </span>

        <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-white leading-tight">
          Frequently asked questions about working with us.
        </h2>

        <p class="text-slate-300 text-base leading-relaxed">
          Everything you need to know about our single-point operating model, media management, and technical standards.
        </p>

        <!-- Direct Consult Prompt Card -->
        <div class="p-6 rounded-2xl bg-gradient-to-br from-slate-900 to-slate-950 border border-blue-500/20 space-y-4">
          <h3 class="font-heading text-lg font-bold text-white">Have a specific question?</h3>
          <p class="text-slate-300 text-xs leading-relaxed">Speak directly with our digital team on WhatsApp for an immediate assessment of your commercial goals.</p>
          <Button 
            href={siteConfig.links.whatsapp} 
            variant="secondary"
            class="w-full text-center py-2.5 font-bold text-xs !bg-teal-600 hover:!bg-teal-500 !text-white border-0"
          >
            Ask on WhatsApp
          </Button>
        </div>
      </div>

      <!-- Right Column: Accordion Items (7 Cols) -->
      <div class="lg:col-span-7 space-y-4">
        {
          faqs.map((faq) => (
            <details 
              class="group rounded-2xl bg-slate-900/80 border border-white/10 p-6 [&_summary::-webkit-details-marker]:hidden transition-all duration-300 open:bg-slate-900 open:border-blue-500/30"
            >
              <summary class="flex cursor-pointer items-center justify-between font-heading text-lg font-bold text-white group-hover:text-blue-300 transition-colors focus:outline-none">
                <span>{faq.question}</span>
                <span class="ml-4 shrink-0 transition-transform duration-300 group-open:-rotate-180 text-blue-400">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </span>
              </summary>

              <div class="mt-4 text-slate-300 text-sm leading-relaxed border-t border-white/10 pt-4">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </Container>
</section>
