---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { getAssetPath } from '../../data/site';
---

<section id="work" class="py-20 md:py-32 bg-slate-950 text-white border-b border-white/10 relative">
  <Container>
    <SectionHeading
      eyebrow="FEATURED CASE STUDIES"
      title="Commercial execution with verified business impact."
      description="Detailed breakdowns of how our digital campaigns, technical architecture, and creative strategy deliver measurable client growth."
      class="mb-20 dark-theme"
    />

    <div class="space-y-24">
      
      <!-- CASE STUDY 1: Black Gold Fertilizer -->
      <article class="rounded-3xl bg-gradient-to-br from-slate-900 via-slate-900/90 to-blue-950/40 border border-blue-500/20 p-8 sm:p-12 shadow-2xl relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl group-hover:bg-blue-500/20 transition-all pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
          <!-- Copy & Stats (7 Cols) -->
          <div class="lg:col-span-7 space-y-6">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono font-bold tracking-widest text-blue-400 uppercase bg-blue-500/10 border border-blue-500/20 px-3 py-1 rounded-full">
                AGRICULTURE & E-COMMERCE
              </span>
              <span class="text-xs font-mono text-slate-400">Scale Case Study</span>
            </div>

            <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
              Black Gold Fertilizer
            </h3>

            <p class="text-slate-300 text-base sm:text-lg leading-relaxed max-w-xl">
              Scalable e-commerce acquisition strategy combining targeted Meta ad funnels, high-converting creative variations, and streamlined checkout optimization.
            </p>

            <!-- Oversized Result Numbers -->
            <div class="pt-4 grid grid-cols-2 gap-6 border-t border-white/10">
              <div>
                <span class="block font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-blue-400">PKR 30M+</span>
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-1 block">Revenue Supported</span>
              </div>
              <div>
                <span class="block font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-teal-400">29,000+</span>
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-1 block">Product Orders Delivered</span>
              </div>
            </div>

            <!-- Tags & Action -->
            <div class="pt-4 flex flex-wrap items-center gap-3">
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">Meta Advertising</span>
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">E-Commerce Strategy</span>
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">Creative Testing</span>
            </div>

            <div class="pt-2">
              <a
                href={`${getAssetPath('/work/black-gold-fertilizer/')}`}
                class="inline-flex items-center gap-2 font-bold text-sm text-blue-400 hover:text-blue-300 transition-colors group/link"
              >
                <span>Read Full Case Study</span>
                <svg class="w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Custom Decorative Code Graphic (5 Cols) -->
          <div class="lg:col-span-5">
            <div class="p-6 rounded-2xl bg-slate-950/80 border border-white/10 space-y-4 font-mono text-xs shadow-inner">
              <div class="flex items-center justify-between text-slate-500 border-b border-white/10 pb-3">
                <span>// CAMPAIGN_ARCHITECTURE</span>
                <span class="text-blue-400">ACTIVE</span>
              </div>
              
              <div class="space-y-2 text-slate-300">
                <div class="flex justify-between">
                  <span class="text-slate-400">Targeting:</span>
                  <span class="text-white">Commercial Farming & Retail</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Funnel Type:</span>
                  <span class="text-teal-400">Direct-to-Consumer Purchase</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Creative Formats:</span>
                  <span class="text-indigo-400">Product Video & Carousel</span>
                </div>
              </div>

              <!-- Animated Micro Metric Box -->
              <div class="p-4 rounded-xl bg-blue-950/40 border border-blue-500/30 flex items-center justify-between">
                <div>
                  <span class="text-[10px] text-blue-300 uppercase block">Scale Multiplier</span>
                  <span class="text-lg font-bold text-white">Consistent High ROAS</span>
                </div>
                <span class="w-3 h-3 rounded-full bg-blue-400 animate-ping"></span>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- CASE STUDY 2: Wajib Livestock Qurbani Campaign -->
      <article class="rounded-3xl bg-gradient-to-br from-slate-900 via-slate-900/90 to-teal-950/40 border border-teal-500/20 p-8 sm:p-12 shadow-2xl relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl group-hover:bg-teal-500/20 transition-all pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
          <!-- Copy & Stats (7 Cols) -->
          <div class="lg:col-span-7 space-y-6">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono font-bold tracking-widest text-teal-400 uppercase bg-teal-500/10 border border-teal-500/20 px-3 py-1 rounded-full">
                LIVESTOCK & SEASONAL E-COMMERCE
              </span>
              <span class="text-xs font-mono text-slate-400">Seasonal Campaign</span>
            </div>

            <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
              Wajib Livestock Qurbani Campaign
            </h3>

            <!-- Exact Approved Result Wording -->
            <p class="text-slate-300 text-base sm:text-lg leading-relaxed max-w-xl">
              Helped sell more than 150 animals and supported PKR 4.2M+ in sales during the Eid Qurbani campaign.
            </p>

            <!-- Oversized Result Numbers -->
            <div class="pt-4 grid grid-cols-2 gap-6 border-t border-white/10">
              <div>
                <span class="block font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-teal-400">150+</span>
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-1 block">Animals Sold</span>
              </div>
              <div>
                <span class="block font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-blue-400">PKR 4.2M+</span>
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-1 block">Campaign Sales Supported</span>
              </div>
            </div>

            <!-- Tags & Action -->
            <div class="pt-4 flex flex-wrap items-center gap-3">
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">Lead Generation</span>
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">WhatsApp Routing</span>
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">Video Ads</span>
            </div>

            <div class="pt-2">
              <a
                href={`${getAssetPath('/work/qurbani-campaign/')}`}
                class="inline-flex items-center gap-2 font-bold text-sm text-teal-400 hover:text-teal-300 transition-colors group/link"
              >
                <span>Read Full Case Study</span>
                <svg class="w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Custom Decorative Code Graphic (5 Cols) -->
          <div class="lg:col-span-5">
            <div class="p-6 rounded-2xl bg-slate-950/80 border border-white/10 space-y-4 font-mono text-xs shadow-inner">
              <div class="flex items-center justify-between text-slate-500 border-b border-white/10 pb-3">
                <span>// SEASONAL_PIPELINE</span>
                <span class="text-teal-400">HIGH DEMAND</span>
              </div>
              
              <div class="space-y-2 text-slate-300">
                <div class="flex justify-between">
                  <span class="text-slate-400">Channel Mix:</span>
                  <span class="text-white">Meta Ads + Direct WhatsApp</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Lead Response Time:</span>
                  <span class="text-teal-400">&lt; 5 Minutes Automated</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Conversion Rate:</span>
                  <span class="text-indigo-400">High-Intent Buyer Qualification</span>
                </div>
              </div>

              <!-- Animated Micro Metric Box -->
              <div class="p-4 rounded-xl bg-teal-950/40 border border-teal-500/30 flex items-center justify-between">
                <div>
                  <span class="text-[10px] text-teal-300 uppercase block">Campaign Duration</span>
                  <span class="text-lg font-bold text-white">Rapid Seasonal Sprint</span>
                </div>
                <span class="w-3 h-3 rounded-full bg-teal-400 animate-ping"></span>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- CASE STUDY 3: RK Reno Solutions -->
      <article class="rounded-3xl bg-gradient-to-br from-slate-900 via-slate-900/90 to-indigo-950/40 border border-indigo-500/20 p-8 sm:p-12 shadow-2xl relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl group-hover:bg-indigo-500/20 transition-all pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
          <!-- Copy & Stats (7 Cols) -->
          <div class="lg:col-span-7 space-y-6">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono font-bold tracking-widest text-indigo-400 uppercase bg-indigo-500/10 border border-indigo-500/20 px-3 py-1 rounded-full">
                RENOVATION & LOCAL SERVICES
              </span>
              <span class="text-xs font-mono text-slate-400">SEO Case Study</span>
            </div>

            <h3 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
              RK Reno Solutions
            </h3>

            <!-- Verified Result Wording -->
            <p class="text-slate-300 text-base sm:text-lg leading-relaxed max-w-xl">
              Built a structured SEO foundation targeting renovation and air-conditioning services in Kuala Lumpur and Selangor.
            </p>

            <!-- Oversized Result Numbers -->
            <div class="pt-4 grid grid-cols-2 gap-6 border-t border-white/10">
              <div>
                <span class="block font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-indigo-400">KL & Selangor</span>
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-1 block">Targeted Regional Reach</span>
              </div>
              <div>
                <span class="block font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-blue-400">Structured SEO</span>
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-1 block">Technical Search Foundation</span>
              </div>
            </div>

            <!-- Tags & Action -->
            <div class="pt-4 flex flex-wrap items-center gap-3">
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">Technical SEO</span>
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">Service Pages</span>
              <span class="text-xs font-mono text-slate-400 bg-slate-950 px-3 py-1.5 rounded-md border border-white/10">Local Ranking</span>
            </div>

            <div class="pt-2">
              <a
                href={`${getAssetPath('/work/rk-reno-solutions/')}`}
                class="inline-flex items-center gap-2 font-bold text-sm text-indigo-400 hover:text-indigo-300 transition-colors group/link"
              >
                <span>Read Full Case Study</span>
                <svg class="w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Custom Decorative Code Graphic (5 Cols) -->
          <div class="lg:col-span-5">
            <div class="p-6 rounded-2xl bg-slate-950/80 border border-white/10 space-y-4 font-mono text-xs shadow-inner">
              <div class="flex items-center justify-between text-slate-500 border-b border-white/10 pb-3">
                <span>// SEO_INDEXING_GRAPH</span>
                <span class="text-indigo-400">OPTIMIZED</span>
              </div>
              
              <div class="space-y-2 text-slate-300">
                <div class="flex justify-between">
                  <span class="text-slate-400">Target Geographies:</span>
                  <span class="text-white">KL, Subang, PJ, Shah Alam</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Core Services:</span>
                  <span class="text-teal-400">Renovation & Air-Con</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Page Speed Rating:</span>
                  <span class="text-indigo-400">95+ Mobile Performance</span>
                </div>
              </div>

              <!-- Animated Micro Metric Box -->
              <div class="p-4 rounded-xl bg-indigo-950/40 border border-indigo-500/30 flex items-center justify-between">
                <div>
                  <span class="text-[10px] text-indigo-300 uppercase block">Search Architecture</span>
                  <span class="text-lg font-bold text-white">Clean Semantic Schema</span>
                </div>
                <span class="w-3 h-3 rounded-full bg-indigo-400 animate-ping"></span>
              </div>
            </div>
          </div>
        </div>
      </article>

    </div>
  </Container>
</section>
