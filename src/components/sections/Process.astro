---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { processData } from '../../data/process';
---

<section id="process" class="bg-brand-black text-brand-white py-20 md:py-28 scroll-mt-20">
  <Container class="space-y-12 md:space-y-16">
    <SectionHeading
      eyebrow="HOW WE WORK"
      title="A clear process from business problem to measurable execution."
      theme="dark"
    />

    <!-- Numbered Sequence Layout: Stacked timeline on mobile/tablet, 3-column grid on desktop -->
    <div class="flex flex-col lg:grid lg:grid-cols-3 gap-x-10 gap-y-12 pt-4">
      {
        processData.map((item) => (
          <div class="flex gap-6 items-start border-t border-brand-grey/10 pt-8">
            <span class="font-heading text-3xl sm:text-4xl font-bold text-brand-blue select-none shrink-0 leading-none">
              {item.step}
            </span>
            <div class="space-y-3">
              <h3 class="font-heading text-xl sm:text-2xl font-bold text-brand-white tracking-tight">
                {item.title}
              </h3>
              <p class="font-body text-base font-normal text-brand-muted-dark leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
