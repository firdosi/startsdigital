---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';

const steps = [
  {
    number: '01',
    title: 'Understand',
    subtitle: 'Audit & Commercial Goals',
    description: 'We analyze your market positioning, current customer acquisition costs, existing channels, and profit targets.'
  },
  {
    number: '02',
    title: 'Plan',
    subtitle: 'Strategy & Architecture',
    description: 'We map out a clear omnichannel media budget allocation, creative messaging strategy, and website technical requirements.'
  },
  {
    number: '03',
    title: 'Build',
    subtitle: 'Assets & Media Setup',
    description: 'We design high-converting ad creatives, build clean web infrastructure, and deploy conversion tracking & automation.'
  },
  {
    number: '04',
    title: 'Scale',
    subtitle: 'Optimization & Growth',
    description: 'We continuously test media variations, optimize ad bidding, and scale winning campaigns for sustained commercial revenue.'
  }
];
---

<section class="py-20 md:py-32 bg-slate-950 text-white border-b border-white/10 relative">
  <Container>
    <SectionHeading
      eyebrow="EXECUTION FRAMEWORK"
      title="A systematic 4-stage process built for reliable scaling."
      description="No guessing or random tactics. Every client engagement follows a disciplined, structured framework."
      class="mb-20 dark-theme"
    />

    <!-- Desktop Horizontal Connected Timeline (Hidden on Mobile) -->
    <div class="hidden lg:block relative">
      <!-- Connecting Accent Line -->
      <div class="absolute top-1/2 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-600 via-teal-400 to-indigo-600 -translate-y-1/2 -z-10 opacity-30"></div>

      <div class="grid grid-cols-4 gap-8">
        {
          steps.map((step) => (
            <div class="p-8 rounded-2xl bg-slate-900 border border-white/10 hover:border-blue-500/40 transition-all duration-300 group shadow-xl relative flex flex-col justify-between h-full">
              <div class="flex items-center justify-between mb-6">
                <span class="font-mono text-3xl font-extrabold text-blue-400 group-hover:scale-110 transition-transform">{step.number}</span>
                <span class="w-3 h-3 rounded-full bg-blue-500/40 group-hover:bg-blue-400 transition-colors"></span>
              </div>

              <div>
                <h3 class="font-heading text-2xl font-extrabold text-white mb-1 group-hover:text-blue-300 transition-colors">
                  {step.title}
                </h3>
                <span class="text-xs font-mono text-teal-400 block mb-4">{step.subtitle}</span>
                <p class="text-slate-300 text-sm leading-relaxed">
                  {step.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Mobile Vertical Connected Timeline (Shown on Mobile & Tablet) -->
    <div class="lg:hidden relative space-y-8 pl-6 border-l-2 border-blue-500/30">
      {
        steps.map((step) => (
          <div class="relative p-6 rounded-2xl bg-slate-900 border border-white/10">
            <span class="absolute -left-[35px] top-6 w-4 h-4 rounded-full bg-blue-500 ring-4 ring-slate-950"></span>
            
            <div class="flex items-center gap-3 mb-2">
              <span class="font-mono text-2xl font-extrabold text-blue-400">{step.number}</span>
              <h3 class="font-heading text-xl font-extrabold text-white">{step.title}</h3>
            </div>
            
            <span class="text-xs font-mono text-teal-400 block mb-3">{step.subtitle}</span>
            
            <p class="text-slate-300 text-sm leading-relaxed">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
