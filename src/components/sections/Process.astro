---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { processData } from '../../data/process';
---

<section id="process" class="bg-brand-black text-brand-white py-20 md:py-28 scroll-mt-20">
  <Container class="space-y-12 md:space-y-16">
    <SectionHeading
      eyebrow="HOW WE WORK"
      title="A clear process from business problem to measurable execution."
      theme="dark"
    />

    <!-- Numbered Sequence Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12 pt-4">
      {
        processData.map((item) => (
          <div class="flex gap-5 items-start border-t border-brand-grey/10 pt-6">
            <span class="font-heading text-xl sm:text-2xl font-extrabold text-brand-blue tracking-tight select-none shrink-0">
              {item.step}
            </span>
            <div class="space-y-2">
              <h3 class="font-heading text-lg font-bold text-brand-white">
                {item.title}
              </h3>
              <p class="font-body text-sm font-light text-brand-text leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
