---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<section id="hero" class="relative pt-28 pb-16 md:pt-36 md:pb-24 bg-slate-950 text-white overflow-hidden border-b border-white/10">
  <!-- Ambient Radial Glow Effects -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-tr from-blue-600/20 via-teal-500/10 to-indigo-600/20 rounded-full blur-[120px] pointer-events-none -z-10 animate-pulse-glow" aria-hidden="true"></div>
  <div class="absolute top-10 right-10 w-96 h-96 bg-blue-500/10 rounded-full blur-[100px] pointer-events-none -z-10" aria-hidden="true"></div>

  <!-- Grid Pattern Overlay -->
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,#1e293b15_1px,transparent_1px),linear-gradient(to_bottom,#1e293b15_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]" aria-hidden="true"></div>

  <Container class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
    <!-- Left Column: Headline, Copy, Action CTAs, Metrics -->
    <div class="lg:col-span-7 flex flex-col space-y-6 md:space-y-8">
      <div>
        <span class="inline-flex items-center gap-2.5 text-xs font-extrabold tracking-[0.2em] text-teal-400 uppercase font-heading bg-teal-500/10 border border-teal-500/20 px-4 py-2 rounded-full">
          <span class="w-2 h-2 rounded-full bg-teal-400 animate-pulse" aria-hidden="true"></span>
          PERFORMANCE & CREATIVE DIGITAL AGENCY
        </span>
      </div>

      <!-- Main Headline (Exact Approved Text) -->
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.1]">
        Digital marketing built to scale <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-300 to-indigo-300">real businesses.</span>
      </h1>

      <!-- Supporting Copy -->
      <p class="text-lg sm:text-xl text-slate-300 max-w-2xl font-normal leading-relaxed">
        Specializing in high-ROI <strong class="text-white font-semibold">paid advertising</strong>, custom conversion-focused <strong class="text-white font-semibold">websites</strong>, technical <strong class="text-white font-semibold">SEO</strong>, <strong class="text-white font-semibold">creative content</strong> production, and practical <strong class="text-white font-semibold">AI systems</strong>.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-2">
        <Button
          href={siteConfig.links.contact}
          variant="primary"
          class="!py-4 !px-8 text-base font-bold !bg-blue-600 hover:!bg-blue-500 !text-white shadow-xl shadow-blue-600/30 border-0 transition-all transform hover:-translate-y-0.5"
        >
          Discuss Your Project
        </Button>
        <a
          href="#work"
          class="inline-flex items-center justify-center gap-2 py-4 px-8 text-base font-bold text-slate-200 hover:text-white bg-slate-900/80 hover:bg-slate-800 border border-white/10 hover:border-white/20 rounded-lg transition-all"
        >
          <span>Explore Featured Work</span>
          <svg class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>

      <!-- Metric Highlights Strip (Explicit Numbers Included) -->
      <div class="pt-6 border-t border-white/10 grid grid-cols-2 sm:grid-cols-4 gap-6">
        <div>
          <span class="block font-heading text-2xl sm:text-3xl font-extrabold text-white">PKR 30M+</span>
          <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Revenue Supported</span>
        </div>
        <div>
          <span class="block font-heading text-2xl sm:text-3xl font-extrabold text-teal-400">29,000+</span>
          <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Product Sales</span>
        </div>
        <div>
          <span class="block font-heading text-2xl sm:text-3xl font-extrabold text-blue-400">PKR 4.2M+</span>
          <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Campaign Sales</span>
        </div>
        <div>
          <span class="block font-heading text-2xl sm:text-3xl font-extrabold text-indigo-400">150+</span>
          <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Livestock Sold</span>
        </div>
      </div>
    </div>

    <!-- Right Column: Abstract Decorative Code-Based Visual Composition -->
    <div class="lg:col-span-5 relative flex justify-center">
      <div class="relative w-full max-w-lg">
        <!-- Ambient Backing Card Glow -->
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-teal-400 rounded-2xl blur-xl opacity-30 animate-pulse-glow"></div>

        <!-- Main Glassmorphic Container -->
        <div class="relative rounded-2xl bg-slate-900/90 border border-white/15 p-6 shadow-2xl backdrop-blur-xl space-y-6">
          
          <!-- Top Window Header Bar -->
          <div class="flex items-center justify-between border-b border-white/10 pb-4">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
              <span class="ml-2 text-xs font-mono text-slate-400">GrowthEngine.config.v2</span>
            </div>
            <span class="inline-flex items-center gap-1.5 text-[10px] font-mono font-bold text-teal-400 bg-teal-500/10 px-2.5 py-1 rounded-full border border-teal-500/20">
              LIVE SYSTEM
            </span>
          </div>

          <!-- Abstract Layer 1: Campaign Funnel Nodes & Live Performance Line -->
          <div class="p-4 rounded-xl bg-slate-950/70 border border-white/10 space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs font-mono text-slate-400">Acquisition & Retention Flow</span>
              <span class="text-xs font-bold text-blue-400">+142% ROAS</span>
            </div>
            
            <!-- SVG Trend Wave Line -->
            <div class="h-24 w-full relative overflow-hidden flex items-end">
              <svg class="w-full h-full text-blue-500" viewBox="0 0 300 80" fill="none" preserveAspectRatio="none">
                <path d="M0 60 Q 60 40, 120 45 T 240 20 T 300 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" fill="none" />
                <path d="M0 60 Q 60 40, 120 45 T 240 20 T 300 10 L 300 80 L 0 80 Z" fill="url(#blue-gradient)" opacity="0.25" />
                <defs>
                  <linearGradient id="blue-gradient" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#3b82f6" />
                    <stop offset="100%" stop-color="#030712" />
                  </linearGradient>
                </defs>
              </svg>
            </div>
          </div>

          <!-- Abstract Layer 2: Grid of Glowing Feature Pills -->
          <div class="grid grid-cols-2 gap-3">
            <div class="p-3.5 rounded-xl bg-slate-950/60 border border-blue-500/20 flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <div>
                <span class="block text-xs font-bold text-white">Paid Ads</span>
                <span class="text-[10px] text-slate-400">Meta & Google</span>
              </div>
            </div>

            <div class="p-3.5 rounded-xl bg-slate-950/60 border border-teal-500/20 flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-teal-500/20 flex items-center justify-center text-teal-400">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
              </div>
              <div>
                <span class="block text-xs font-bold text-white">Web & SEO</span>
                <span class="text-[10px] text-slate-400">Custom Architecture</span>
              </div>
            </div>
          </div>

          <!-- Abstract Layer 3: Floating Status Badge -->
          <div class="flex items-center justify-between p-3 rounded-xl bg-gradient-to-r from-blue-950/60 to-slate-900 border border-white/10 text-xs">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-blue-400 animate-ping"></span>
              <span class="font-medium text-slate-300">Omnichannel Active Strategy</span>
            </div>
            <span class="font-mono text-teal-400 font-bold">100% Scalable</span>
          </div>

        </div>
      </div>
    </div>
  </Container>
</section>
