---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { getAssetPath } from '../../data/site';
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 bg-brand-white overflow-hidden border-b border-brand-light-border/60">
  <Container class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-12 items-center">
    <!-- Left Column: Copy & Actions -->
    <div class="lg:col-span-7 flex flex-col space-y-6 md:space-y-8">
      <div>
        <span class="inline-block text-xs font-extrabold tracking-[0.2em] text-brand-teal uppercase font-heading bg-brand-teal/10 px-3 py-1.5 rounded-md">
          DIGITAL MARKETING, CREATIVE & TECHNOLOGY
        </span>
      </div>

      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-brand-black leading-[1.15]">
        Digital strategy, campaigns and websites built to generate <span class="text-brand-blue">measurable growth.</span>
      </h1>

      <p class="font-body text-base sm:text-lg font-normal leading-relaxed text-brand-text max-w-2xl">
        Starts Digital helps businesses grow through paid advertising, websites, SEO, creative content and AI-powered digital systems.
      </p>

      <!-- Primary Actions -->
      <div class="flex flex-col sm:flex-row gap-4 pt-2">
        <Button 
          href="#contact" 
          variant="primary"
          class="!px-7 !py-3.5 font-semibold text-base shadow-sm"
        >
          Discuss Your Project
        </Button>
        <Button 
          href={getAssetPath('/work/')} 
          variant="secondary"
          class="!px-7 !py-3.5 font-semibold text-base !bg-white !text-brand-black !border-brand-light-border hover:!bg-brand-grey/30"
        >
          View Our Work
        </Button>
      </div>

      <!-- Verified Results Metric Bar -->
      <div class="pt-6 border-t border-brand-light-border grid grid-cols-2 sm:grid-cols-3 gap-6">
        <div>
          <span class="block font-heading text-2xl font-extrabold text-brand-blue">PKR 30M+</span>
          <span class="text-xs font-semibold text-brand-text uppercase tracking-wider">Revenue Supported</span>
        </div>
        <div>
          <span class="block font-heading text-2xl font-extrabold text-brand-blue">29,000+</span>
          <span class="text-xs font-semibold text-brand-text uppercase tracking-wider">Product Sales</span>
        </div>
        <div class="col-span-2 sm:col-span-1">
          <span class="block font-heading text-2xl font-extrabold text-brand-black">Multiple</span>
          <span class="text-xs font-semibold text-brand-text uppercase tracking-wider">Industries & Markets</span>
        </div>
      </div>
    </div>

    <!-- Right Column: Visual Frame with Visible Prototype Label -->
    <div class="lg:col-span-5">
      <div class="relative rounded-2xl border border-brand-light-border bg-white p-3 shadow-xl space-y-2">
        <div class="flex items-center justify-between px-2 pt-1">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-amber-500/10 text-amber-700 font-extrabold text-[11px] font-heading rounded tracking-wider uppercase border border-amber-500/20">
            PROTOTYPE VISUAL
          </span>
          <span class="text-[11px] font-semibold text-brand-text/80 font-heading">
            Visual direction preview using temporary design assets
          </span>
        </div>

        <div class="relative overflow-hidden rounded-xl bg-brand-navy/5">
          <img 
            src={getAssetPath('/prototype/hero-business.webp')} 
            alt="Temporary visual direction preview using temporary design assets"
            width="600"
            height="400"
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto object-cover rounded-lg border border-brand-light-border/40"
          />
        </div>
      </div>
    </div>
  </Container>
</section>
