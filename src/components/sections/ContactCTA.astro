---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<section id="contact" class="py-24 md:py-36 bg-slate-950 text-white border-b border-white/10 relative overflow-hidden">
  <!-- Glowing Backdrop Texture -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(59,130,246,0.2),rgba(255,255,255,0))]" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-teal-500/10 rounded-full blur-[140px] pointer-events-none" aria-hidden="true"></div>

  <Container class="relative z-10">
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <div>
        <span class="inline-flex items-center gap-2 text-xs font-extrabold tracking-[0.25em] text-blue-400 uppercase font-heading bg-blue-500/10 border border-blue-500/20 px-4 py-2 rounded-full mb-6">
          TAKE THE NEXT STEP
        </span>
        <h2 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight leading-tight">
          Ready to scale your <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-teal-300 to-indigo-300">digital revenue?</span>
        </h2>
      </div>

      <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed">
        Speak directly with our digital team. We will review your current ad performance, web conversion architecture, and market opportunities without fluff.
      </p>

      <div class="pt-4 flex flex-col sm:flex-row items-center justify-center gap-5">
        <Button
          href={siteConfig.links.whatsapp}
          variant="primary"
          class="w-full sm:w-auto !py-4 !px-8 text-base font-bold !bg-teal-600 hover:!bg-teal-500 !text-white shadow-xl shadow-teal-600/30 border-0 transition-all hover:scale-[1.02]"
        >
          Message on WhatsApp
        </Button>

        <a
          href={`mailto:${siteConfig.contact.email}`}
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 py-4 px-8 text-base font-bold text-slate-200 hover:text-white bg-slate-900 hover:bg-slate-800 border border-white/10 hover:border-white/20 rounded-lg transition-all"
        >
          <span>Email Our Team</span>
          <svg class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </a>
      </div>

      <!-- Quick Contact Badges -->
      <div class="pt-8 border-t border-white/10 flex flex-wrap items-center justify-center gap-8 text-xs font-mono text-slate-400">
        <div>Email: <a href={`mailto:${siteConfig.contact.email}`} class="text-white hover:text-blue-400">{siteConfig.contact.email}</a></div>
        <div>WhatsApp: <a href={siteConfig.links.whatsapp} class="text-white hover:text-teal-400">{siteConfig.contact.phone}</a></div>
      </div>
    </div>
  </Container>
</section>
