---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<section id="contact" class="py-20 md:py-28 bg-brand-navy text-brand-white relative overflow-hidden border-t border-brand-light-border/10">
  <Container class="space-y-12 relative z-10">
    <div class="max-w-4xl mx-auto text-center space-y-6">
      <span class="text-xs font-extrabold tracking-[0.2em] text-brand-teal uppercase font-heading bg-brand-teal/10 px-3 py-1.5 rounded-md">
        START YOUR GROWTH ENGINE
      </span>
      
      <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-extrabold text-brand-white leading-[1.15]">
        Ready to build a stronger digital growth system?
      </h2>

      <p class="font-body text-base sm:text-lg text-brand-muted-dark max-w-2xl mx-auto leading-relaxed">
        Let’s review your current marketing performance, discuss campaign requirements, and build a strategy focused on verified business outcomes.
      </p>

      <!-- Contact Info Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-xl mx-auto pt-4 text-left">
        <div class="p-4 bg-white/5 border border-white/10 rounded-xl flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-brand-blue/20 flex items-center justify-center text-brand-blue shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <span class="block text-xs font-bold uppercase tracking-wider text-brand-muted-dark font-heading">Direct Email</span>
            <a href={`mailto:${siteConfig.contact.email}`} class="font-body text-sm font-semibold text-brand-white hover:text-brand-blue transition-colors">
              {siteConfig.contact.email}
            </a>
          </div>
        </div>

        <div class="p-4 bg-white/5 border border-white/10 rounded-xl flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-brand-teal/20 flex items-center justify-center text-brand-teal shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <span class="block text-xs font-bold uppercase tracking-wider text-brand-muted-dark font-heading">WhatsApp Direct</span>
            <a href={siteConfig.contact.whatsappUrl} target="_blank" rel="noopener noreferrer" class="font-body text-sm font-semibold text-brand-white hover:text-brand-teal transition-colors">
              {siteConfig.contact.phone}
            </a>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-6">
        <Button 
          href={siteConfig.contact.whatsappUrl} 
          variant="primary"
          class="!px-8 !py-4 font-semibold text-base shadow-lg w-full sm:w-auto text-center"
        >
          Discuss Your Project
        </Button>
        <a 
          href={siteConfig.contact.whatsappUrl}
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 font-heading text-base font-semibold text-brand-white bg-white/10 border border-white/20 rounded-lg hover:bg-white/20 transition-colors w-full sm:w-auto text-center"
        >
          <span>WhatsApp Us Direct</span>
          <svg class="w-4 h-4 text-brand-teal" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984 0 1.758.459 3.474 1.33 4.982L2 22l5.167-1.347a9.96 9.96 0 004.843 1.251h.004c5.506 0 9.99-4.478 9.99-9.985 0-2.667-1.039-5.176-2.927-7.062A9.924 9.924 0 0012.012 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </Container>
</section>
