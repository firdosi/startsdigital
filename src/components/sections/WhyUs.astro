---
import Container from '../ui/Container.astro';

const differentiators = [
  {
    title: 'Strategy & Execution Together',
    description: 'We do not deliver static PDF strategy decks and disappear. We write the copy, produce the video ad creatives, build the landing page, and optimize campaign budgets directly.',
  },
  {
    title: 'Multi-Industry Domain Experience',
    description: 'From e-commerce consumer goods and livestock campaigns to local construction services and healthcare labs, we adapt our growth models to your industry dynamics.',
  },
  {
    title: 'Marketing & Technical Capabilities',
    description: 'We blend performance marketing expertise with clean web development (Astro, TypeScript, Tailwind) and practical AI automation systems to build sustainable growth infrastructure.',
  },
  {
    title: 'Direct Communication & Transparency',
    description: 'You communicate directly with the strategists and creators executing your work. No account manager layers, no inflated reports, and clear weekly progress tracking.',
  },
];
---

<section id="why-us" class="py-20 md:py-32 bg-brand-white border-b border-brand-light-border">
  <Container class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
    <!-- Left Column: Large Editorial Statement -->
    <div class="lg:col-span-5 space-y-6 sticky top-28">
      <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
        OUR OPERATING MODEL
      </span>
      <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-extrabold text-brand-black leading-[1.15]">
        Strategy, creative and execution managed as one <span class="text-brand-blue">connected growth system.</span>
      </h2>
      <p class="font-body text-base text-brand-text leading-relaxed">
        We build integrated digital engines where strategy, creative production, and engineering operate in sync without agency silos.
      </p>
    </div>

    <!-- Right Column: 4 Short Differentiators with Dividers (No white boxes) -->
    <div class="lg:col-span-7 divide-y divide-brand-light-border border-y border-brand-light-border">
      {differentiators.map((diff, idx) => (
        <div class="py-8 space-y-3">
          <div class="flex items-center gap-3">
            <span class="font-heading text-xs font-extrabold text-brand-teal uppercase tracking-widest bg-brand-teal/10 px-2.5 py-1 rounded">
              0{idx + 1}
            </span>
            <h3 class="font-heading text-xl sm:text-2xl font-bold text-brand-black">
              {diff.title}
            </h3>
          </div>
          <p class="font-body text-base text-brand-text leading-relaxed pl-10">
            {diff.description}
          </p>
        </div>
      ))}
    </div>
  </Container>
</section>
