---
import Container from '../ui/Container.astro';

const pillars = [
  {
    title: 'Strategy & Execution Together',
    description: 'We do not deliver static PDF strategy decks and disappear. We write the copy, produce the video ad creatives, build the landing page, and optimize campaign budgets directly.',
    badge: 'FULL-STACK AGENCY',
  },
  {
    title: 'Multi-Industry Domain Experience',
    description: 'From e-commerce consumer goods and livestock campaigns to local construction services and healthcare labs, we adapt our growth models to your industry dynamics.',
    badge: 'VERIFIED PRACTICE',
  },
  {
    title: 'Marketing, Engineering & AI Capabilities',
    description: 'We blend performance marketing expertise with clean web development (Astro, TypeScript, Tailwind) and practical AI automation systems to build sustainable growth infrastructure.',
    badge: 'MODERN TECH STACK',
  },
  {
    title: 'Direct Communication & Transparency',
    description: 'You communicate directly with the strategists and creators executing your work. No account manager layers, no inflated reports, and clear weekly progress tracking.',
    badge: 'DIRECT COLLABORATION',
  },
];
---

<section id="why-us" class="py-20 md:py-28 bg-brand-white border-b border-brand-light-border">
  <Container class="space-y-14">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 pb-6 border-b border-brand-light-border">
      <div class="space-y-3 max-w-2xl">
        <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
          OUR OPERATING MODEL
        </span>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-extrabold text-brand-black">
          Why Businesses Choose Starts Digital
        </h2>
      </div>
      <p class="font-body text-base text-brand-text max-w-md">
        We build integrated digital engines where strategy, creative production, and engineering operate in sync.
      </p>
    </div>

    <!-- Pillars Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {pillars.map((pillar, idx) => (
        <div class="p-8 sm:p-10 bg-white border border-brand-light-border rounded-2xl space-y-4 shadow-xs hover:border-brand-blue/40 transition-colors flex flex-col justify-between">
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs font-extrabold tracking-widest text-brand-blue uppercase font-heading bg-brand-blue/10 px-3 py-1 rounded-md">
                {pillar.badge}
              </span>
              <span class="font-heading text-xl font-extrabold text-brand-light-border">0{idx + 1}</span>
            </div>
            <h3 class="font-heading text-2xl font-extrabold text-brand-black">
              {pillar.title}
            </h3>
            <p class="font-body text-base text-brand-text leading-relaxed">
              {pillar.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
