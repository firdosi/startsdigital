---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { projectsData } from '../../data/projects';
---

<section id="work" class="bg-brand-white text-brand-black py-20 md:py-28 scroll-mt-20">
  <Container class="space-y-12 md:space-y-16">
    <SectionHeading
      eyebrow="SELECTED WORK"
      title="Experience across products, services and competitive industries."
      theme="light"
    />

    <!-- Premium Editorial Project Panels -->
    <div class="flex flex-col border-t border-brand-grey/25 divide-y divide-brand-grey/25">
      {
        projectsData.map((project, index) => (
          <div class="py-12 md:py-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Project Number & Info (col-span-5) -->
            <div class="lg:col-span-5 space-y-3">
              <span class="font-heading text-xs sm:text-sm font-bold text-brand-teal uppercase tracking-widest">
                Project 0{index + 1}
              </span>
              <h3 class="font-heading text-2xl sm:text-3xl font-bold text-brand-black leading-tight">
                {project.title}
              </h3>
              <p class="font-body text-xs sm:text-sm font-semibold text-brand-text uppercase tracking-wider">
                {project.industry}
              </p>
            </div>

            <!-- Right Column: Dominant Outcome & Services Sentence (col-span-7) -->
            <div class="lg:col-span-7 space-y-6 lg:pl-6">
              <div class="space-y-2">
                <span class="block font-heading text-xs font-bold tracking-widest text-brand-teal uppercase">
                  Verified Outcome
                </span>
                <p class="font-heading text-lg sm:text-xl font-bold text-brand-black leading-relaxed">
                  {project.result}
                </p>
              </div>

              <div class="pt-4 border-t border-brand-grey/15">
                <p class="font-body text-sm sm:text-base font-normal text-brand-text leading-relaxed">
                  <strong class="font-semibold text-brand-black">Services Rendered:</strong>{' '}
                  {project.services.join(', ')}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Case Studies Simplified Note -->
    <div class="pt-12 border-t border-brand-grey/25 text-center">
      <p class="font-body text-sm font-semibold tracking-wider text-brand-text">
        Detailed case studies coming next.
      </p>
    </div>
  </Container>
</section>
