---
import Container from '../ui/Container.astro';
import { brands } from '../../data/brands';
---

<section class="py-14 bg-slate-950 border-b border-white/10 overflow-hidden relative">
  <Container class="mb-6">
    <p class="text-center text-xs font-heading font-extrabold tracking-[0.25em] text-slate-400 uppercase">
      TRUSTED BY GROWTH-ORIENTED BRANDS & ENTERPRISES
    </p>
  </Container>

  <!-- Marquee Container with Left/Right Gradient Fade Masks -->
  <div class="relative w-full overflow-hidden [mask-image:linear-gradient(to_right,transparent_0%,#000_15%,#000_85%,transparent_100%)]">
    <div class="animate-marquee flex items-center gap-12 whitespace-nowrap py-4">
      {/* Duplicate list to create seamless infinite scroll loop */}
      {
        [...brands, ...brands].map((brand) => (
          <div 
            class="flex items-center gap-12 group cursor-default"
          >
            <span class="font-heading text-lg sm:text-xl font-bold tracking-wider text-slate-300 group-hover:text-blue-400 transition-colors uppercase">
              {brand.name}
            </span>
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500/40 group-hover:bg-blue-400 transition-colors" aria-hidden="true"></span>
          </div>
        ))
      }
    </div>
  </div>
</section>
