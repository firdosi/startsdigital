---
import Container from '../ui/Container.astro';
import { platforms } from '../../data/platforms';
import { getAssetPath } from '../../data/site';
---

<section class="py-16 md:py-24 bg-brand-white border-b border-brand-light-border">
  <Container class="space-y-12">
    <div class="text-center max-w-2xl mx-auto space-y-3">
      <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
        TECHNOLOGY STACK
      </span>
      <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-brand-black">
        Platforms & Tools We Work With
      </h2>
      <p class="font-body text-sm sm:text-base text-brand-text">
        We integrate industry-leading advertising channels, analytics systems, content management platforms and design software.
      </p>
    </div>

    <!-- Platform Tool Tiles Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {platforms.map((platform) => (
        <div class="flex flex-col items-center justify-center p-6 bg-white border border-brand-light-border rounded-xl shadow-xs hover:border-brand-blue/40 transition-colors group">
          <img 
            src={getAssetPath(platform.logo)} 
            alt={`${platform.name} logo`}
            width="48"
            height="48"
            loading="lazy"
            class="h-10 w-10 object-contain group-hover:scale-105 transition-transform"
          />
          <span class="mt-3 font-heading text-xs font-bold text-brand-black text-center">
            {platform.name}
          </span>
        </div>
      ))}
    </div>
  </Container>
</section>
