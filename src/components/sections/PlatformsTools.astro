---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { platforms } from '../../data/platforms';

const categoryLabels: Record<string, string> = {
  advertising: 'PAID ADVERTISING & PPC',
  analytics: 'ANALYTICS & CONVERSION TRACKING',
  cms: 'E-COMMERCE & CMS PLATFORMS',
  communication: 'CLIENT AUTOMATION & MESSAGING',
  design: 'CREATIVE PRODUCTION & DESIGN'
};

const groupedPlatforms = Object.entries(
  platforms.reduce((acc, platform) => {
    acc[platform.category] = acc[platform.category] || [];
    acc[platform.category].push(platform.name);
    return acc;
  }, {} as Record<string, string[]>)
);
---

<section class="py-20 md:py-32 bg-slate-950 text-white border-b border-white/10 relative">
  <Container>
    <SectionHeading
      eyebrow="STACK & ARCHITECTURE"
      title="Enterprise platforms and modern technical tools."
      description="We deploy official API integrations and trusted technology frameworks to execute paid media, analytics, e-commerce, and automation."
      class="mb-16 dark-theme"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        groupedPlatforms.map(([categoryKey, tools]) => (
          <div class="p-8 rounded-2xl bg-slate-900/60 border border-white/10 hover:border-blue-500/30 transition-all">
            <h3 class="text-xs font-mono font-extrabold tracking-widest text-teal-400 uppercase mb-6 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-teal-400"></span>
              {categoryLabels[categoryKey] || categoryKey}
            </h3>

            <div class="flex flex-wrap gap-3">
              {tools.map((tool) => (
                <span 
                  class="font-heading text-sm sm:text-base font-bold text-slate-200 bg-slate-950 px-4 py-2 rounded-xl border border-white/10 hover:border-blue-400/40 hover:text-white transition-all shadow-sm"
                >
                  {tool}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
