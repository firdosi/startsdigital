---
import Container from '../ui/Container.astro';

interface Props {
  enabled?: boolean;
}

const { enabled = false } = Astro.props;
---

{enabled && (
  <section id="founder" class="py-20 md:py-28 bg-brand-white border-b border-brand-light-border">
    <Container>
      <div class="p-8 sm:p-12 bg-white border border-brand-light-border rounded-2xl grid grid-cols-1 lg:grid-cols-12 gap-8 items-center shadow-xs">
        <div class="lg:col-span-4 flex justify-center">
          <div class="w-48 h-48 sm:w-64 sm:h-64 rounded-2xl bg-brand-grey/40 border border-brand-light-border flex items-center justify-center text-brand-text font-heading text-sm text-center p-4">
            [ Founder Photograph Placeholder ]
          </div>
        </div>
        <div class="lg:col-span-8 space-y-4">
          <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
            AGENCY LEADERSHIP
          </span>
          <h3 class="font-heading text-2xl sm:text-3xl font-extrabold text-brand-black">
            Founder & Principal Strategist
          </h3>
          <p class="font-body text-base text-brand-text leading-relaxed">
            Directing digital strategy, performance media acquisition, and tech implementation for growing businesses.
          </p>
        </div>
      </div>
    </Container>
  </section>
)}
