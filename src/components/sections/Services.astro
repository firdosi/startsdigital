---
import Container from '../ui/Container.astro';

const services = [
  {
    id: 'performance-marketing',
    title: 'Performance Marketing',
    category: 'PAID MEDIA',
    description: 'Data-driven ad campaigns on Meta, Google and TikTok engineered to drive qualified traffic, lead inquiries and measurable e-commerce revenue.',
    highlights: ['Meta & Instagram Ads', 'Google Search & Shopping', 'TikTok Ad Creatives', 'Audience Retargeting'],
    featured: true,
  },
  {
    id: 'website-development',
    title: 'Website Development',
    category: 'ENGINEERING',
    description: 'High-speed, conversion-focused websites and landing pages built on modern Astro, WordPress and Webflow stacks with clean UX and SEO architecture.',
    highlights: ['Custom Astro & SSR Sites', 'WooCommerce & Shopify', 'High-Speed Performance', 'Mobile UX Optimization'],
    featured: true,
  },
  {
    id: 'seo-organic-growth',
    title: 'SEO & Organic Growth',
    category: 'VISIBILITY',
    description: 'Technical SEO audits, keyword strategy and high-intent content planning designed to build long-term organic search authority and inbound leads.',
    highlights: ['Technical & On-Page SEO', 'Keyword Architecture', 'Local SEO & Maps', 'Content Velocity'],
    featured: false,
  },
  {
    id: 'creative-content-video',
    title: 'Creative Content & Video',
    category: 'PRODUCTION',
    description: 'Short-form Reels, TikToks, UGC video editing and high-converting ad hooks designed to capture attention and elevate brand perception.',
    highlights: ['Short-Form Video Editing', 'UGC & Ad Creative Packs', 'Brand Identity Visuals', 'Hook Testing'],
    featured: false,
  },
  {
    id: 'lead-generation',
    title: 'Lead Generation',
    category: 'CONVERSION',
    description: 'Full-funnel lead generation engines combining targeted ads, high-converting offer copy, and automated WhatsApp/email response sequences.',
    highlights: ['High-Intent Lead Forms', 'WhatsApp Lead Routing', 'Offer & Copy Testing', 'Funnel Analytics'],
    featured: false,
  },
  {
    id: 'ai-automation',
    title: 'AI & Digital Automation',
    category: 'SYSTEMS',
    description: 'Practical AI implementations for marketing workflows, automated customer routing, dynamic copy generation, and data analysis systems.',
    highlights: ['Marketing Workflow AI', 'Automated Lead Routing', 'Custom AI Prompting', 'Analytics Integration'],
    featured: false,
  },
];
---

<section id="services" class="py-20 md:py-28 bg-brand-white border-b border-brand-light-border">
  <Container class="space-y-14">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 pb-6 border-b border-brand-light-border">
      <div class="space-y-3 max-w-2xl">
        <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
          OUR CORE CAPABILITIES
        </span>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-extrabold text-brand-black">
          Services Built for Modern Digital Growth
        </h2>
      </div>
      <p class="font-body text-base text-brand-text max-w-md">
        We combine creative strategy, paid media execution, software engineering and SEO into an integrated growth engine.
      </p>
    </div>

    <!-- Featured Top 2 Service Panels (Larger, Open Layout) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {services.filter(s => s.featured).map((service, index) => (
        <div class="bg-white border border-brand-light-border rounded-2xl p-8 sm:p-10 shadow-xs hover:border-brand-blue/40 transition-colors flex flex-col justify-between space-y-8 relative overflow-hidden">
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-xs font-extrabold tracking-widest text-brand-blue uppercase font-heading bg-brand-blue/10 px-3 py-1 rounded-md">
                {service.category}
              </span>
              <span class="font-heading text-2xl font-extrabold text-brand-light-border">0{index + 1}</span>
            </div>
            <h3 class="font-heading text-2xl sm:text-3xl font-extrabold text-brand-black">
              {service.title}
            </h3>
            <p class="font-body text-base text-brand-text leading-relaxed">
              {service.description}
            </p>
          </div>

          <div class="pt-6 border-t border-brand-light-border/60">
            <h4 class="text-xs font-bold uppercase tracking-wider text-brand-black/70 mb-3 font-heading">Key Deliverables</h4>
            <div class="grid grid-cols-2 gap-2.5">
              {service.highlights.map(item => (
                <div class="flex items-center gap-2 text-sm text-brand-black font-semibold">
                  <svg class="w-4 h-4 text-brand-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Supporting 4 Services (Open Layout Grid with Thin Dividers) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
      {services.filter(s => !s.featured).map((service, index) => (
        <div class="p-8 bg-brand-grey/20 border-l-4 border-l-brand-blue border-y border-r border-brand-light-border rounded-r-xl space-y-4 hover:bg-brand-grey/40 transition-colors">
          <div class="flex items-center justify-between">
            <span class="text-xs font-bold tracking-widest text-brand-teal uppercase font-heading">
              {service.category}
            </span>
            <span class="font-heading text-sm font-bold text-brand-text">0{index + 3}</span>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand-black">
            {service.title}
          </h3>
          <p class="font-body text-sm text-brand-text leading-relaxed">
            {service.description}
          </p>
          <div class="flex flex-wrap gap-2 pt-2">
            {service.highlights.map(item => (
              <span class="text-xs font-semibold text-brand-black bg-white border border-brand-light-border px-2.5 py-1 rounded-md">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
