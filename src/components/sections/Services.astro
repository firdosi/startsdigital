---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { servicesData } from '../../data/services';
---

<section id="services" class="bg-brand-navy text-brand-white py-20 md:py-28 scroll-mt-20">
  <Container class="space-y-12 md:space-y-16">
    <SectionHeading
      eyebrow="WHAT WE DO"
      title="Connected digital services built around business growth."
      theme="dark"
    />

    <!-- Editorial 3-Column Service Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12 pt-4">
      {
        servicesData.map((service, index) => (
          <div class="flex flex-col space-y-3 border-t border-brand-grey/10 pt-6">
            <span class="font-heading text-xs font-semibold text-brand-teal tracking-wider uppercase">
              0{index + 1}
            </span>
            <h3 class="font-heading text-lg font-bold text-brand-white">
              {service.title}
            </h3>
            <p class="font-body text-sm font-light text-brand-text leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
