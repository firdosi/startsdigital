---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="services" class="py-20 md:py-32 bg-slate-950 text-white border-b border-white/10 relative">
  <!-- Subtle Background Glow -->
  <div class="absolute bottom-1/3 right-10 w-96 h-96 bg-blue-600/10 rounded-full blur-[140px] pointer-events-none" aria-hidden="true"></div>

  <Container>
    <SectionHeading
      eyebrow="CORE CAPABILITIES"
      title="End-to-end digital capabilities designed to generate revenue."
      description="We replace fragmented freelancer teams with a cohesive growth architecture spanning media, engineering, search, content, and automation."
      class="mb-16 dark-theme"
    />

    <!-- Asymmetric Bento Box Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      
      <!-- Panel 01: Paid Advertising (Featured 8 Cols) -->
      <div class="md:col-span-12 lg:col-span-8 p-8 md:p-10 rounded-2xl bg-gradient-to-br from-slate-900 to-slate-950 border border-blue-500/20 hover:border-blue-500/50 transition-all duration-300 group shadow-xl relative overflow-hidden flex flex-col justify-between">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl group-hover:bg-blue-500/20 transition-all"></div>
        
        <div>
          <div class="flex items-center justify-between mb-8">
            <span class="font-mono text-4xl font-extrabold text-blue-400 opacity-60 group-hover:opacity-100 transition-opacity">01</span>
            <span class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
            </span>
          </div>

          <h3 class="font-heading text-2xl md:text-3xl font-extrabold text-white mb-4 group-hover:text-blue-300 transition-colors">
            Paid Advertising and Lead Generation
          </h3>

          <p class="text-slate-300 text-base leading-relaxed max-w-xl mb-6">
            Precision Meta Ads and Google Ads campaigns engineered for immediate sales acquisition, lead volume, and sustainable ROAS across e-commerce, agriculture, and professional service sectors.
          </p>
        </div>

        <div class="pt-6 border-t border-white/10 grid grid-cols-2 sm:grid-cols-3 gap-4 text-xs font-semibold text-slate-300">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span> Meta & Instagram Ads
          </div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-teal-400"></span> Google Search & PPC
          </div>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span> Funnel Retargeting
          </div>
        </div>
      </div>

      <!-- Panel 02: Website Design and E-Commerce (4 Cols) -->
      <div class="md:col-span-12 lg:col-span-4 p-8 md:p-10 rounded-2xl bg-slate-900/80 border border-white/10 hover:border-teal-500/40 transition-all duration-300 group shadow-xl flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-8">
            <span class="font-mono text-4xl font-extrabold text-teal-400 opacity-60 group-hover:opacity-100 transition-opacity">02</span>
            <span class="w-12 h-12 rounded-xl bg-teal-500/10 border border-teal-500/20 flex items-center justify-center text-teal-400 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
            </span>
          </div>

          <h3 class="font-heading text-xl md:text-2xl font-extrabold text-white mb-4 group-hover:text-teal-300 transition-colors">
            Website Design and E-Commerce
          </h3>

          <p class="text-slate-300 text-sm leading-relaxed mb-6">
            Custom high-converting websites and WooCommerce platforms designed for ultra-fast load speed, seamless mobile checkout, and high conversion rates.
          </p>
        </div>

        <div class="pt-4 border-t border-white/10 text-xs font-mono text-teal-400">
          Astro • WooCommerce • WordPress
        </div>
      </div>

      <!-- Panel 03: SEO and Local Search (4 Cols) -->
      <div class="md:col-span-12 lg:col-span-4 p-8 md:p-10 rounded-2xl bg-slate-900/80 border border-white/10 hover:border-indigo-500/40 transition-all duration-300 group shadow-xl flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-8">
            <span class="font-mono text-4xl font-extrabold text-indigo-400 opacity-60 group-hover:opacity-100 transition-opacity">03</span>
            <span class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </span>
          </div>

          <h3 class="font-heading text-xl md:text-2xl font-extrabold text-white mb-4 group-hover:text-indigo-300 transition-colors">
            SEO and Local Search
          </h3>

          <p class="text-slate-300 text-sm leading-relaxed mb-6">
            Technical search engine optimization and local service landing pages built to capture organic demand across competitive commercial keywords.
          </p>
        </div>

        <div class="pt-4 border-t border-white/10 text-xs font-mono text-indigo-400">
          Technical Audit • Content Strategy • Maps
        </div>
      </div>

      <!-- Panel 04: Creative Content (4 Cols) -->
      <div class="md:col-span-12 lg:col-span-4 p-8 md:p-10 rounded-2xl bg-slate-900/80 border border-white/10 hover:border-blue-500/40 transition-all duration-300 group shadow-xl flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-8">
            <span class="font-mono text-4xl font-extrabold text-blue-400 opacity-60 group-hover:opacity-100 transition-opacity">04</span>
            <span class="w-12 h-12 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </span>
          </div>

          <h3 class="font-heading text-xl md:text-2xl font-extrabold text-white mb-4 group-hover:text-blue-300 transition-colors">
            Creative Content
          </h3>

          <p class="text-slate-300 text-sm leading-relaxed mb-6">
            Performance ad creatives, short-form video editing, product graphics, and social content tailored for social feed conversion.
          </p>
        </div>

        <div class="pt-4 border-t border-white/10 text-xs font-mono text-blue-400">
          Ad Creatives • Short-Form Video • Graphics
        </div>
      </div>

      <!-- Panel 05: AI Marketing Systems (4 Cols) -->
      <div class="md:col-span-12 lg:col-span-4 p-8 md:p-10 rounded-2xl bg-slate-900/80 border border-white/10 hover:border-teal-500/40 transition-all duration-300 group shadow-xl flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-8">
            <span class="font-mono text-4xl font-extrabold text-teal-400 opacity-60 group-hover:opacity-100 transition-opacity">05</span>
            <span class="w-12 h-12 rounded-xl bg-teal-500/10 border border-teal-500/20 flex items-center justify-center text-teal-400 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </span>
          </div>

          <h3 class="font-heading text-xl md:text-2xl font-extrabold text-white mb-4 group-hover:text-teal-300 transition-colors">
            AI Marketing Systems
          </h3>

          <p class="text-slate-300 text-sm leading-relaxed mb-6">
            Automated lead qualification workflows, AI-assisted content pipelines, and automated customer routing systems for operational efficiency.
          </p>
        </div>

        <div class="pt-4 border-t border-white/10 text-xs font-mono text-teal-400">
          Lead Automation • Routing • AI Workflows
        </div>
      </div>

      <!-- Panel 06: Campaign Strategy (Featured Full Width or Span 12) -->
      <div class="col-span-12 p-8 md:p-10 rounded-2xl bg-gradient-to-r from-blue-950/60 via-slate-900 to-slate-950 border border-white/15 hover:border-blue-400/40 transition-all duration-300 group shadow-xl flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="max-w-2xl">
          <div class="flex items-center gap-3 mb-4">
            <span class="font-mono text-2xl font-extrabold text-blue-400">06</span>
            <span class="text-xs font-extrabold text-blue-300 uppercase tracking-widest bg-blue-500/10 px-3 py-1 rounded-full border border-blue-500/20">STRATEGIC ARCHITECTURE</span>
          </div>
          <h3 class="font-heading text-2xl md:text-3xl font-extrabold text-white mb-3">
            Campaign Strategy & Growth Consulting
          </h3>
          <p class="text-slate-300 text-sm md:text-base leading-relaxed">
            Holistic commercial positioning, marketing budget allocation, multi-channel rollout plans, and data-backed scale advisory for business owners.
          </p>
        </div>

        <div class="shrink-0">
          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold text-sm shadow-lg shadow-blue-600/25 transition-all">
            <span>Get Strategy Audit</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
        </div>
      </div>

    </div>
  </Container>
</section>
