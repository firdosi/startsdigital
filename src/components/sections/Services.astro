---
import Container from '../ui/Container.astro';
import { getAssetPath } from '../../data/site';

const serviceCategories = [
  {
    id: 'performance-lead-gen',
    title: 'Performance & Lead Generation',
    tagline: 'PAID MEDIA & FUNNEL SCALING',
    description: 'Data-driven ad campaigns engineered to capture intent, generate qualified inquiries, and drive e-commerce sales.',
    deliverables: [
      'Meta Advertising (FB & IG)',
      'Google Advertising (Search & Shopping)',
      'Lead Generation Systems',
      'Campaign Management',
      'Audience Retargeting'
    ],
    theme: 'light',
  },
  {
    id: 'websites-ecommerce-seo',
    title: 'Websites, E-Commerce & SEO',
    tagline: 'ENGINEERING & ORGANIC GROWTH',
    description: 'High-speed conversion websites, online stores, and technical search optimization built for sustainable visibility.',
    deliverables: [
      'Website Development (Astro & Modern Stacks)',
      'High-Converting Landing Pages',
      'WooCommerce & Shopify Stores',
      'Technical & On-Page SEO',
      'Local Search Optimization',
      'Conversion Rate Improvements'
    ],
    theme: 'dark',
  },
  {
    id: 'creative-content-ai',
    title: 'Creative Content & AI Systems',
    tagline: 'PRODUCTION & AUTOMATION',
    description: 'Short-form video editing, scroll-stopping ad creatives, and practical AI marketing automation workflows.',
    deliverables: [
      'Short-Form Video & UGC Ad Creatives',
      'Ad Hook Testing & Production',
      'AI Video & Copy Production',
      'Marketing Automation',
      'Custom AI Workflows'
    ],
    theme: 'visual',
    image: getAssetPath('/prototype/content-strategy.webp'),
    altText: 'Concept visual preview for creative content and AI systems',
  },
];
---

<section id="services" class="py-20 md:py-32 bg-brand-white border-b border-brand-light-border">
  <Container class="space-y-16">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 pb-8 border-b border-brand-light-border">
      <div class="space-y-3 max-w-2xl">
        <span class="text-xs font-bold tracking-[0.2em] text-brand-teal uppercase font-heading">
          THREE CORE SOLUTION PILLARS
        </span>
        <h2 class="font-heading text-3xl sm:text-4xl md:text-5xl font-extrabold text-brand-black">
          Integrated Growth Capabilities
        </h2>
      </div>
      <p class="font-body text-base text-brand-text max-w-md leading-relaxed">
        Instead of isolated services, we deploy three connected solution pillars engineered to acquire, convert, and scale.
      </p>
    </div>

    <!-- 3 Visually Distinct Large Panels (No repetitive 6 cards) -->
    <div class="space-y-10">
      <!-- Panel 1: Performance & Lead Generation (Light Panel with Accent Border) -->
      <div class="bg-white border-2 border-brand-blue/20 rounded-3xl p-8 sm:p-12 shadow-md grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-5 space-y-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-brand-blue/10 flex items-center justify-center text-brand-blue shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <circle cx="12" cy="12" r="6" />
                <circle cx="12" cy="12" r="2" />
              </svg>
            </div>
            <span class="text-xs font-extrabold tracking-widest text-brand-blue uppercase font-heading bg-brand-blue/10 px-3 py-1 rounded-md">
              {serviceCategories[0].tagline}
            </span>
          </div>

          <h3 class="font-heading text-2xl sm:text-3xl font-extrabold text-brand-black">
            {serviceCategories[0].title}
          </h3>
          <p class="font-body text-base text-brand-text leading-relaxed">
            {serviceCategories[0].description}
          </p>
        </div>

        <div class="lg:col-span-7 bg-brand-grey/20 border border-brand-light-border rounded-2xl p-6 sm:p-8">
          <h4 class="text-xs font-bold uppercase tracking-wider text-brand-black mb-4 font-heading">Core Capabilities & Deliverables</h4>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {serviceCategories[0].deliverables.map((item) => (
              <div class="flex items-center gap-3 p-3 bg-white border border-brand-light-border rounded-xl">
                <svg class="w-5 h-5 text-brand-blue shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="font-body text-base font-semibold text-brand-black">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Panel 2: Websites, E-Commerce & SEO (Dark Navy High-Contrast Panel) -->
      <div class="bg-brand-navy text-white rounded-3xl p-8 sm:p-12 shadow-xl grid grid-cols-1 lg:grid-cols-12 gap-8 items-center border border-white/10">
        <div class="lg:col-span-5 space-y-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-brand-teal/20 flex items-center justify-center text-brand-teal shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <span class="text-xs font-extrabold tracking-widest text-brand-teal uppercase font-heading bg-brand-teal/20 px-3 py-1 rounded-md">
              {serviceCategories[1].tagline}
            </span>
          </div>

          <h3 class="font-heading text-2xl sm:text-3xl font-extrabold text-white">
            {serviceCategories[1].title}
          </h3>
          <p class="font-body text-base text-brand-muted-dark leading-relaxed">
            {serviceCategories[1].description}
          </p>
        </div>

        <div class="lg:col-span-7 bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8">
          <h4 class="text-xs font-bold uppercase tracking-wider text-brand-teal mb-4 font-heading">Core Capabilities & Deliverables</h4>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {serviceCategories[1].deliverables.map((item) => (
              <div class="flex items-center gap-3 p-3 bg-white/10 border border-white/10 rounded-xl">
                <svg class="w-5 h-5 text-brand-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="font-body text-base font-semibold text-white">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Panel 3: Creative Content & AI Systems (Image-Led Panel with Lazy Loading) -->
      <div class="bg-brand-blue/5 border border-brand-blue/20 rounded-3xl p-8 sm:p-12 shadow-md grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-6 space-y-6">
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-xl bg-brand-blue/10 flex items-center justify-center text-brand-blue shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </div>
              <span class="text-xs font-extrabold tracking-widest text-brand-blue uppercase font-heading bg-brand-blue/10 px-3 py-1 rounded-md">
                {serviceCategories[2].tagline}
              </span>
            </div>

            <h3 class="font-heading text-2xl sm:text-3xl font-extrabold text-brand-black">
              {serviceCategories[2].title}
            </h3>
            <p class="font-body text-base text-brand-text leading-relaxed">
              {serviceCategories[2].description}
            </p>
          </div>

          <div class="space-y-2">
            <h4 class="text-xs font-bold uppercase tracking-wider text-brand-black font-heading">Deliverables Breakdown</h4>
            <div class="flex flex-wrap gap-2">
              {serviceCategories[2].deliverables.map((item) => (
                <span class="text-sm font-semibold text-brand-black bg-white border border-brand-light-border px-3 py-1.5 rounded-lg shadow-2xs">
                  {item}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Concept Visual Image Side (Below-the-fold: loading="lazy" decoding="async") -->
        <div class="lg:col-span-6">
          <div class="relative rounded-2xl border border-brand-light-border bg-white p-2 shadow-lg overflow-hidden">
            <img 
              src={serviceCategories[2].image} 
              alt={serviceCategories[2].altText}
              width="600"
              height="380"
              loading="lazy"
              decoding="async"
              class="w-full h-auto object-cover rounded-xl border border-brand-light-border/40"
            />
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
