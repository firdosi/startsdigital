---
interface Props {
  color?: 'orange' | 'purple' | 'lime' | 'green' | 'coral';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  delay?: string;
}

const { color = 'lime', size = 'md', class: className = '', delay = '0s' } = Astro.props;

const colorClasses = {
  orange: 'text-[#ff762b]',
  purple: 'text-[#9a83f5]',
  lime: 'text-[#ddff35]',
  green: 'text-[#39c98a]',
  coral: 'text-[#ff514b]',
};

const sizeClasses = {
  sm: 'text-lg',
  md: 'text-2xl',
  lg: 'text-4xl',
};
---

<div
  aria-hidden="true"
  class:list={[
    'pointer-events-none absolute font-bold animate-float-gentle select-none opacity-80',
    colorClasses[color],
    sizeClasses[size],
    className
  ]}
  style={`animation-delay: ${delay};`}
>
  ✦
</div>
