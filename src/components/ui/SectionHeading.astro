---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  alignment?: 'left' | 'center';
  theme?: 'dark' | 'light';
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  alignment = 'left',
  theme = 'dark',
  class: className = '',
} = Astro.props;

const alignmentClasses = {
  left: 'text-left',
  center: 'text-center mx-auto',
};

const titleColor = theme === 'light' ? 'text-brand-black' : 'text-brand-white';
const descColor = theme === 'light' ? 'text-brand-text' : 'text-brand-text';
---

<div class={`max-w-3xl ${alignmentClasses[alignment]} ${className}`}>
  {eyebrow && (
    <span class="inline-block text-xs font-bold tracking-[0.15em] text-brand-teal uppercase mb-3 font-heading">
      {eyebrow}
    </span>
  )}
  <h2 class={`font-heading text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight ${titleColor} leading-tight`}>
    {title}
  </h2>
  {description && (
    <p class={`mt-4 text-base sm:text-lg ${descColor} font-light leading-relaxed`}>
      {description}
    </p>
  )}
</div>
