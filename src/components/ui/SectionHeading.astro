---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  alignment?: 'left' | 'center';
  theme?: 'dark' | 'light';
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  alignment = 'left',
  theme = 'dark',
  class: className = '',
} = Astro.props;

const alignmentClasses = {
  left: 'text-left',
  center: 'text-center mx-auto',
};

const titleColor = theme === 'light' ? 'text-[#061d33]' : 'text-white';
const descColor = theme === 'light' ? 'text-slate-700' : 'text-slate-300';
---

<div class={`max-w-3xl space-y-3 ${alignmentClasses[alignment]} ${className}`}>
  {eyebrow && (
    <span class="block text-xs font-medium tracking-[0.06em] text-[#ff762b] uppercase font-mono">
      {eyebrow}
    </span>
  )}
  <h2 class={`font-heading text-[31px] md:text-[36px] lg:text-[44px] font-bold tracking-[-0.025em] ${titleColor} leading-[1.15]`}>
    {title}
  </h2>
  {description && (
    <p class={`text-base sm:text-lg ${descColor} font-body font-normal leading-[1.65]`}>
      {description}
    </p>
  )}
</div>
